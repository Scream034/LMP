<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="LMP.UI.Features.Shell.SplashWindow"
    Title="LMP"
    Width="500" Height="380"
    WindowStartupLocation="CenterScreen"
    CanResize="False"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    WindowDecorations="None"
    Background="Transparent"
    TransparencyLevelHint="Transparent">

    <Border Background="{DynamicResource BgPrimaryBrush}"
        CornerRadius="16"
        BorderThickness="1"
        BorderBrush="{DynamicResource BgHighlightBrush}"
        BoxShadow="0 8 32 4 #40000000">

        <Grid RowDefinitions="*, Auto, Auto, Auto, 56">

            <!-- ═══ LOGO SECTION ═══ -->
            <StackPanel Grid.Row="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="24">

                <!-- Sci-Fi Icon -->
                <Grid Width="96" Height="96" HorizontalAlignment="Center">
                    <Border Width="96" Height="96" CornerRadius="20"
                        Background="{DynamicResource AccentBrush}" Opacity="0.2" />

                    <Border Width="80" Height="80"
                        Background="{DynamicResource BgSecondaryBrush}"
                        CornerRadius="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Grid>
                            <Path Data="M8,5 L19,12 L8,19 Z"
                                Fill="{DynamicResource AccentBrush}"
                                Stretch="Uniform"
                                Width="32" Height="32"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0" />

                            <StackPanel Orientation="Horizontal" Spacing="-3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,10,10">
                                <Path Data="M0,0 L6,6 L0,12"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="2.5"
                                    StrokeLineCap="Round"
                                    Width="8" Height="12"
                                    Stretch="Uniform" />
                                <Path Data="M0,0 L6,6 L0,12"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="2.5"
                                    StrokeLineCap="Round"
                                    Width="8" Height="12"
                                    Stretch="Uniform" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- App Name + Tagline -->
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="LITE MUSIC PLAYER"
                        FontSize="24"
                        FontWeight="Bold"
                        LetterSpacing="4"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        HorizontalAlignment="Center" />

                    <TextBlock Text="Fast. Simple. Powerful."
                        FontSize="12"
                        LetterSpacing="2"
                        Foreground="{DynamicResource TextMutedBrush}"
                        HorizontalAlignment="Center"
                        Opacity="0.7" />
                </StackPanel>
            </StackPanel>

            <!-- ═══ STATUS TEXT ═══ -->
            <TextBlock Grid.Row="1"
                x:Name="StatusText"
                Text="Initializing..."
                FontSize="13"
                Foreground="{DynamicResource TextSecondaryBrush}"
                HorizontalAlignment="Center"
                Margin="0,0,0,16" />

            <!-- ═══ PROGRESS BAR ═══ -->
            <Border Grid.Row="2"
                Height="3"
                Margin="48,0"
                CornerRadius="1.5"
                Background="{DynamicResource BgHighlightBrush}"
                ClipToBounds="True">

                <Border x:Name="ProgressFill"
                    HorizontalAlignment="Left"
                    Width="0"
                    Height="3"
                    Background="{DynamicResource AccentBrush}"
                    CornerRadius="1.5">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.3"
                                Easing="CubicEaseOut" />
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </Border>

            <!-- ═══ VERSION + BUILD INFO ═══ -->
            <StackPanel Grid.Row="3"
                HorizontalAlignment="Center"
                Spacing="4"
                Margin="0,16,0,0">

                <!-- Version + Git Hash -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
                    <TextBlock x:Name="VersionText"
                        Text="v1.0.142-dev"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="•"
                        FontSize="12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Opacity="0.5" />
                    <TextBlock x:Name="GitHashText"
                        Text="abc1234"
                        FontSize="12"
                        FontFamily="Consolas, monospace"
                        Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>

                <!-- Commit Count + Build Date -->
                <TextBlock x:Name="BuildInfoText"
                    Text="142 commits • 2024-01-15"
                    FontSize="11"
                    Foreground="{DynamicResource TextMutedBrush}"
                    HorizontalAlignment="Center"
                    Opacity="0.6" />
            </StackPanel>

            <!-- ═══ FOOTER: GitHub Link ═══ -->
            <Border Grid.Row="4"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="0,0,16,16">
                <Button x:Name="GitHubButton"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Padding="16,8">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="Button:pointerover TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Style>
                        <Style Selector="Button:pointerover Path">
                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                        </Style>
                    </Button.Styles>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- GitHub Icon -->
                        <Path
                            Data="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                            Fill="{DynamicResource TextMutedBrush}"
                            Stretch="Uniform"
                            Width="16" Height="16"
                            VerticalAlignment="Center" />

                        <TextBlock x:Name="GitHubUrlText"
                            Text="github.com/paralax/LMP"
                            FontSize="12"
                            Foreground="{DynamicResource TextMutedBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>