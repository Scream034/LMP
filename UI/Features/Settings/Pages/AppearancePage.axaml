<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.UI.Features.Settings"
    xmlns:controls="using:LMP.UI.Features.Settings.Controls"
    x:Class="LMP.UI.Features.Settings.Pages.AppearancePage"
    x:DataType="vm:SettingsViewModel"
    x:CompileBindings="True">

    <StackPanel Margin="32,24">
        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
            <PathIcon Grid.Column="0" Data="{StaticResource Icon.Palette}"
                Width="20" Height="20" VerticalAlignment="Center"
                Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Grid.Column="1" Classes="h2"
                Text="{Binding L[Settings_Appearance]}"
                VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>

        <Border Classes="card">
            <StackPanel Spacing="20">

                <!--  Theme preset  -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Theme_Presets]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Theme_PresetsDesc]}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                        ItemsSource="{Binding ThemePresets}"
                        SelectedItem="{Binding SelectedPreset}"
                        PlaceholderText="{Binding L[Theme_SelectPreset]}"
                        MinWidth="200" />
                </Grid>

                <Separator Background="{DynamicResource BgHighlightBrush}" Height="1" />

                <!--  Accent color  -->
                <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Classes="color-name" Text="{Binding L[Theme_AccentColor]}" />
                        <TextBlock Classes="color-hint" Text="{Binding L[Theme_AccentColorDesc]}" />
                    </StackPanel>
                    <controls:ColorPickerButton Grid.Column="1"
                        Color="{Binding AccentColor, Mode=TwoWay}" />
                </Grid>

                <!--  Advanced colors  -->
                <Expander Header="{Binding L[Settings_AdvancedColors]}" IsExpanded="False">
                    <StackPanel Spacing="0" Margin="0,16,0,0">

                        <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="color-name" Text="{Binding L[Theme_BgPrimary]}" />
                                <TextBlock Classes="color-hint"
                                    Text="{Binding L[Theme_BgPrimaryDesc]}" />
                            </StackPanel>
                            <controls:ColorPickerButton Grid.Column="1"
                                Color="{Binding BgPrimaryColor, Mode=TwoWay}" />
                        </Grid>

                        <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="color-name"
                                    Text="{Binding L[Theme_BgSecondary]}" />
                                <TextBlock Classes="color-hint"
                                    Text="{Binding L[Theme_BgSecondaryDesc]}" />
                            </StackPanel>
                            <controls:ColorPickerButton Grid.Column="1"
                                Color="{Binding BgSecondaryColor, Mode=TwoWay}" />
                        </Grid>

                        <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="color-name" Text="{Binding L[Theme_BgElevated]}" />
                                <TextBlock Classes="color-hint"
                                    Text="{Binding L[Theme_BgElevatedDesc]}" />
                            </StackPanel>
                            <controls:ColorPickerButton Grid.Column="1"
                                Color="{Binding BgElevatedColor, Mode=TwoWay}" />
                        </Grid>

                        <Separator Background="{DynamicResource BgHighlightBrush}"
                            Height="1" Margin="0,8,0,16" />

                        <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="color-name"
                                    Text="{Binding L[Theme_TextPrimary]}" />
                                <TextBlock Classes="color-hint"
                                    Text="{Binding L[Theme_TextPrimaryDesc]}" />
                            </StackPanel>
                            <controls:ColorPickerButton Grid.Column="1"
                                Color="{Binding TextPrimaryColor, Mode=TwoWay}" />
                        </Grid>

                        <Grid Classes="color-row" ColumnDefinitions="*, Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Classes="color-name"
                                    Text="{Binding L[Theme_TextSecondary]}" />
                                <TextBlock Classes="color-hint"
                                    Text="{Binding L[Theme_TextSecondaryDesc]}" />
                            </StackPanel>
                            <controls:ColorPickerButton Grid.Column="1"
                                Color="{Binding TextSecondaryColor, Mode=TwoWay}" />
                        </Grid>

                    </StackPanel>
                </Expander>

                <!--  Apply / Reset  -->
                <StackPanel Orientation="Horizontal" Spacing="16"
                    IsVisible="{Binding HasUnsavedThemeChanges}"
                    Margin="0,10,0,0">
                    <Button Classes="primary-btn"
                        Content="{Binding L[Common_Apply]}"
                        Command="{Binding ApplyThemeCommand}" />
                    <Button Content="{Binding L[Common_Reset]}"
                        Command="{Binding ResetThemeCommand}" />
                </StackPanel>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>