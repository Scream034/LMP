<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.UI.Features.Settings"
    x:Class="LMP.UI.Features.Settings.Pages.NetworkPage"
    x:DataType="vm:SettingsViewModel"
    x:CompileBindings="True">

    <StackPanel Margin="32,24">
        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
            <PathIcon Grid.Column="0" Data="{StaticResource Icon.Web}"
                Width="20" Height="20" VerticalAlignment="Center"
                Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Grid.Column="1" Classes="h2"
                Text="{Binding L[Settings_Network]}"
                VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>

        <Border Classes="card">
            <StackPanel Spacing="20">

                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Settings_NetProfile]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Settings_NetProfileDesc]}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                        SelectedItem="{Binding SelectedInternetProfile}"
                        ItemsSource="{Binding InternetProfileOptions}"
                        MinWidth="200" />
                </Grid>

                <Expander Header="{Binding L[Settings_Proxy]}">
                    <StackPanel Spacing="12">
                        <CheckBox Content="{Binding L[Common_Enable]}"
                            IsChecked="{Binding ProxyEnabled}" />
                        <Grid ColumnDefinitions="3*, 16, 1*"
                            IsEnabled="{Binding ProxyEnabled}">
                            <TextBox Grid.Column="0"
                                Text="{Binding ProxyHost}"
                                PlaceholderText="127.0.0.1" />
                            <TextBox Grid.Column="2"
                                Text="{Binding ProxyPort}"
                                PlaceholderText="8080" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Border Background="{DynamicResource SystemWarnOrangeBrush}"
                    CornerRadius="4" Padding="12"
                    IsVisible="{Binding NetworkRestartRequired}">
                    <TextBlock Foreground="{DynamicResource TextDarkBrush}"
                        FontWeight="Bold"
                        Text="{Binding L[Settings_RestartRequired]}"
                        HorizontalAlignment="Center" />
                </Border>

                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Settings_Client]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Settings_ClientDesc]}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                        ItemsSource="{Binding ClientOptions}"
                        SelectedItem="{Binding SelectedClient}"
                        MinWidth="200" />
                </Grid>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>