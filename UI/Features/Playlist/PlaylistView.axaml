<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.UI.Features.Playlist"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:controls="using:LMP.UI.Controls"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:LMP.UI.Behaviors"
    x:Class="LMP.UI.Features.Playlist.PlaylistView"
    x:DataType="vm:PlaylistViewModel">

    <UserControl.Styles>
        <Style Selector="GridSplitter.header-splitter">
            <Setter Property="Background" Value="{DynamicResource BgElevated}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Opacity" Value="0.1" />
            <Setter Property="MinHeight" Value="3" />
            <Setter Property="Cursor" Value="SizeNorthSouth" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="GridSplitter.header-splitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="Grid.playlist-content">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid.playlist-content.loaded">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.playlist-main-btn">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"
                        Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.playlist-main-btn:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.playlist-main-btn:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="RenderTransform" Value="scale(0.88)" />
        </Style>

        <!-- Active Playing State: Glowing/Pulse Breathing Animation (Smooth and subtle) -->
        <Style Selector="Button.playlist-main-btn.is-playing">
            <Style.Animations>
                <Animation Duration="0:0:1.8" IterationCount="Infinite"
                    PlaybackDirection="Alternate" Easing="SineEaseInOut" FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.6" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Dynamic transitions specifically for PathIcon (SAFE) -->
        <Style Selector="Button.playlist-main-btn PathIcon.state-replace">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Hover on non-playing PathIcon -> Accent Color -->
        <Style Selector="Button.playlist-main-btn:pointerover PathIcon.state-replace">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Active playing PathIcon -> Accent Color -->
        <Style Selector="Button.playlist-main-btn.is-playing PathIcon.state-replace">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Dynamic transitions specifically for StackPanel (SAFE - NO Foreground!) -->
        <Style Selector="Button.playlist-main-btn StackPanel.state-pure">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <!-- STATE 1: PURE (Equalizer) -->
        <Style Selector="Button.playlist-main-btn.is-pure StackPanel.state-pure">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- STATE 2: DIRTY / NOT ACTIVE (PlaylistPlay Icon) -->
        <Style Selector="Button.playlist-main-btn:not(.is-pure) PathIcon.state-replace">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- Equalizer Bars Base (Stopped / Paused State) -->
        <Style Selector="Border.eq-bar">
            <Setter Property="Width" Value="4" />
            <Setter Property="Height" Value="5" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.4" Easing="CubicEaseOut" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Hover on Equalizer Bars -> Accent Color -->
        <Style Selector="Button.playlist-main-btn:pointerover Border.eq-bar">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Active Playing Equalizer Bars -> Accent Color -->
        <Style Selector="Button.playlist-main-btn.is-playing Border.eq-bar">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Animations when Playing (Taller and thicker for 48px footprint) -->
        <Style Selector="Button.playlist-main-btn.is-playing Border.eq-bar.b1">
            <Style.Animations>
                <Animation Duration="0:0:0.5" IterationCount="Infinite"
                    PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Height" Value="6" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Height" Value="22" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.playlist-main-btn.is-playing Border.eq-bar.b2">
            <Style.Animations>
                <Animation Duration="0:0:0.7" IterationCount="Infinite"
                    PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Height" Value="26" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Height" Value="6" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.playlist-main-btn.is-playing Border.eq-bar.b3">
            <Style.Animations>
                <Animation Duration="0:0:0.6" IterationCount="Infinite"
                    PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Height" Value="8" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Height" Value="20" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.playlist-main-btn.is-playing Border.eq-bar.b4">
            <Style.Animations>
                <Animation Duration="0:0:0.55" IterationCount="Infinite"
                    PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Height" Value="18" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Height" Value="6" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid Classes="playlist-content"
        Classes.loaded="{Binding !IsLoading}">
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding HeaderHeight, Mode=TwoWay}"
                MinHeight="280"
                MaxHeight="400" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Panel Grid.Row="0" HorizontalAlignment="Stretch">

            <!-- 1. Базовый фон -->
            <Border Background="{DynamicResource BgPrimaryBrush}" />

            <!-- 2. Обычный плейлист -->
            <Border Background="{Binding HeaderBackground}"
                IsVisible="{Binding !IsLikedPlaylist}"
                Padding="32,24,32,24">
                <Grid ColumnDefinitions="Auto, *">
                    <!-- COVER -->
                    <Border Grid.Column="0"
                        Width="180" Height="180"
                        CornerRadius="8" ClipToBounds="True"
                        Background="{DynamicResource BgSkeletonBrush}"
                        BoxShadow="{StaticResource CardShadow}"
                        VerticalAlignment="Bottom">
                        <Panel>
                            <PathIcon Data="{StaticResource Icon.MusicNote}"
                                Width="64" Height="64"
                                Foreground="{DynamicResource TextMutedBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ThumbnailUrl,
                                    Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                            <Image
                                controls:SmartImage.Source="{Binding ThumbnailUrl}"
                                controls:SmartImage.Quality="High"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </Panel>
                    </Border>

                    <!-- INFO & ACTIONS -->
                    <ContentControl Grid.Column="1" Content="{Binding}"
                        ContentTemplate="{StaticResource PlaylistHeaderInfoTemplate}" />
                </Grid>
            </Border>

            <!-- 3. Liked Playlist -->
            <Border IsVisible="{Binding IsLikedPlaylist}" Padding="32,24,32,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="{DynamicResource Accent}" Offset="0.0" />
                        <GradientStop Color="{DynamicResource BgElevated}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="Auto, *">
                    <!-- COVER: Liked -->
                    <Border Grid.Column="0"
                        Width="180" Height="180"
                        CornerRadius="8" ClipToBounds="True"
                        BoxShadow="{StaticResource CardShadow}"
                        VerticalAlignment="Bottom">
                        <Border Classes="liked-gradient">
                            <PathIcon Data="{StaticResource Icon.Heart}"
                                Width="72" Height="72"
                                Foreground="{DynamicResource AccentButtonTextBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.9" />
                        </Border>
                    </Border>

                    <!-- INFO & ACTIONS -->
                    <ContentControl Grid.Column="1" Content="{Binding}"
                        ContentTemplate="{StaticResource PlaylistHeaderInfoTemplate}" />
                </Grid>
            </Border>
        </Panel>

        <!-- ═══ SPLITTER ═══ -->
        <GridSplitter Grid.Row="1"
            Classes="header-splitter"
            ResizeDirection="Rows"
            ResizeBehavior="PreviousAndNext"
            HorizontalAlignment="Stretch" />

        <!-- ═══ TRACK LIST ═══ -->
        <ScrollViewer Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled"
            UseLayoutRounding="True">
            <controls:TrackListControl
                Margin="24,12,24,0"
                Items="{Binding Items}"
                IsLoading="{Binding IsLoading}"
                IsPlaylistContext="{Binding CanEdit}"
                EnableReordering="{Binding CanReorderItems}"
                MoveItemCommand="{Binding MoveItemCommand}" />
        </ScrollViewer>
    </Grid>

    <!-- ═══ SHARED TEMPLATE: Playlist Header Info & Actions ═══ -->
    <UserControl.Resources>
        <DataTemplate x:Key="PlaylistHeaderInfoTemplate" x:DataType="vm:PlaylistViewModel">
            <Grid Margin="32,0,0,0" RowDefinitions="*, Auto">

                <!-- Title, Description, Stats -->
                <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Margin="0,0,0,24">

                    <!-- Название -->
                    <TextBlock Text="{Binding PlaylistName}"
                        FontSize="42" FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis"
                        Padding="0,0,0,6"
                        Margin="0,0,0,2" />

                    <!-- Описание -->
                    <TextBlock Text="{Binding Description}"
                        FontSize="14"
                        Foreground="{DynamicResource TextMutedBrush}"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis"
                        Margin="0,4,0,0"
                        IsVisible="{Binding Description,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                    <!-- Статистика -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBlock Text="{Binding FormattedTrackCount}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="•" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding FormattedDuration}"
                            Foreground="{DynamicResource TextSecondaryBrush}" />

                        <Panel IsVisible="{Binding HasYoutubeLink}">
                            <controls:CopyLinkButton
                                CopyUrl="{Binding PlaylistYoutubeUrl}"
                                SuccessText="{Binding L[Playlist_LinkCopied]}"
                                ToolTipText="{Binding L[Track_CopyLink]}"
                                ShowHoverRing="False"
                                ButtonSize="18"
                                IconSize="13"
                                VerticalAlignment="Center"
                                Margin="2,0,0,0" />
                        </Panel>

                        <PathIcon Data="{StaticResource Icon.CloudCheck}"
                            Width="14" Height="14"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            IsVisible="{Binding IsCloud}"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{Binding L[Library_CloudSyncTooltip]}" />
                    </StackPanel>
                </StackPanel>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="1"
                    Orientation="Horizontal" Spacing="12"
                    VerticalAlignment="Center">

                    <!-- Смарт-кнопка -->
                    <Button Classes="playlist-main-btn"
                        Classes.is-pure="{Binding IsQueuePure}"
                        Classes.is-playing="{Binding IsPlayingPure}"
                        Command="{Binding PlayAllCommand}"
                        ToolTip.Tip="{Binding PlayButtonTooltip}">
                        <Panel>
                            <!-- Иконка Заменить очередь / Начать играть (IsQueuePure == false) -->
                            <PathIcon Data="{StaticResource Icon.PlaylistPlay}"
                                Width="28" Height="28"
                                Classes="state-replace" />

                            <!-- Эквалайзер (IsQueuePure == true) -->
                            <StackPanel Classes="state-pure"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Height="28">
                                <Border Classes="eq-bar b1" />
                                <Border Classes="eq-bar b2" />
                                <Border Classes="eq-bar b3" />
                                <Border Classes="eq-bar b4" />
                            </StackPanel>
                        </Panel>
                    </Button>

                    <Button Classes="playback-btn"
                        Command="{Binding ShufflePlayCommand}"
                        Width="40" Height="40" CornerRadius="20"
                        ToolTip.Tip="{Binding L[Playlist_ShufflePlay]}">
                        <PathIcon Data="{StaticResource Icon.Shuffle}"
                            Width="20" Height="20"
                            Foreground="{Binding IsShuffleActive,
                                Converter={StaticResource BoolToSelector},
                                ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                    </Button>

                    <Button Classes="playback-btn"
                        Command="{Binding AddToQueueCommand}"
                        Width="40" Height="40" CornerRadius="20"
                        ToolTip.Tip="{Binding L[Queue_Add]}">
                        <PathIcon Data="{StaticResource Icon.PlaylistPlus}" Width="20" Height="20" />
                    </Button>

                    <Button Classes="playback-btn"
                        Command="{Binding DownloadAllCommand}"
                        Width="40" Height="40" CornerRadius="20"
                        ToolTip.Tip="{Binding L[Playlist_DownloadAll]}">
                        <PathIcon Data="{StaticResource Icon.Download}"
                            Width="20" Height="20"
                            Foreground="{Binding IsDownloadingActive,
                                Converter={StaticResource BoolToSelector},
                                ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                    </Button>

                    <Button Classes="playback-btn"
                        Command="{Binding RefreshPlaylistCommand}"
                        IsVisible="{Binding IsCloud}"
                        Width="40" Height="40" CornerRadius="20"
                        ToolTip.Tip="{Binding L[Playlist_SyncWithCloud]}">
                        <Panel>
                            <PathIcon Data="{StaticResource Icon.Sync}"
                                Width="20" Height="20"
                                IsVisible="{Binding !IsSyncing}" />
                            <PathIcon Data="{StaticResource Icon.Sync}"
                                Width="20" Height="20"
                                IsVisible="{Binding IsSyncing}"
                                Classes="spinning" />
                        </Panel>
                    </Button>

                    <Button Classes="playback-btn"
                        Command="{Binding EditPlaylistCommand}"
                        IsVisible="{Binding CanEdit}"
                        Width="40" Height="40" CornerRadius="20"
                        ToolTip.Tip="{Binding L[EditPlaylist_Title]}">
                        <PathIcon Data="{StaticResource Icon.Pencil}" Width="20" Height="20" />
                    </Button>

                    <Border Width="1" Height="24"
                        Background="{DynamicResource BgHighlightBrush}"
                        Margin="8,0" />

                    <controls:FilterBar
                        FilterText="{Binding FilterQuery}"
                        Watermark="{Binding L[Search_LocalFilterTitle]}"
                        Width="220" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
</UserControl>