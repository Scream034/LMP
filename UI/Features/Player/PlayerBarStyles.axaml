<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.icon-btn.popup-open">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.format-btn.popup-open">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.icon-btn PathIcon.heart-icon">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.icon-btn:pressed PathIcon.heart-icon">
        <Setter Property="RenderTransform" Value="scale(1.25)" />
    </Style>

    <Style Selector="Grid.track-container">
        <Setter Property="RenderTransform" Value="scaleY(1)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Grid.seek-container:pointerover Grid.track-container">
        <Setter Property="RenderTransform" Value="scaleY(2.0)" />
    </Style>
    <Style Selector="Grid.seek-container.dragging Grid.track-container">
        <Setter Property="RenderTransform" Value="scaleY(2.0)" />
    </Style>

    <Style Selector="Grid.seek-container Ellipse.slider-thumb">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Grid.seek-container:pointerover Ellipse.slider-thumb">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Grid.seek-container.dragging Ellipse.slider-thumb">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Ellipse.slider-thumb.hidden">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>

    <Style Selector="Border.seek-cursor">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Grid.seek-container:pointerover Border.seek-cursor">
        <Setter Property="Opacity" Value="0.6" />
    </Style>
    <Style Selector="Border.seek-cursor.hidden">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>

    <Style Selector="Border.seek-preview-cursor">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.seek-preview-cursor.active">
        <Setter Property="Opacity" Value="0.7" />
    </Style>

    <!-- ИСПРАВЛЕНИЕ XAMLX CRASH: Заменяем <Transitions /> на Value="{x:Null}" -->
    <Style Selector="Border.progress-bar">
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Grid.dragging Border.progress-bar">
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Border.progress-bar.hidden">
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Border.playing-glow">
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Grid.dragging Border.playing-glow">
        <Setter Property="Transitions" Value="{x:Null}" />
    </Style>

    <Style Selector="Border.playing-glow.active">
        <Style.Animations>
            <Animation IterationCount="Infinite" Duration="0:0:1.5">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="0.7" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.3" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Border.playing-glow.suspended">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <Style Selector="Ellipse.vol-thumb">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Fill" Duration="0:0:0.15" />
                <ThicknessTransition Property="Margin" Duration="0:0:0.06" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Ellipse.vol-thumb:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.1)" />
        <Setter Property="Fill" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Ellipse.vol-thumb.dragging">
        <Setter Property="Fill" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Ellipse.vol-thumb.boosted">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Border.vol-track">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <Style Selector="Border.vol-fill">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Height" Duration="0:0:0.06" Easing="CubicEaseOut" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.vol-fill.dragging">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Border.vol-fill.boosted">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.playback-btn.auto-enabled">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.playback-btn.auto-enabled PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.playback-btn.active PathIcon">
        <Setter Property="RenderTransformOrigin" Value="50%, 50%" />
        <Setter Property="RenderTransform">
            <RotateTransform />
        </Setter>
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="RotateTransform.Angle" Value="-20" />
                </KeyFrame>
                <KeyFrame Cue="40%">
                    <Setter Property="RotateTransform.Angle" Value="15" />
                </KeyFrame>
                <KeyFrame Cue="70%">
                    <Setter Property="RotateTransform.Angle" Value="-5" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="RotateTransform.Angle" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.mode-hint">
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #40000000" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,1" />
        <Setter Property="RenderTransform" Value="translateY(8px)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.mode-hint.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>
</Styles>