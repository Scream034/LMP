<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="using:LMP.UI.Dialogs"
        xmlns:controls="using:LMP.UI.Controls"
        x:Class="LMP.UI.Dialogs.CreatePlaylistDialog"
        x:DataType="d:CreatePlaylistDialogViewModel"
        Title="{Binding L[Library_CreatePlaylist]}"
        Width="460" MinHeight="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        CanResize="False"
        Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1"
            CornerRadius="8" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto, Auto">

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding L[Library_CreatePlaylist]}"
                       FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,20" />

            <!-- Editor -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <controls:PlaylistEditorControl DataContext="{Binding Editor}" />
            </ScrollViewer>

            <!-- Sync Toggle -->
            <Border Grid.Row="2"
                    IsVisible="{Binding ShowSyncToggle}"
                    Background="{DynamicResource BgElevatedBrush}"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,16,0,0">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding L[Playlist_SyncToCloud]}"
                                   FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L[Playlist_SyncToCloud_Desc]}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding SyncToCloud, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0" />
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="12"
                        Margin="0,20,0,0">
                <Button Content="{Binding L[Common_Cancel]}"
                        Command="{Binding CancelCommand}"
                        Background="Transparent" />
                <Button Content="{Binding L[Button_Create]}"
                        Command="{Binding ConfirmCommand}"
                        Classes="accent accent-base" />
            </StackPanel>
        </Grid>
    </Border>
</Window>