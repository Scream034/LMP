<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="using:LMP.UI.Dialogs"
        x:Class="LMP.UI.Dialogs.StreamUnavailableDialog"
        x:DataType="dialogs:StreamUnavailableDialog"
        Title="Error"
        Width="480"
        MinHeight="220"
        SizeToContent="Height"
        MaxHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="#E74C3C"
            BorderThickness="2"
            CornerRadius="12"
            Padding="28">

        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

            <!-- Иконка ошибки -->
            <Border Grid.Row="0"
                    HorizontalAlignment="Center"
                    Width="56"
                    Height="56"
                    CornerRadius="28"
                    Background="#E74C3C"
                    Opacity="0.15"
                    Margin="0,0,0,16">
                <Viewbox Width="32" Height="32">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#E74C3C"
                              Data="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z" />
                    </Canvas>
                </Viewbox>
            </Border>

            <!-- Заголовок -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DialogTitle}"
                       FontSize="20"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,12" />

            <!-- Основное сообщение -->
            <ScrollViewer Grid.Row="2"
                          MaxHeight="120"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,16">
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           LineHeight="22" />
            </ScrollViewer>

            <!-- Техническая информация (если есть) -->
            <Border Grid.Row="3"
                    IsVisible="{Binding HasTechnicalInfo}"
                    Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,16">
                <TextBlock Text="{Binding TechnicalInfo}"
                           FontSize="11"
                           FontFamily="Consolas, Courier New, monospace"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           TextWrapping="Wrap"
                           Opacity="0.8" />
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
                <Button Content="{Binding CopyErrorText}"
                        Command="{Binding CopyErrorCommand}"
                        MinWidth="120"
                        IsVisible="{Binding ShowCopyButton}" />

                <Button Content="{Binding CloseButtonText}"
                        Command="{Binding CloseCommand}"
                        MinWidth="120"
                        Classes="accent accent-base" />
            </StackPanel>

        </Grid>
    </Border>
</Window>