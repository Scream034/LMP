<!-- Views/Dialogs/InfoDialog.axaml -->
<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:LMP.UI.Dialogs"
    x:Class="LMP.UI.Dialogs.InfoDialog"
    x:DataType="dialogs:InfoDialog"
    Title="Info"
    Width="400"
    MinHeight="160"
    SizeToContent="Height"
    MaxHeight="400"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="BorderOnly"
    Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="24">
        <StackPanel Spacing="16">
            <!-- Заголовок -->
            <TextBlock Text="{Binding DialogTitle}"
                FontSize="18"
                FontWeight="Bold"
                Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Сообщение с автоматической высотой -->
            <ScrollViewer MaxHeight="200"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Message}"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextSecondaryBrush}" />
            </ScrollViewer>

            <!-- Кнопка -->
            <Button Content="{Binding ButtonText}"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Right"
                MinWidth="80"
                Classes="accent" />
        </StackPanel>
    </Border>
</Window>
