<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="using:LMP.UI.Dialogs"
        xmlns:asyncImage="using:AsyncImageLoader"
        x:Class="LMP.UI.Dialogs.SyncSelectionDialog"
        x:DataType="d:SyncSelectionViewModel"
        Title="{Binding L[Sync_Title]}"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto">
            
            <TextBlock Grid.Row="0" Text="{Binding L[Sync_Title]}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="8" CornerRadius="6" Background="{DynamicResource BgElevatedBrush}">
                                <Grid ColumnDefinitions="30, 60, *">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="1" Width="50" Height="50" CornerRadius="4" ClipToBounds="True">
                                        <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,16,0,0">
                <Button Content="{Binding L[Common_Cancel]}" Command="{Binding CancelCommand}" Background="Transparent"/>
                <Button Content="{Binding L[Sync_Action]}" Command="{Binding SyncCommand}" Classes="accent"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
