<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="using:LMP.UI.Dialogs"
        xmlns:asyncImage="using:AsyncImageLoader"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="LMP.UI.Dialogs.SyncSelectionDialog"
        x:DataType="d:SyncSelectionViewModel"
        Title="{Binding L[Sync_Title]}"
        Width="580" Height="640"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        CanResize="False"
        Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1"
            CornerRadius="8" Padding="24">
        <Grid RowDefinitions="Auto, Auto, *, Auto">

            <!-- Row 0: Title + Subtitle -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
                <TextBlock Text="{Binding L[Sync_Title]}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding L[Sync_Subtitle]}"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <!-- Row 1: Bulk actions + Summary -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *" Margin="0,0,0,12">
                <Button Grid.Column="0"
                        Content="{Binding L[Sync_SelectAll]}"
                        Command="{Binding SelectAllCommand}"
                        Background="Transparent" FontSize="12" Padding="8,4" />
                <Button Grid.Column="1"
                        Content="{Binding L[Sync_DeselectAll]}"
                        Command="{Binding DeselectAllCommand}"
                        Background="Transparent" FontSize="12" Padding="8,4"
                        Margin="4,0,0,0" />
                <TextBlock Grid.Column="2"
                           Text="{Binding SummaryText}"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>

            <!-- Row 2: Playlist list -->
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="d:SyncItemViewModel">
                            <Border Margin="0,0,0,6" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource BgElevatedBrush}">
                                <Grid ColumnDefinitions="50, *, Auto, Auto">

                                    <!-- Thumbnail -->
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="4" ClipToBounds="True"
                                            Background="{DynamicResource BgSkeletonBrush}">
                                        <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <!-- Name + Author -->
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,8,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Author}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   IsVisible="{Binding Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </StackPanel>

                                    <!-- Conflict badge -->
                                    <Border Grid.Column="2"
                                            IsVisible="{Binding HasConflict}"
                                            Background="#FFB86C"
                                            CornerRadius="4" Padding="6,2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Opacity="0.9">
                                        <TextBlock Text="{Binding L[Sync_Conflict]}"
                                                   FontSize="10"
                                                   Foreground="#1E1E1E"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <!-- Action ComboBox -->
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding AvailableActions}"
                                              SelectedItem="{Binding SelectedOption}"
                                              MinWidth="140"
                                              VerticalAlignment="Center"
                                              FontSize="13">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="d:SyncActionOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 3: Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="12"
                        Margin="0,16,0,0">
                <Button Content="{Binding L[Common_Cancel]}"
                        Command="{Binding CancelCommand}"
                        Background="Transparent" />
                <Button Content="{Binding L[Common_OK]}"
                        Command="{Binding ConfirmCommand}"
                        Classes="accent accent-base" />
            </StackPanel>
        </Grid>
    </Border>
</Window>