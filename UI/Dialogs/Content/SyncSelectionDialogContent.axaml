<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:LMP.UI.Dialogs"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:controls="using:LMP.UI.Controls"
    x:Class="LMP.UI.Dialogs.Content.SyncSelectionDialogContent"
    x:DataType="dialogs:SyncSelectionViewModel">

    <Border Background="{DynamicResource BgPrimaryBrush}"
        BorderBrush="{DynamicResource BgHighlightBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="20"
        Width="720"
        MinHeight="500"
        MaxHeight="800">

        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

            <!-- Row 0: Компактный Header со статистикой справа -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,12">
                <!-- Заголовок -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding L[Sync_Title]}"
                        FontSize="20" FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding L[Sync_Subtitle]}"
                        FontSize="12"
                        Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>

                <!-- Статистика справа (компактная) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2"
                    HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TotalSummary}"
                        FontSize="12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        TextAlignment="Right"
                        ToolTip.Tip="{Binding TotalSummary}" />
                    <TextBlock Text="{Binding SelectedSummary}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AccentBrush}"
                        TextAlignment="Right"
                        ToolTip.Tip="{Binding SelectedSummary}" />
                </StackPanel>
            </Grid>

            <!-- Row 1: Поиск -->
            <Border Grid.Row="1" Margin="0,0,0,10"
                Background="{DynamicResource BgElevatedBrush}"
                CornerRadius="6" Padding="10,6"
                ToolTip.Tip="{Binding L[Sync_Tooltip_Search]}">
                <Grid ColumnDefinitions="Auto, *">
                    <!-- Поиск: иконка лупы -->
                    <PathIcon Grid.Column="0"
                        Data="{StaticResource Icon.Search}"
                        Width="18" Height="18"
                        Foreground="{DynamicResource TextMutedBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                        Text="{Binding SearchQuery, Mode=TwoWay}"
                        PlaceholderText="{Binding L[Sync_SearchPlaceholder]}"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="13"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Row 2: Глобальные шаблоны -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,0,0,10">
                <!-- Шаблон конфликтов -->
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                    <!-- Шаблон конфликтов: иконка предупреждения -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="{StaticResource Icon.AlertCircleOutline}"
                            Width="14" Height="14"
                            Foreground="#FFB86C" />
                        <TextBlock Text="{Binding L[Sync_Template_Conflicts]}"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding ConflictTemplates}"
                        SelectedItem="{Binding SelectedConflictTemplate}"
                        HorizontalAlignment="Stretch" FontSize="13"
                        ToolTip.Tip="{Binding L[Sync_Tooltip_Template_Conflicts]}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="dialogs:SyncActionOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Шаблон новых -->
                <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                    <!-- Шаблон новых: иконка галочки в круге -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="{StaticResource Icon.CheckCircleOutline}"
                            Width="14" Height="14"
                            Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding L[Sync_Template_New]}"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding NewTemplates}"
                        SelectedItem="{Binding SelectedNewTemplate}"
                        HorizontalAlignment="Stretch" FontSize="13"
                        ToolTip.Tip="{Binding L[Sync_Tooltip_Template_New]}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="dialogs:SyncActionOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Row 3: Список плейлистов -->
            <ScrollViewer Grid.Row="3">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dialogs:SyncItemViewModel">
                            <Border Margin="0,0,0,6" Padding="10" CornerRadius="6"
                                Background="{DynamicResource BgElevatedBrush}"
                                BorderThickness="1"
                                BorderBrush="{Binding IsHighlighted,
                                        Converter={StaticResource BoolToSelector},
                                        ConverterParameter='AccentBrush|Transparent'}">
                                <Grid ColumnDefinitions="56, *, Auto, Auto, Auto">

                                    <!-- Обложка -->
                                    <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        CornerRadius="4" ClipToBounds="True"
                                        Background="{DynamicResource BgSkeletonBrush}">
                                        <Panel>
                                            <!-- Список: заглушка плейлиста без обложки -->
                                            <PathIcon Data="{StaticResource Icon.PlaylistMusic}"
                                                Width="24" Height="24"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding !HasThumbnail}" />
                                            <Image
                                                asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                                Stretch="UniformToFill"
                                                IsVisible="{Binding HasThumbnail}" />
                                        </Panel>
                                    </Border>

                                    <!-- Название + Автор + Кол-во треков -->
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0"
                                        VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                            FontSize="14" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Author}" FontSize="12"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                IsVisible="{Binding Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <TextBlock Text="•" FontSize="12"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                IsVisible="{Binding HasTrackCount}" />
                                            <TextBlock Text="{Binding FormattedTrackCount}"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                IsVisible="{Binding HasTrackCount}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Бейдж конфликта -->
                                    <Border Grid.Column="2" IsVisible="{Binding HasConflict}"
                                        Background="#FFB86C" CornerRadius="4" Padding="6,2"
                                        Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.9">
                                        <TextBlock Text="{Binding L[Sync_Conflict]}"
                                            FontSize="10" Foreground="#1E1E1E"
                                            FontWeight="SemiBold" />
                                    </Border>

                                    <!-- Кнопка копирования ссылки -->
                                    <controls:CopyLinkButton Grid.Column="3"
                                        CopyUrl="{Binding PlaylistUrl}"
                                        SuccessText="{Binding L[Track_Copied]}"
                                        ToolTipText="{Binding L[Sync_Tooltip_CopyLink]}"
                                        ButtonSize="32" IconSize="16"
                                        ShowHoverRing="False" />

                                    <!-- ComboBox действия -->
                                    <ComboBox Grid.Column="4"
                                        ItemsSource="{Binding AvailableActions}"
                                        SelectedItem="{Binding SelectedOption}"
                                        MinWidth="140" VerticalAlignment="Center" FontSize="13">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="dialogs:SyncActionOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 4: Кнопки -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="12" Margin="0,14,0,0">
                <Button Content="{Binding L[Common_Cancel]}" Command="{Binding CancelCommand}"
                    Background="Transparent" />
                <Button Content="{Binding L[Common_OK]}" Command="{Binding ConfirmCommand}"
                    Classes="accent accent-base" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>