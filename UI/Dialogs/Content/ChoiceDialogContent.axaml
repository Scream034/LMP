<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="using:LMP.UI.Dialogs"
    xmlns:content="using:LMP.UI.Dialogs.Content"
    x:Class="LMP.UI.Dialogs.Content.ChoiceDialogContent"
    x:DataType="dialogs:ChoiceDialogViewModel">

    <Border Background="{DynamicResource BgPrimaryBrush}"
        BorderBrush="{DynamicResource BgHighlightBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="24"
        MinWidth="400"
        MaxWidth="520">

        <StackPanel Spacing="16">
            <!-- Заголовок -->
            <TextBlock Text="{Binding Title}"
                FontSize="18" FontWeight="Bold"
                Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Сообщение -->
            <ScrollViewer MaxHeight="200"
                VerticalScrollBarVisibility="Auto"
                IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding Message}"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    FontSize="14" />
            </ScrollViewer>

            <!-- Опциональный чекбокс -->
            <CheckBox Content="{Binding CheckBoxText}"
                IsChecked="{Binding IsChecked}"
                IsVisible="{Binding HasCheckBox}"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Margin="0,4,0,0" />

            <!-- Кнопки -->
            <ItemsControl ItemsSource="{Binding Buttons}"
                HorizontalAlignment="Right">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dialogs:ChoiceButtonViewModel">
                        <Button Content="{Binding Text}"
                            Command="{Binding ClickCommand}"
                            MinWidth="90"
                            Classes.accent="{Binding IsPrimary}"
                            Classes.accent-base="{Binding IsPrimary}"
                            HorizontalContentAlignment="Center" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>