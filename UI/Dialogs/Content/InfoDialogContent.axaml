<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:content="using:LMP.UI.Dialogs.Content"
             x:Class="LMP.UI.Dialogs.Content.InfoDialogContent"
             x:DataType="content:InfoDialogContent">

    <Border Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BgHighlightBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24"
            MinWidth="400"
            MaxWidth="500">

        <StackPanel Spacing="16">
            <!-- Заголовок -->
            <TextBlock Text="{Binding Title}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <!-- Сообщение -->
            <ScrollViewer MaxHeight="500"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </ScrollViewer>

            <!-- Кнопка -->
            <Button Content="{Binding ButtonText}"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    MinWidth="80"
                    Classes="accent accent-base" />
        </StackPanel>
    </Border>
</UserControl>