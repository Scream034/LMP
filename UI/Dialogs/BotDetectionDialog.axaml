<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="using:LMP.UI.Dialogs"
        x:Class="LMP.UI.Dialogs.BotDetectionDialog"
        x:DataType="dialogs:BotDetectionDialog"
        Title="Please Wait"
        Width="460"
        Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="2"
            CornerRadius="12"
            Padding="28">

        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

            <!-- Иконка -->
            <Border Grid.Row="0"
                    HorizontalAlignment="Center"
                    Width="56"
                    Height="56"
                    CornerRadius="28"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0.15"
                    Margin="0,0,0,16">
                <Viewbox Width="32" Height="32">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource AccentBrush}"
                              Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" />
                    </Canvas>
                </Viewbox>
            </Border>

            <!-- Заголовок -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DialogTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,12" />

            <!-- Сообщение -->
            <TextBlock Grid.Row="2"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       LineHeight="22"
                       Margin="0,0,0,20" />

            <!-- Таймер -->
            <TextBlock Grid.Row="3"
                       Text="{Binding TimeRemaining}"
                       FontSize="42"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AccentBrush}" />

            <!-- Прогресс-бар -->
            <ProgressBar Grid.Row="4"
                         Value="{Binding Progress}"
                         Maximum="100"
                         Height="6"
                         Margin="0,16,0,16"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource BgSecondaryBrush}"
                         CornerRadius="3" />

            <!-- Подсказка и кнопка -->
            <Grid Grid.Row="5" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Hint}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Opacity="0.8"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Content="{Binding CloseButtonText}"
                        Command="{Binding CloseCommand}"
                        MinWidth="100"
                        Classes="accent"
                        Margin="16,0,0,0" />
            </Grid>

        </Grid>
    </Border>
</Window>