<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="ListBox.track-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.track-list ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Transitions">
            <Transitions>
                <ThicknessTransition Property="BorderThickness" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border Name="PART_RootBorder" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter Name="PART_ContentPresenter" Background="Transparent"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style
        Selector="ListBox.track-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="ListBox.track-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══ TRACK ROW — Border-only hover/active (no background change) ═══ -->
    <Style Selector="Border.track-row">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Border.track-row:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row.is-active">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Style.Animations>
            <Animation Duration="0:0:1.8" IterationCount="Infinite"
                PlaybackDirection="Alternate"
                Easing="SineEaseInOut"
                FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.733" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.track-row.menu-open">
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
    </Style>
    <Style Selector="Border.track-row.is-active.menu-open">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.track-row.menu-open:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.track-row.is-active TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- КНОПКА ОБЛОЖКИ (Скругление и обрезка без лишних Border-оберток)      -->
    <Style Selector="Button.cover-btn">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    ClipToBounds="True">
                    <ContentPresenter Name="PART_ContentPresenter"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Переключение геометрии иконки Play/Pause -->
    <Style Selector="Button.cover-btn PathIcon">
        <Setter Property="Data" Value="{StaticResource Icon.Play}" />
    </Style>
    <Style Selector="Button.cover-btn PathIcon.playing">
        <Setter Property="Data" Value="{StaticResource Icon.Pause}" />
    </Style>

    <Style Selector="Button.cover-btn Border.cover-overlay">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Button.cover-btn:pointerover Border.cover-overlay">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.cover-btn Border.cover-overlay PathIcon">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.85)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.cover-btn:pointerover Border.cover-overlay PathIcon">
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>
    <Style Selector="Button.cover-btn:pressed Border.cover-overlay PathIcon">
        <Setter Property="RenderTransform" Value="scale(0.9)" />
    </Style>

    <!-- КНОПКА ЛАЙКА (Анимации + Подмена иконки Heart/HeartOutline)        -->
    <Style Selector="Button.like-btn">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(1)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.like-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.85)" />
    </Style>
    <Style Selector="Button.like-btn.is-liked">
        <Setter Property="RenderTransform" Value="scale(1.05)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn PathIcon">
        <Setter Property="Data" Value="{StaticResource Icon.HeartOutline}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.like-btn.is-liked PathIcon">
        <Setter Property="Data" Value="{StaticResource Icon.Heart}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.more-btn, Button.remove-btn">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style
        Selector="Border.track-row:pointerover Button.more-btn, Border.track-row:pointerover Button.remove-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="Border.track-row.menu-open Button.more-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <Style Selector="Border.track-row TextBlock.duration-text">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.track-row:pointerover TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="Border.track-row.menu-open TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- ═══ DRAG & DROP INDICATORS для ItemsRepeater ═══ -->
    <!-- 
        TryGetElement() возвращает Border.track-row напрямую (нет ListBoxItem-обёртки).
        Классы insert-top/insert-bottom/dragging добавляются в TrackListControl.axaml.cs.
    -->
    <Style Selector="Border.track-row.dragging">
        <Setter Property="Opacity" Value="0.4" />
    </Style>
    <Style Selector="Border.track-row.insert-top">
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.track-row.insert-bottom">
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- LOADING DOTS -->
    <Style Selector="Ellipse.loading-dot">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Ellipse.loading-dot-2">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.15">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Ellipse.loading-dot-3">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.3">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="TextBlock.loading-dot1">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="TextBlock.loading-dot2">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.2">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="TextBlock.loading-dot3">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.4">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PLAYLIST CARD — Staggered Animation + Context Menu                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Внутренняя карточка плейлиста -->
    <Style Selector="Border.playlist-card-inner">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <!-- Стартовое состояние для stagger: невидима + сдвинута вниз -->
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <TranslateTransform Y="16" />
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Видимое состояние (stagger завершён) -->
    <Style Selector="Border.playlist-card-inner.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform">
            <TranslateTransform Y="0" />
        </Setter>
    </Style>

    <!-- Hover: border акцентный -->
    <Style Selector="Border.playlist-card-inner.visible:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Сохраняем акцентную рамку при открытом контекстном меню -->
    <Style Selector="Border.playlist-card-inner.menu-open">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Анимация активного воспроизведения плейлиста (плавное "дыхание") -->
    <Style Selector="Border.playlist-card-inner.is-active">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Style.Animations>
            <Animation Duration="0:0:1.8" IterationCount="Infinite"
                PlaybackDirection="Alternate"
                Easing="SineEaseInOut"
                FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.75" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Обложка плейлиста -->
    <Style Selector="Border.playlist-cover">
        <Setter Property="Height" Value="220" />
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="CornerRadius" Value="8,8,0,0" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <!-- Liked playlist градиентный фон: СВЕРХУ ВНИЗ -->
    <Style Selector="Border.liked-gradient">
        <Setter Property="CornerRadius" Value="8,8,0,0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                    <GradientStop Color="{DynamicResource Accent}" Offset="0.0" />
                    <GradientStop Color="{DynamicResource BgElevated}" Offset="1.0" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Skeleton карточка (размер соответствует реальной карточке 220px) -->
    <Style Selector="Border.playlist-skeleton">
        <Setter Property="Width" Value="220" />
        <Setter Property="Height" Value="290" />
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Border.skeleton">
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="0.6" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.3" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Cloud sync crossfade animation -->
    <Style Selector="Panel.cloud-crossfade-overlay">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>