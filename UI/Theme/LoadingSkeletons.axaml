<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia">

    <!-- ============================================= -->
    <!-- Р С’Р СңР ВҳР СҡР С’Р ВҰР ВҳР РҮ Р СҹР вҖўР В Р вҖўР вҖәР ВҳР вҖҷР С’Р СңР ВҳР РҮ Р СӣР вҖҳР вҖәР С’Р СҷР С’ (CROSSFADE)       -->
    <!-- ============================================= -->

    <Style Selector="Panel.cloud-crossfade-overlay">
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- Р С’Р СңР ВҳР СҡР С’Р ВҰР ВҳР РҮ Р вҖқР В«Р ТҗР С’Р СңР ВҳР РҮ (BREATHING)                  -->
    <!-- ============================================= -->

    <Style Selector="StackPanel.breathing">
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.4" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.9" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- Р С’Р СңР ВҳР СҡР С’Р ВҰР ВҳР РҮ Р вҖәР РҲР СҹР В« (Р СҹР вҖәР С’Р вҖҷР СңР СӣР вҖў Р СҹР С’Р В Р вҖўР СңР ВҳР вҖў)               -->
    <!-- ============================================= -->

    <Style Selector="mi|MaterialIcon.scanner-smooth">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <ScaleTransform />
                    <TranslateTransform />
                    <RotateTransform />
                </TransformGroup>
            </Setter.Value>
        </Setter>

        <!-- Р СһР ВөР Р…РЎРҠ Р Т‘Р В»РЎРҸ Р С•Р ВұРЎРүР ВөР СҳР В° -->
        <Setter Property="Effect">
            <DropShadowEffect Color="Black" BlurRadius="8" Opacity="0.4" OffsetX="2" OffsetY="2" />
        </Setter>

        <Style.Animations>
            <!-- 1. Р вҖқР РҶР С‘Р В¶Р ВөР Р…Р С‘Р Вө Р С—Р С• Р С–Р С•РЎРӮР С‘Р В·Р С•Р Р…РЎвҖҡР В°Р В»Р С‘ (Р РҒР С‘РЎРӮР С•Р С”Р В°РЎРҸ Р В°Р СҳР С—Р В»Р С‘РЎвҖҡРЎС“Р Т‘Р В°) -->
            <Animation Duration="0:0:4" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="RotateTransform.Angle" Value="-15" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.X" Value="250" /> <!-- Р вҖқР РҶР С‘Р С–Р В°Р ВөР Сҳ Р РҶР С—РЎРӮР В°Р РҶР С• -->
                    <Setter Property="RotateTransform.Angle" Value="15" />  <!-- Р СңР ВөР СҳР Р…Р С•Р С–Р С• Р Р…Р В°Р С”Р В»Р С•Р Р…РЎРҸР ВөР Сҳ -->
                </KeyFrame>
            </Animation>

            <!-- 2. Р вҖқР РҶР С‘Р В¶Р ВөР Р…Р С‘Р Вө Р С—Р С• Р РҶР ВөРЎРӮРЎвҖҡР С‘Р С”Р В°Р В»Р С‘ (Р СҡР ВөР Р…РЎРҠРЎвӮ¬Р В°РЎРҸ Р В°Р СҳР С—Р В»Р С‘РЎвҖҡРЎС“Р Т‘Р В°, Р Т‘РЎРӮРЎС“Р С–Р С•Р в„– РЎвҖҡР В°Р в„–Р СҳР С‘Р Р…Р С– Р Т‘Р В»РЎРҸ РЎРҢРЎвҖһРЎвҖһР ВөР С”РЎвҖҡР В° Р РҶР С•РЎРғРЎРҠР СҳР ВөРЎРӮР С”Р С‘) -->
            <Animation Duration="0:0:2.5" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="120" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.1" /> <!-- Р СҹРЎС“Р В»РЎРҠРЎРғР В°РЎвҖ Р С‘РЎРҸ РЎРӮР В°Р В·Р СҳР ВөРЎРӮР В° -->
                    <Setter Property="ScaleTransform.ScaleY" Value="1.1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- Р РҺР СҷР вҖўР вҖәР вҖўР СһР СӣР СңР В« Р вҖ”Р С’Р вҖңР В Р РҲР вҖ”Р СҷР Вҳ                            -->
    <!-- ============================================= -->

    <!-- Р вҖҳР В°Р В·Р С•Р РҶР В°РЎРҸ РЎРғРЎвҖҡРЎРӮР С•Р С”Р В° РЎвҖҡРЎРӮР ВөР С”Р В° -->
    <Style Selector="ContentControl.track-skeleton-row">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Height="52" Margin="0,2" Background="Transparent">
                        <Grid ColumnDefinitions="52, *, 50" Margin="8,0">
                            <!-- Р ВҳР С”Р С•Р Р…Р С”Р В°/Р СӣР ВұР В»Р С•Р В¶Р С”Р В° -->
                            <Border Grid.Column="0" Width="40" Height="40"
                                Background="{DynamicResource BgSkeletonBrush}" CornerRadius="4"
                                VerticalAlignment="Center" HorizontalAlignment="Left" />

                            <!-- Р СһР ВөР С”РЎРғРЎвҖҡР С•Р РҶРЎвҖ№Р Вө Р ВұР В»Р С•Р С”Р С‘ -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Border Width="180" Height="10"
                                    Background="{DynamicResource BgSkeletonBrush}"
                                    HorizontalAlignment="Left" CornerRadius="2" />
                                <Border Width="100" Height="7"
                                    Background="{DynamicResource BgSkeletonDeepBrush}"
                                    HorizontalAlignment="Left" Margin="0,6,0,0" CornerRadius="2" />
                            </StackPanel>

                            <!-- Р вҖқР В»Р С‘РЎвҖҡР ВөР В»РЎРҠР Р…Р С•РЎРғРЎвҖҡРЎРҠ -->
                            <Border Grid.Column="2" Width="30" Height="7"
                                Background="{DynamicResource BgSkeletonDeepBrush}"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                CornerRadius="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Р СҹР В°Р С–Р С‘Р Р…Р В°РЎвҖ Р С‘РЎРҸ (Р СңР С‘Р В¶Р Р…Р С‘Р в„– Р В»Р С•Р В°Р Т‘Р ВөРЎРӮ) -->
    <Style Selector="ContentControl.loading-skeletons">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,4,0,24" Opacity="0.5">
                        <StackPanel.Effect>
                            <BlurEffect Radius="3" />
                        </StackPanel.Effect>
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 
        Р СӣР вҖҳР В©Р ВҳР в„ў Р РҒР С’Р вҖҳР вҖәР СӣР Сң Р РҺР СҹР ВҳР РҺР СҷР С’ (Р Т‘Р В»РЎРҸ Initial Р С‘ Search)
        Р ВҳРЎРғР С—Р С•Р В»РЎРҠР В·РЎС“Р ВөР Сҳ Р С•Р Т‘Р С‘Р Р… РЎРғРЎвҖҡР С‘Р В»РЎРҠ StackPanel Р Т‘Р В»РЎРҸ Р С‘Р Т‘Р ВөР Р…РЎвҖҡР С‘РЎвҖЎР Р…Р С•РЎРғРЎвҖҡР С‘
    -->
    <Style Selector="StackPanel.skeleton-list-container">
        <Setter Property="Spacing" Value="4" />
        <Setter Property="Margin" Value="0,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />

        <!-- Р вҖўР Т‘Р С‘Р Р…РЎвҖ№Р в„– Р вҖҳР В»РЎРӢРЎРӮ -->
        <Setter Property="Effect">
            <BlurEffect Radius="6" />
        </Setter>

        <!-- Р вҖўР Т‘Р С‘Р Р…РЎвҖ№Р в„– Р вҖңРЎРӮР В°Р Т‘Р С‘Р ВөР Р…РЎвҖҡ Р С‘РЎРғРЎвҖЎР ВөР В·Р Р…Р С•Р РҶР ВөР Р…Р С‘РЎРҸ РЎРғР Р…Р С‘Р В·РЎС“ -->
        <Setter Property="OpacityMask">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0.0" Color="#FF000000" />
                <GradientStop Offset="0.6" Color="#FF000000" />
                <GradientStop Offset="1.0" Color="#00000000" />
            </LinearGradientBrush>
        </Setter>
    </Style>


    <!-- Р СңР В°РЎвҖЎР В°Р В»РЎРҠР Р…Р В°РЎРҸ Р В·Р В°Р С–РЎРӮРЎС“Р В·Р С”Р В° (IsLoading) -->
    <Style Selector="ContentControl.loading-initial">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <!-- Р ВҳРЎРғР С—Р С•Р В»РЎРҠР В·РЎС“Р ВөР Сҳ Р С•Р ВұРЎвҖ°Р С‘Р в„– Р С”Р В»Р В°РЎРғРЎРғ skeleton-list-container + Р В°Р Р…Р С‘Р СҳР В°РЎвҖ Р С‘РЎРӢ breathing -->
                    <StackPanel Classes="breathing skeleton-list-container">
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Styles>