<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Library"
    xmlns:controls="using:LMP.UI.Controls">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PLAYLIST CARD HOVER STYLES                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="ContentControl.playlist-card Border.card-root">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="ContentControl.playlist-card Border.card-root:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ContentControl.playlist-card Panel.action-bar">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="ContentControl.playlist-card Border.card-root:pointerover Panel.action-bar">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PLAYLIST CARD DATA TEMPLATE                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="ContentControl.playlist-card">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="vm:PlaylistCardViewModel">
                    <Border Classes="card-root"
                        CornerRadius="8"
                        BorderThickness="1.5"
                        Width="160" Height="248"
                        Margin="0,0,16,16"
                        ClipToBounds="False"
                        Cursor="Hand">

                        <Grid RowDefinitions="*, Auto">

                            <!-- ═══ MAIN CONTENT ═══ -->
                            <Button Grid.Row="0"
                                Command="{Binding OpenCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="12,12,12,4"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Top"
                                Cursor="Hand">
                                <StackPanel>

                                    <Border Width="136" Height="136" CornerRadius="4"
                                        ClipToBounds="True"
                                        Margin="0,0,0,10">
                                        <Panel Background="{DynamicResource BgHighlightBrush}">

                                            <!-- Заглушка плейлиста (нет обложки) -->
                                            <PathIcon Data="{StaticResource Icon.PlaylistMusic}"
                                                Width="64" Height="64"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding ThumbnailUrl,
                                                    Converter={StaticResource NullToVisible},
                                                    ConverterParameter='invert'}" />

                                            <Image
                                                Stretch="UniformToFill"
                                                IsVisible="{Binding ThumbnailUrl,
                                                Converter={StaticResource StringStartsWithConverter},
                                                ConverterParameter='http'}" />

                                            <Image
                                                Source="{Binding ThumbnailUrl,
                                                Converter={StaticResource BitmapAssetConverter}}"
                                                Stretch="UniformToFill">
                                                <Image.IsVisible>
                                                    <MultiBinding
                                                        Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="ThumbnailUrl"
                                                            Converter="{StaticResource NullToVisible}" />
                                                        <Binding Path="ThumbnailUrl"
                                                            Converter="{StaticResource StringStartsWithConverter}"
                                                            ConverterParameter="!http" />
                                                    </MultiBinding>
                                                </Image.IsVisible>
                                            </Image>

                                            <!-- Liked playlist иконка сердца -->
                                            <PathIcon Data="{StaticResource Icon.Heart}"
                                                Width="64" Height="64"
                                                Foreground="{DynamicResource AccentBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding Id,
                                                    Converter={StaticResource StringStartsWithConverter},
                                                    ConverterParameter='liked'}" />
                                        </Panel>
                                    </Border>

                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                        FontSize="13"
                                        TextTrimming="CharacterEllipsis" MaxLines="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding FormattedTrackCount}" FontSize="11"
                                        Margin="0,2,0,0"
                                        Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- ═══ BOTTOM ACTION BAR ═══ -->
                            <Panel Grid.Row="1" Classes="action-bar"
                                Margin="8,2,8,8"
                                Height="32">

                                <UniformGrid Rows="1" HorizontalAlignment="Stretch">

                                    <!-- Add to queue -->
                                    <Button Command="{Binding AddToQueueCommand}"
                                        Classes="ghost-btn"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        ToolTip.Tip="{Binding L[Queue_Add]}">
                                        <PathIcon Data="{StaticResource Icon.PlaylistPlus}"
                                            Width="18" Height="18" />
                                    </Button>

                                    <controls:CopyLinkButton
                                        CopyUrl="{Binding YoutubeUrl}"
                                        IsVisible="{Binding CanCopyLink}"
                                        SuccessText="{Binding L[Playlist_LinkCopied]}"
                                        ToolTipText="{Binding L[Track_CopyLink]}"
                                        ButtonSize="32"
                                        IconSize="16" />

                                    <!-- Delete -->
                                    <Button Command="{Binding DeleteCommand}"
                                        Classes="ghost-btn"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        IsVisible="{Binding CanDelete}"
                                        ToolTip.Tip="{Binding L[Button_Delete]}">
                                        <PathIcon Data="{StaticResource Icon.DeleteOutline}"
                                            Width="18" Height="18" />
                                    </Button>
                                </UniformGrid>
                            </Panel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</Styles>