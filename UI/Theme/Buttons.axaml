<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BASE BUTTON TEMPLATE                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                                                                     -->
    <!-- ПРАВИЛО АНИМАЦИИ ЦВЕТОВ (ANTI-FLASH):                             -->
    <!-- Никогда не анимируем от/к Transparent (#00FFFFFF)!                  -->
    <!-- Вместо этого используем *TransparentBrush — тот же RGB, альфа=0.   -->
    <!--                                                                     -->
    <!-- ВАЖНО: TransparentBrush должен совпадать по RGB с ЦЕЛЕВЫМ цветом,  -->
    <!-- а не с каким-то другим. Иначе при интерполяции на 50% появится     -->
    <!-- видимый цвет-гибрид (мерцание).                                    -->
    <!--                                                                     -->
    <!-- Пример:                                                             -->
    <!--   ✗ AccentTransparent → BgHighlight = мерцание фиолетовым          -->
    <!--   ✓ BgHighlightTransparent → BgHighlight = плавное появление       -->
    <!--                                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border
                    Name="PART_Border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter
                        Name="PART_ContentPresenter"
                        Background="Transparent"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        RecognizesAccessKey="True" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="RepeatButton">
        <Setter Property="Transitions">
            <Transitions />
        </Setter>
    </Style>

    <!-- ═══ FLUENT OVERRIDE ═══ -->
    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button:disabled PathIcon">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- WINDOW CONTROL BUTTONS                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.window-btn">
        <Setter Property="Background" Value="{DynamicResource BgHoverTransparentBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.window-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <Style Selector="Button.window-btn > Panel > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn:pointerover > Panel > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.window-btn > Panel > Grid > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn:pointerover > Panel > Grid > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.window-btn > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Stroke" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn:pointerover > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- ═══ CLOSE BUTTON ═══ -->
    <Style Selector="Button.window-btn-close">
        <Setter Property="Background" Value="{DynamicResource SystemErrorTransparentBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn-close:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBrush}" />
    </Style>
    <Style Selector="Button.window-btn-close:pointerover > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.window-btn-close:pressed">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBgBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ACCENT-BASE: ОБЩИЙ Fluent override для accent-кнопок               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                                                                     -->
    <!-- Применяется к: Button.accent, Button.primary-btn, Button.play-circle -->
    <!-- Гарантирует что Foreground остаётся AccentButtonTextBrush           -->
    <!-- во всех состояниях, несмотря на Fluent перехват.                    -->
    <!--                                                                     -->
    <!-- ИСПОЛЬЗОВАНИЕ: добавьте класс accent-base к кнопке:               -->
    <!--   <Button Classes="accent accent-base" .../>                        -->
    <!--   <Button Classes="primary-btn accent-base" .../>                   -->
    <!--   <Button Classes="play-circle accent-base" .../>                   -->
    <!--                                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.accent-base /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style
        Selector="Button.accent-base:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.accent-base:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.accent-base TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.accent-base:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.accent-base PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ACCENT BUTTON                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.accent:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PRIMARY BUTTON                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.primary-btn">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.primary-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SIDEBAR BUTTON                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.sidebar-btn">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn.active">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn.active:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn TextBlock">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.sidebar-btn ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ICON BUTTON                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.icon-btn">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.icon-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.icon-btn:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.icon-btn:disabled">
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>
    <Style Selector="Button.icon-btn:disabled PathIcon">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.icon-btn PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.icon-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.icon-btn.active PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PLAYBACK BUTTONS                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.playback-btn">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.playback-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.playback-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.playback-btn.active:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.playback-btn:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.playback-btn.disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>
    <Style
        Selector="Button.playback-btn.disabled PathIcon,
                     Button.playback-btn:disabled PathIcon">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.playback-btn-main">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.playback-btn-main:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.playback-btn-main:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <!-- Иконка: AccentButtonTextBrush + белый эффект для тёмных акцентов -->
    <Style Selector="Button.playback-btn-main PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <!-- Template override: убираем дефолтный hover фон Avalonia -->
    <Style Selector="Button.playback-btn-main /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PLAY CIRCLE                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.play-circle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextTransparentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.play-circle:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="Button.play-circle:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DELETE BUTTON                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.delete-btn">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border:pointerover Button.delete-btn">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.delete-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBgBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FILTER TYPE BUTTON                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.filter-type-btn">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.filter-type-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.filter-type-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GHOST BUTTON                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.ghost-btn">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ghost-btn:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.ghost-btn:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.ghost-btn PathIcon">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ghost-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.ghost-btn TextBlock">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost-btn ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost-btn:disabled">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Opacity" Value="0.4" />
    </Style>
    <Style Selector="Button.ghost-btn:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost-btn:disabled PathIcon">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SEARCH CHIP — история поиска с кнопкой удаления                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Контейнер чипа -->
    <Style Selector="Border.search-chip">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.search-chip:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Текст чипа (кликабельный) -->
    <Style Selector="Button.search-chip-text">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Padding" Value="12,5,4,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CornerRadius" Value="14,0,0,14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.search-chip-text:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.search-chip-text /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="Button.search-chip-text:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Крестик удаления -->
    <Style Selector="Button.search-chip-close">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Padding" Value="2,4,8,4" />
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.search-chip-close:pointerover">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.search-chip-close /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="Button.search-chip-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.search-chip-close PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.search-chip-close:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- NAV TAB — Навигационные вкладки в TitleBar (браузерный стиль)      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.nav-tab">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Height" Value="46" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Hover: border из того же RGB семейства — без мигания -->
    <Style Selector="Button.nav-tab:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
    </Style>
    <Style Selector="Button.nav-tab:pressed">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <!-- Active: акцентный нижний border, некликабельна -->
    <Style Selector="Button.nav-tab.active">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <!-- Текст: 11px для компактности -->
    <Style Selector="Button.nav-tab TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.nav-tab ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Иконка: 20px -->
    <Style Selector="Button.nav-tab PathIcon">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.nav-tab:pointerover PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.nav-tab.active PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Fluent override -->
    <Style Selector="Button.nav-tab /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.nav-tab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.nav-tab:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.nav-tab:disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SYNC TOGGLE — Toggle-кнопки фильтрации в диалоге синхронизации    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                                                                     -->
    <!-- Chip-style toggle: скруглённые, с иконкой.                         -->
    <!-- Unchecked: ghost-стиль (прозрачный фон, мягкая обводка).           -->
    <!-- Checked: акцентный фон.                                            -->
    <!--                                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="ToggleButton.sync-toggle">
        <Setter Property="Background" Value="{DynamicResource BgHighlightTransparentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ToggleButton">
                <Border
                    Name="PART_Border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter
                        Name="PART_ContentPresenter"
                        Background="Transparent"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Hover (unchecked) -->
    <Style Selector="ToggleButton.sync-toggle:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Checked: акцентный стиль -->
    <Style Selector="ToggleButton.sync-toggle:checked">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.sync-toggle:checked:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <!-- Checked: иконка и текст наследуют AccentButtonTextBrush -->
    <Style Selector="ToggleButton.sync-toggle:checked PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="ToggleButton.sync-toggle:checked TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Fluent override для ToggleButton -->
    <Style Selector="ToggleButton.sync-toggle /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="ToggleButton.sync-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="ToggleButton.sync-toggle:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style
        Selector="ToggleButton.sync-toggle:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonTextBrush}" />
    </Style>
    <Style Selector="ToggleButton.sync-toggle TextBlock">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CTRL BUTTON — кнопки управления окном и панели уведомлений         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                                                                     -->
    <!-- Inline BorderBrush на Button — local value, блокирует :pointerover -->
    <!-- из глобальных стилей. Класс решает проблему: style setter имеет    -->
    <!-- правильный приоритет и анимация работает корректно.                -->
    <!--                                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button.ctrl-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ctrl-btn:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.ctrl-btn:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.ctrl-btn /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.ctrl-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.ctrl-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Вариант для кнопки закрытия: SystemError вместо Accent -->
    <Style Selector="Button.ctrl-btn-close">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemErrorTransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ctrl-btn-close:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemErrorBrush}" />
    </Style>
    <Style Selector="Button.ctrl-btn-close:pressed">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemErrorBrush}" />
    </Style>
    <Style Selector="Button.ctrl-btn-close /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style
        Selector="Button.ctrl-btn-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</Styles>