<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">


    <!-- SHARED RESOURCES (only non-transition resources)                     -->


    <Style>
        <Style.Resources>
            <BoxShadows x:Key="CardShadow">0 4 8 0 #40000000</BoxShadows>
            <BoxShadows x:Key="SmallShadow">0 2 4 0 #40000000</BoxShadows>
        </Style.Resources>
    </Style>


    <!-- BASE STYLES     -->


    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BgPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
    </Style>


    <!-- WINDOW CONTROL BUTTONS                                               -->


    <Style Selector="Button.window-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.window-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Button.window-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <!-- Window button icons -->
    <Style Selector="Button.window-btn > Border">
        <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.window-btn:pointerover > Border">
        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-btn > Panel > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.window-btn:pointerover > Panel > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-btn > Panel > Grid > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.window-btn:pointerover > Panel > Grid > Border">
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-btn > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Stroke" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.window-btn:pointerover > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Close button -->
    <Style Selector="Button.window-btn-close:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <Style Selector="Button.window-btn-close:pointerover > Grid > Line">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.window-btn-close:pressed">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBgBrush}" />
    </Style>


    <!-- APP LOGO BUTTON -->


    <Style Selector="Button#AppLogoButton:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button#AppLogoButton StackPanel Grid Path">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Fill" Duration="0:0:0.15" />
                <BrushTransition Property="Stroke" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button#AppLogoButton:pointerover StackPanel Grid Path">
        <Setter Property="Fill" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="Stroke" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Button#AppLogoButton StackPanel Grid Border">
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button#AppLogoButton:pointerover StackPanel Grid Border">
        <Setter Property="Opacity" Value="0.25" />
    </Style>


    <!-- ACCENT BUTTON   -->


    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Button.accent:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="Button.accent TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>


    <!-- PRIMARY BUTTON  -->


    <Style Selector="Button.primary-btn">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.primary-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.04)" />
    </Style>

    <Style Selector="Button.primary-btn:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="Button.primary-btn TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>


    <!-- SIDEBAR BUTTON  -->


    <Style Selector="Button.sidebar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.sidebar-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.sidebar-btn.active">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.sidebar-btn:disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="Button.sidebar-btn.active:disabled">
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>


    <!-- ICON BUTTON     -->


    <Style Selector="Button.icon-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.icon-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.1)" />
    </Style>

    <Style Selector="Button.icon-btn mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.icon-btn:pointerover mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.icon-btn.active mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>


    <!-- PLAYBACK BUTTON -->


    <Style Selector="Button.playback-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.playback-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.1)" />
    </Style>

    <Style Selector="Button.playback-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)" />
    </Style>

    <Style Selector="Button.playback-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.playback-btn.active:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Button.playback-btn.disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>


    <!-- MAIN PLAY/PAUSE BUTTON                                               -->


    <Style Selector="Button.playback-btn-main">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.playback-btn-main:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.08)" />
    </Style>

    <Style Selector="Button.playback-btn-main:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)" />
    </Style>

    <Style Selector="Button.playback-btn-main.disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>


    <!-- PLAY CIRCLE BUTTON                                                   -->


    <Style Selector="Button.play-circle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.play-circle:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.06)" />
    </Style>

    <Style Selector="Button.play-circle mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>


    <!-- DELETE BUTTON   -->


    <Style Selector="Button.delete-btn">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border:pointerover Button.delete-btn">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.delete-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemError}" />
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBg}" />
    </Style>


    <!-- VOLUME BAR      -->


    <Style Selector="Border.volume-bar">
        <Setter Property="Width" Value="4" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.volume-bar.boosted">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>


    <!-- SLIDER COMPONENTS                                                    -->


    <Style Selector="Border.slider-track">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Opacity" Value="0.2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.slider-fill">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Border.slider-buffer">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="Border.slider-area">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Border.slider-area[IsHitTestVisible=False]">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="Ellipse.slider-thumb">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                <BrushTransition Property="Fill" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.slider-area:pointerover Ellipse.slider-thumb">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Ellipse.slider-thumb.dragging">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="scale(1.2)" />
        <Setter Property="Fill" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Border.slider-tooltip">
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="IsVisible" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="RenderTransform">
            <TranslateTransform />
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBlock.slider-tooltip-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>


    <!-- INDICATORS      -->


    <Style Selector="Border.repeat-indicator">
        <Setter Property="Width" Value="4" />
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.repeat-indicator.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Border.mode-hint">
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #40000000" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,1" />
        <Setter Property="RenderTransform" Value="translateY(8px)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.mode-hint.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>

    <Style Selector="Border.seek-busy-indicator">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3" />
                    <Setter Property="BorderThickness" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="BorderThickness" Value="2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.3" />
                    <Setter Property="BorderThickness" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.seek-gradient-runner">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="2" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0.8" />
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="-40" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="20%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="80%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.X" Value="400" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>


    <!-- LOADING DOTS    -->


    <Style Selector="Ellipse.loading-dot">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Ellipse.loading-dot-2">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.15">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Ellipse.loading-dot-3">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.3">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="TextBlock.loading-dot1">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="TextBlock.loading-dot2">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.2">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="TextBlock.loading-dot3">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.4">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>


    <!-- TEXTBOX STYLES  -->


    <Style Selector="TextBox.search-box">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="40,10,16,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBox.search-box:focus">
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="TextBox.search-box:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="TextBox.filter-ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBox.filter-ghost:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox.filter-ghost:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
    </Style>


    <!-- FILTER TYPE BUTTONS                                                  -->


    <Style Selector="Button.filter-type-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.filter-type-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Button.filter-type-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>


    <!-- TRACK LIST STYLES                                                    -->


    <Style Selector="ListBox.track-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.track-list ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Transitions">
            <Transitions>
                <ThicknessTransition Property="BorderThickness" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border Name="PART_RootBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter Name="PART_ContentPresenter"
                        Background="Transparent"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style
        Selector="ListBox.track-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style
        Selector="ListBox.track-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Track Row -->
    <Style Selector="Border.track-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row.is-active">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <Style Selector="Border.track-row.menu-open">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row.is-active.menu-open">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <Style Selector="Border.track-row.menu-open:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <!-- Cover Button -->
    <Style Selector="Button.cover-btn">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.cover-btn Panel.cover-overlay">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.cover-btn:pointerover Panel.cover-overlay">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.cover-btn mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.85)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.cover-btn:pointerover mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Button.cover-btn:pressed mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransform" Value="scale(0.9)" />
    </Style>

    <!-- Playing Indicator -->
    <Style Selector="mi|MaterialIcon.playing-indicator">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.6" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Track Title -->
    <Style Selector="Border.track-row TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row.is-active TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Like Button -->
    <Style Selector="Button.like-btn">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(1)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.85)" />
    </Style>

    <Style Selector="Button.like-btn.is-liked">
        <Setter Property="RenderTransform" Value="scale(1.05)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn.is-liked mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- More Button -->
    <Style Selector="Button.more-btn">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.8)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover Button.more-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Border.track-row.menu-open Button.more-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Button.more-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.9)" />
    </Style>

    <!-- Remove Button -->
    <Style Selector="Button.remove-btn">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.8)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover Button.remove-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <!-- Duration text -->
    <Style Selector="Border.track-row TextBlock.duration-text">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <Style Selector="Border.track-row.menu-open TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- Drag & Drop -->
    <Style Selector="ListBox.track-list ListBoxItem.dragging">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="ListBox.track-list ListBoxItem.insert-top">
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ListBox.track-list ListBoxItem.insert-bottom">
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>


    <!-- CONTEXT MENU    -->


    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinWidth" Value="180" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="MenuItem mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="MenuItem.danger">
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <Style Selector="MenuItem.danger mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <Style Selector="Separator.menu-separator">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="8,4" />
    </Style>


    <!-- STANDARD AVALONIA CONTROLS OVERRIDE                                  -->


    <!-- Standard Button -->
    <Style
        Selector="Button:not(.accent):not(.primary-btn):not(.sidebar-btn):not(.icon-btn):not(.playback-btn):not(.playback-btn-main):not(.window-btn):not(.window-btn-close):not(.card-action-btn):not(.cover-btn):not(.like-btn):not(.more-btn):not(.remove-btn):not(.delete-btn):not(.play-circle):not(.filter-type-btn)">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style
        Selector="Button:not(.accent):not(.primary-btn):not(.sidebar-btn):not(.icon-btn):not(.playback-btn):not(.playback-btn-main):not(.window-btn):not(.window-btn-close):not(.card-action-btn):not(.cover-btn):not(.like-btn):not(.more-btn):not(.remove-btn):not(.delete-btn):not(.play-circle):not(.filter-type-btn):pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <Style
        Selector="Button:not(.accent):not(.primary-btn):not(.sidebar-btn):not(.icon-btn):not(.playback-btn):not(.playback-btn-main):not(.window-btn):not(.window-btn-close):not(.card-action-btn):not(.cover-btn):not(.like-btn):not(.more-btn):not(.remove-btn):not(.delete-btn):not(.play-circle):not(.filter-type-btn):pressed">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="CheckBox /template/ Path#CheckGlyph">
        <Setter Property="Fill" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <!-- RadioButton -->
    <Style Selector="RadioButton:not(.chip)">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="RadioButton:not(.chip) /template/ Ellipse#OuterEllipse">
        <Setter Property="Stroke" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Fill" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <Style Selector="RadioButton:not(.chip):pointerover /template/ Ellipse#OuterEllipse">
        <Setter Property="Stroke" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Fill" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <Style Selector="RadioButton:not(.chip):checked /template/ Ellipse#OuterEllipse">
        <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Fill" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <Style Selector="RadioButton:not(.chip) /template/ Ellipse#CheckGlyph">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ToggleSwitch -->
    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
    </Style>

    <Style Selector="ToggleSwitch /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="ToggleSwitch:pointerover /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="ToggleSwitch:checked /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="ToggleSwitch /template/ Border#SwitchKnob">
        <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="ToggleSwitch:pointerover /template/ Border#SwitchKnob">
        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnob">
        <Setter Property="Background" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#SwitchKnob">
        <Setter Property="Background" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <!-- Slider -->
    <Style Selector="Slider">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Slider /template/ Border#TrackBackground">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="Slider:horizontal /template/ Border#PART_SelectionRange">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Slider /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Slider /template/ Thumb /template/ Border">
        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Slider:pointerover /template/ Thumb /template/ Border">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Slider:pressed /template/ Thumb /template/ Border">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ComboBox /template/ Popup Border">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="4,2" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <Style
        Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
    </Style>

    <!-- TextBox -->
    <Style Selector="TextBox:not(.search-box):not(.filter-ghost)">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style
        Selector="TextBox:not(.search-box):not(.filter-ghost):pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style
        Selector="TextBox:not(.search-box):not(.filter-ghost):focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Multiline TextBox -->
    <Style Selector="TextBox[AcceptsReturn=True]">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox[AcceptsReturn=True]:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- ScrollBar -->
    <Style Selector="ScrollBar /template/ Border#TrackRect">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style Selector="ScrollBar:pointerover /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- ProgressBar -->
    <Style Selector="ProgressBar">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ProgressBar /template/ Border#PART_Indicator">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Chip RadioButton -->
    <Style Selector="RadioButton.chip:checked">
        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BgPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="RadioButton.chip:checked ContentPresenter">
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BgPrimaryBrush}" />
    </Style>

</Styles>