<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

    <!-- 
      NOTE: Color definitions have been moved to ThemeManagerService.
      This file now only contains styles referencing those dynamic resources.
    -->

    <Style>
        <Style.Resources>
            <!-- Shadows remain here as they are complex objects, not simple colors -->
            <BoxShadows x:Key="CardShadow">0 4 8 0 #40000000</BoxShadows>
            <BoxShadows x:Key="SmallShadow">0 2 4 0 #40000000</BoxShadows>
        </Style.Resources>
    </Style>

    <!-- Window Style -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BgPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
    </Style>

    <!-- Accent Button -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.accent:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Sidebar Button -->
    <Style Selector="Button.sidebar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn.active">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.sidebar-btn:disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>
    <Style Selector="Button.sidebar-btn.active:disabled">
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <!-- Icon Button -->
    <Style Selector="Button.icon-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.icon-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.1)" />
    </Style>

    <!-- Playback Control Button -->
    <Style Selector="Button.playback-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.playback-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.1)" />
    </Style>
    <Style Selector="Button.playback-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)" />
    </Style>
    <Style Selector="Button.playback-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.playback-btn.active:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.playback-btn.disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- Main Play/Pause Button -->
    <Style Selector="Button.playback-btn-main">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.playback-btn-main:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.08)" />
    </Style>
    <Style Selector="Button.playback-btn-main:pressed">
        <Setter Property="RenderTransform" Value="scale(0.95)" />
    </Style>
    <Style Selector="Button.playback-btn-main.disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- Delete Button -->
    <Style Selector="Button.delete-btn">
        <Setter Property="Background" Value="#80000000" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border:pointerover Button.delete-btn">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.delete-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemErrorBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Primary Button -->
    <Style Selector="Button.primary-btn">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.04)" />
    </Style>

    <!-- Play Circle Button -->
    <Style Selector="Button.play-circle">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.play-circle:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="RenderTransform" Value="scale(1.06)" />
    </Style>

    <!-- Volume Bar -->
    <Style Selector="Border.volume-bar">
        <Setter Property="Width" Value="4" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.volume-bar.boosted">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Slider Thumb -->
    <Style Selector="Ellipse.slider-thumb">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.slider-area:pointerover Ellipse.slider-thumb">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Ellipse.slider-thumb.dragging">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="scale(1.2)" />
    </Style>

    <!-- Repeat Indicator -->
    <Style Selector="Border.repeat-indicator">
        <Setter Property="Width" Value="4" />
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.repeat-indicator.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <!-- Mode Hint Popup -->
    <Style Selector="Border.mode-hint">
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #40000000" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,1" />
        <Setter Property="RenderTransform" Value="translateY(8px)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.mode-hint.visible">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>

    <!-- Seek Busy Indicator -->
    <Style Selector="Border.seek-busy-indicator">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.3" />
                    <Setter Property="BorderThickness" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="BorderThickness" Value="2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.3" />
                    <Setter Property="BorderThickness" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Loading Dots -->
    <Style Selector="Ellipse.loading-dot">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Ellipse.loading-dot-2">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.15">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Ellipse.loading-dot-3">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" Delay="0:0:0.3">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="33%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="66%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- TextBox Search -->
    <Style Selector="TextBox.search-box">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="40,10,16,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="TextBox.search-box:focus">
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>
    <Style Selector="TextBox.search-box:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>


    <!-- Анимированная иконка (Like/Copy) -->
    <!-- Заменяет локальные стили и переходы внутри кнопок -->
    <Style Selector="Button.icon-btn mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <!-- При наведении на кнопку, иконка светлеет -->
    <Style Selector="Button.icon-btn:pointerover mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Стиль для активного состояния (например, Лайк поставлен) -->
    <!-- Используется через Classes="active" или привязку свойства -->
    <Style Selector="Button.icon-btn.active mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Слайдеры (Seek Bar & Volume) -->
    <!-- Фон дорожки -->
    <Style Selector="Border.slider-track">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Заполненная часть дорожки -->
    <Style Selector="Border.slider-fill">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Буферная часть дорожки -->
    <Style Selector="Border.slider-buffer">
        <Setter Property="Height" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
    </Style>

    <!-- Область клика (HitBox) -->
    <Style Selector="Border.slider-area">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <!-- Отключаем область клика, если трека нет -->
    <Style Selector="Border.slider-area[IsHitTestVisible=False]">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Tooltip над слайдером (время/громкость) -->
    <Style Selector="Border.slider-tooltip">
        <Setter Property="Background" Value="{DynamicResource BgSkeletonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="IsVisible" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="RenderTransform">
            <TranslateTransform />
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Текст внутри tooltip -->
    <Style Selector="TextBlock.slider-tooltip-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Градиентный бегунок загрузки (Seek Gradient Runner) -->
    <Style Selector="Border.seek-gradient-runner">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="2" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0.8" />
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="-40" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="20%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="80%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.X" Value="400" /> <!-- Примерная ширина -->
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Невидимый TextBox для фильтра -->
    <Style Selector="TextBox.filter-ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBox.filter-ghost:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.filter-ghost:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Кнопки типов (Music/Video/All) -->
    <Style Selector="Button.filter-type-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.filter-type-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <!-- Активное состояние для кнопок (применяется через Classes="active") -->
    <Style Selector="Button.filter-type-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="#1AFFFFFF" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         TRACK LIST STYLES - Полные стили для TrackListControl
         ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- LISTBOX CONTAINER -->
    <Style Selector="ListBox.track-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- LISTBOXITEM - с поддержкой drag & drop индикаторов -->
    <Style Selector="ListBox.track-list ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Transitions">
            <Transitions>
                <ThicknessTransition Property="BorderThickness" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border
                    Name="PART_RootBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="0"
                    Margin="0">
                    <ContentPresenter
                        Name="PART_ContentPresenter"
                        Background="Transparent"
                        Padding="0"
                        Margin="0"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Особенное состояние прозрачности -->
    <Style
        Selector="ListBox.track-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style
        Selector="ListBox.track-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ═══ СТРОКА ТРЕКА ═══ -->

    <Style Selector="Border.track-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row.is-active">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <!-- Меню открыто - ВСЕГДА сохраняем подсветку (высокий приоритет) -->
    <Style Selector="Border.track-row.menu-open">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <Style Selector="Border.track-row.is-active.menu-open">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    </Style>

    <!-- Меню открыто + pointerover (на случай если курсор вернулся) -->
    <Style Selector="Border.track-row.menu-open:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
    </Style>

    <!-- ═══ ОБЛОЖКА ТРЕКА ═══ -->

    <Style Selector="Button.cover-btn">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.cover-btn Panel.cover-overlay">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.cover-btn:pointerover Panel.cover-overlay">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.cover-btn mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.85)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.cover-btn:pointerover mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Button.cover-btn:pressed mi|MaterialIcon.play-icon">
        <Setter Property="RenderTransform" Value="scale(0.9)" />
    </Style>

    <!-- ═══ ИНДИКАТОР ВОСПРОИЗВЕДЕНИЯ ═══ -->

    <Style Selector="mi|MaterialIcon.playing-indicator">
        <Style.Animations>
            <Animation Duration="0:0:0.8" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.6" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ═══ ЗАГОЛОВОК ТРЕКА ═══ -->

    <Style Selector="Border.track-row TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row.is-active TextBlock.track-title">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ═══ КНОПКА ЛАЙКА ═══ -->

    <Style Selector="Button.like-btn">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(1)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.85)" />
    </Style>

    <Style Selector="Button.like-btn.is-liked">
        <Setter Property="RenderTransform" Value="scale(1.05)" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                    Easing="BackEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.like-btn.is-liked mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ═══ КНОПКА MORE (три точки) ═══ -->

    <Style Selector="Button.more-btn">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.8)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover Button.more-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <!-- Меню открыто - кнопка видна -->
    <Style Selector="Border.track-row.menu-open Button.more-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <Style Selector="Button.more-btn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.9)" />
    </Style>

    <!-- ═══ КНОПКА УДАЛЕНИЯ (для очереди) ═══ -->

    <Style Selector="Button.remove-btn">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.8)" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"
                    Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover Button.remove-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

    <!-- ═══ ДЛИТЕЛЬНОСТЬ ═══ -->

    <Style Selector="Border.track-row TextBlock.duration-text">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.track-row:pointerover TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- Меню открыто - длительность скрыта -->
    <Style Selector="Border.track-row.menu-open TextBlock.duration-text">
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- ═══ КОНТЕКСТНОЕ МЕНЮ ═══ -->

    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinWidth" Value="180" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="MenuItem mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="MenuItem.danger">
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <Style Selector="MenuItem.danger mi|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource SystemErrorBrush}" />
    </Style>

    <Style Selector="Separator.menu-separator">
        <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="8,4" />
    </Style>

    <!-- ═══ АНИМАЦИЯ ТОЧЕК ЗАГРУЗКИ ═══ -->

    <Style Selector="TextBlock.loading-dot1">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="TextBlock.loading-dot2">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.2">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="TextBlock.loading-dot3">
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.4">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="25%">
                    <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ════════ DRAG & DROP STYLES ════════ -->

    <!-- Перетаскиваемый элемент становится полупрозрачным -->
    <Style Selector="ListBox.track-list ListBoxItem.dragging">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Линия вставки СВЕРХУ -->
    <Style Selector="ListBox.track-list ListBoxItem.insert-top">
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- Линия вставки СНИЗУ -->
    <Style Selector="ListBox.track-list ListBoxItem.insert-bottom">
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
</Styles>