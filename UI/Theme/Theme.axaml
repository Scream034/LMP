<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ПОДКЛЮЧАЕМ РАЗДЕЛЕННЫЕ ТЕМЫ -->
    <StyleInclude Source="avares://LMP/UI/Theme/Typography.axaml" />
    <StyleInclude Source="avares://LMP/UI/Theme/Buttons.axaml" />
    <StyleInclude Source="avares://LMP/UI/Theme/Controls.axaml" />
    <StyleInclude Source="avares://LMP/UI/Theme/AppComponents.axaml" />
    <!-- PlayerBarStyles ПОСЛЕ AppComponents — переопределяет vol-* стили -->
    <StyleInclude Source="avares://LMP/UI/Features/Player/PlayerBarStyles.axaml" />

    <Style>
        <Style.Resources>
            <BoxShadows x:Key="CardShadow">0 4 8 0 #40000000</BoxShadows>
            <BoxShadows x:Key="SmallShadow">0 2 4 0 #40000000</BoxShadows>
        </Style.Resources>
    </Style>

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BgPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI, sans-serif" />
    </Style>

</Styles>