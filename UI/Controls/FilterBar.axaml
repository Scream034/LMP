<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LMP.UI.Controls"
    x:Class="LMP.UI.Controls.FilterBar"
    x:Name="Root"
    x:DataType="local:FilterBar">

    <TextBox Text="{Binding FilterText, ElementName=Root, Mode=TwoWay}"
        PlaceholderText="{Binding Watermark, ElementName=Root}"
        Height="{Binding BarHeight, ElementName=Root}"
        CornerRadius="{Binding BarCornerRadius, ElementName=Root}"
        FontSize="{Binding TextFontSize, ElementName=Root}"
        VerticalContentAlignment="Center"
        Padding="6,0,12,0">
        <TextBox.InnerLeftContent>
            <!--
                IconData привязан к вычисляемому DirectProperty FilterBar.IconData,
                которое возвращает StreamGeometry из Application.Resources по ключу IconKey.
                Это позволяет менять иконку снаружи через строковый ключ без зависимости
                от Material.Icons.
            -->
            <PathIcon Data="{Binding IconData, ElementName=Root}"
                Width="{Binding IconSize, ElementName=Root}"
                Height="{Binding IconSize, ElementName=Root}"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Margin="12,0,8,0" />
        </TextBox.InnerLeftContent>
    </TextBox>
</UserControl>