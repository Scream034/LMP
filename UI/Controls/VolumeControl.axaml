<UserControl
    x:Class="LMP.UI.Controls.VolumeControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LMP.UI.Controls"
    x:Name="rootVolumeControl"
    ClipToBounds="False">

    <Panel Name="VolumePanel">
        <!-- Кнопка вызова/сворачивания (Управление свойствами перенесено в Code-Behind) -->
        <Button x:Name="VolumeButton" Width="38" Height="38"
            Classes="icon-btn"
            Transitions="{x:Null}"
            Click="OnVolumeButtonClick"
            PointerWheelChanged="OnVolumeScroll">
            <Grid>
                <PathIcon Width="24" Height="24"
                    Foreground="{Binding $parent[Button].Foreground}"
                    Data="{StaticResource Icon.VolumeMute}"
                    IsVisible="{Binding IsMuted, RelativeSource={RelativeSource AncestorType=controls:VolumeControl}}" />
                <PathIcon Width="24" Height="24"
                    Foreground="{Binding $parent[Button].Foreground}"
                    Data="{StaticResource Icon.VolumeLow}"
                    IsVisible="{Binding IsVolumeLow, RelativeSource={RelativeSource AncestorType=controls:VolumeControl}}" />
                <PathIcon Width="24" Height="24"
                    Foreground="{Binding $parent[Button].Foreground}"
                    Data="{StaticResource Icon.VolumeMedium}"
                    IsVisible="{Binding IsVolumeMedium, RelativeSource={RelativeSource AncestorType=controls:VolumeControl}}" />
                <PathIcon Width="24" Height="24"
                    Foreground="{Binding $parent[Button].Foreground}"
                    Data="{StaticResource Icon.VolumeHigh}"
                    IsVisible="{Binding IsVolumeHigh, RelativeSource={RelativeSource AncestorType=controls:VolumeControl}}" />
                <PathIcon Width="24" Height="24"
                    Foreground="{Binding $parent[Button].Foreground}"
                    Data="{StaticResource Icon.VolumeVibrate}"
                    IsVisible="{Binding IsVolumeBoosted, RelativeSource={RelativeSource AncestorType=controls:VolumeControl}}" />
            </Grid>
        </Button>

        <!-- Вертикальный парящий Popup-слайдер -->
        <Popup
            x:Name="VolumePopup"
            IsLightDismissEnabled="False"
            Placement="Top"
            PlacementTarget="{Binding #VolumeButton}"
            VerticalOffset="2">
            <Border
                x:Name="PopupBorder"
                DataContext="{Binding #rootVolumeControl}"
                x:DataType="controls:VolumeControl"
                Width="38"
                Padding="6,8"
                Background="Transparent"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2,2,2,0"
                CornerRadius="10,10,0,0"
                ClipToBounds="False"
                PointerEntered="OnVolumePopupContentEntered"
                PointerExited="OnVolumePopupContentExited">
                <Grid RowDefinitions="Auto,*">
                    
                    <TextBlock Name="VolumeValueText"
                        Grid.Row="0"
                        FontSize="11"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,6"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="{Binding VolumePercentText}" />

                    <Panel
                        Grid.Row="1"
                        Name="VolumeSliderPanel"
                        Width="16" 
                        Height="{Binding VolumeSliderHeight}"
                        HorizontalAlignment="Center">
                        
                        <Border Width="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            Classes="vol-track" />
                            
                        <Border Name="VolumeBar"
                            Width="3" Height="0" MinHeight="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Classes="vol-fill" />
                            
                        <Ellipse Name="VolumeThumb"
                            Width="10" Height="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Classes="vol-thumb" />

                        <Border Name="VolumeHitBox"
                            Width="16"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            Cursor="Hand"
                            PointerCaptureLost="OnVolumeAreaCaptureLost"
                            PointerExited="OnVolumeAreaExited"
                            PointerMoved="OnVolumeAreaMoved"
                            PointerPressed="OnVolumeAreaPressed"
                            PointerReleased="OnVolumeAreaReleased"
                            PointerWheelChanged="OnVolumeScroll" />
                    </Panel>
                </Grid>
            </Border>
        </Popup>
    </Panel>
</UserControl>