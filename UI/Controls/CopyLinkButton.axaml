<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="LMP.UI.Controls.CopyLinkButton"
    x:Name="Root">

    <UserControl.Styles>
        <Style Selector="Button.copy-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.copy-btn Border.hover-ring">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.10" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.copy-btn:pointerover Border.hover-ring">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.copy-btn:pressed Border.hover-ring">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.copy-btn:pressed">
            <Setter Property="Opacity" Value="0.82" />
        </Style>
    </UserControl.Styles>

    <Button Classes="copy-btn"
        Click="OnClick"
        Width="{Binding ButtonSize, ElementName=Root}"
        Height="{Binding ButtonSize, ElementName=Root}"
        CornerRadius="999"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        ToolTip.Tip="{Binding ToolTipText, ElementName=Root}">

        <Grid Width="{Binding ButtonSize, ElementName=Root}"
            Height="{Binding ButtonSize, ElementName=Root}">

            <Border Classes="hover-ring"
                Margin="2"
                CornerRadius="999"
                BorderThickness="1"
                IsVisible="{Binding ShowHoverRing, ElementName=Root}"
                BorderBrush="{DynamicResource AccentBrush}" />

            <mi:MaterialIcon x:Name="LinkIcon"
                Width="{Binding IconSize, ElementName=Root}"
                Height="{Binding IconSize, ElementName=Root}"
                Kind="{Binding IconKind, ElementName=Root}"
                Foreground="{Binding IconForeground, ElementName=Root}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <mi:MaterialIcon.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                    </Transitions>
                </mi:MaterialIcon.Transitions>
            </mi:MaterialIcon>
        </Grid>
    </Button>
</UserControl>