<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:LMP.UI.Controls"
             x:Class="LMP.UI.Controls.AppIcon"
             x:DataType="local:AppIcon">
    
    <Grid x:Name="RootGrid">
        <!-- Glow -->
        <Border x:Name="GlowBorder"
                CornerRadius="4" 
                Background="{DynamicResource AccentBrush}" 
                Opacity="0.15"
                IsVisible="False" />
        
        <!-- Play Triangle -->
        <Path x:Name="PlayPath"
              Data="M8,5 L19,12 L8,19 Z" 
              Fill="{DynamicResource AccentBrush}"
              Stretch="Uniform" 
              HorizontalAlignment="Left" 
              VerticalAlignment="Center" />
        
        <!-- Speed Chevrons -->
        <StackPanel x:Name="ChevronsPanel"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom">
            <Path x:Name="Chevron1"
                  Data="M0,0 L6,6 L0,12" 
                  Stroke="{DynamicResource AccentBrush}" 
                  StrokeLineCap="Round"
                  Stretch="Uniform" />
            <Path x:Name="Chevron2"
                  Data="M0,0 L6,6 L0,12" 
                  Stroke="{DynamicResource AccentBrush}" 
                  StrokeLineCap="Round"
                  Stretch="Uniform" />
        </StackPanel>
    </Grid>
</UserControl>