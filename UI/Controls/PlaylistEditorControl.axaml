<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="using:LMP.UI.Dialogs"
    xmlns:controls="using:LMP.UI.Controls"
    xmlns:asyncImage="using:AsyncImageLoader"
    x:Class="LMP.UI.Controls.PlaylistEditorControl"
    x:DataType="d:PlaylistEditorViewModel"
    x:CompileBindings="True">

    <StackPanel Spacing="14">

        <!-- ═══ Name ═══ -->
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding L[EditPlaylist_Name]}"
                FontSize="13" FontWeight="SemiBold"
                Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding Name, Mode=TwoWay}"
                Watermark="{Binding L[Library_PlaylistNameHint]}"
                IsReadOnly="{Binding IsSystemPlaylist}" />
            <TextBlock Text="{Binding L[EditPlaylist_SystemNameHint]}"
                FontSize="11"
                Foreground="{DynamicResource TextMutedBrush}"
                IsVisible="{Binding IsSystemPlaylist}" />
        </StackPanel>

        <!-- ═══ Description ═══ -->
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding L[EditPlaylist_Description]}"
                FontSize="13" FontWeight="SemiBold"
                Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding Description, Mode=TwoWay}"
                Watermark="{Binding L[EditPlaylist_DescriptionHint]}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                MinHeight="48"
                MaxHeight="80"
                FontSize="12" />
        </StackPanel>

        <!-- ═══ Thumbnail Section ═══ -->
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding L[EditPlaylist_Cover]}"
                FontSize="13" FontWeight="SemiBold"
                Foreground="{DynamicResource TextSecondaryBrush}" />

            <Border Background="{DynamicResource BgElevatedBrush}"
                CornerRadius="8"
                Padding="12">
                <StackPanel Spacing="10">

                    <!-- Переключатель вкладок -->
                    <StackPanel Orientation="Horizontal" Spacing="4"
                        IsVisible="{Binding ShowCoverModeSwitch}">
                        <!-- Вкладка URL -->
                        <Button Padding="10,5" FontSize="11" CornerRadius="12"
                            Command="{Binding SetCoverModeUrl}"
                            Classes.ghost-btn="{Binding !IsCoverModeUrl}"
                            Classes.accent="{Binding IsCoverModeUrl}"
                            Classes.accent-base="{Binding IsCoverModeUrl}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Data="{StaticResource Icon.Link}" Width="13" Height="13" />
                                <TextBlock Text="URL" FontSize="11" />
                            </StackPanel>
                        </Button>

                        <!-- Вкладка из треков -->
                        <Button Padding="10,5" FontSize="11" CornerRadius="12"
                            Command="{Binding SetCoverModeFromTracks}"
                            IsVisible="{Binding HasTracksCoverOption}"
                            Classes.ghost-btn="{Binding !IsCoverModeFromTracks}"
                            Classes.accent="{Binding IsCoverModeFromTracks}"
                            Classes.accent-base="{Binding IsCoverModeFromTracks}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Data="{StaticResource Icon.ImageMultipleOutline}"
                                    Width="13" Height="13" />
                                <TextBlock Text="{Binding L[CoverPicker_Tab]}" FontSize="11" />
                            </StackPanel>
                        </Button>

                        <!-- Вкладка файл -->
                        <Button Padding="10,5" FontSize="11" CornerRadius="12"
                            Command="{Binding SetCoverModeFile}"
                            Classes.ghost-btn="{Binding !IsCoverModeFile}"
                            Classes.accent="{Binding IsCoverModeFile}"
                            Classes.accent-base="{Binding IsCoverModeFile}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Data="{StaticResource Icon.FileImageOutline}" Width="13"
                                    Height="13" />
                                <TextBlock Text="{Binding L[CoverPicker_FileTab]}" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ═══ URL ═══ -->
                    <Grid ColumnDefinitions="*, Auto"
                        IsVisible="{Binding IsCoverModeUrl}">
                        <TextBox Grid.Column="0"
                            Text="{Binding ThumbnailUrl, Mode=TwoWay}"
                            Watermark="https://..."
                            FontSize="12" />
                        <Border Grid.Column="1"
                            Width="36" Height="36"
                            CornerRadius="6" ClipToBounds="True"
                            Margin="8,0,0,0"
                            Background="{DynamicResource BgSkeletonBrush}">
                            <Panel>
                                <!-- Превью URL: заглушка без изображения -->
                                <PathIcon Data="{StaticResource Icon.ImageOutline}"
                                    Width="18" Height="18"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding !HasThumbnailPreview}" />
                                <Image asyncImage:ImageLoader.Source="{Binding ThumbnailPreviewUrl}"
                                    Stretch="UniformToFill"
                                    Width="36" Height="36"
                                    IsVisible="{Binding IsPreviewHttp}" />
                                <Image Source="{Binding LocalPreviewBitmap}"
                                    Stretch="UniformToFill"
                                    Width="36" Height="36"
                                    IsVisible="{Binding IsPreviewLocal}" />
                            </Panel>
                        </Border>
                    </Grid>

                    <!-- ═══ Из треков ═══ -->
                    <Border IsVisible="{Binding IsCoverModeFromTracks}"
                        MaxHeight="220">
                        <controls:PlaylistCoverPicker DataContext="{Binding CoverPicker}" />
                    </Border>

                    <!-- ═══ Файл ═══ -->
                    <StackPanel IsVisible="{Binding IsCoverModeFile}" Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0"
                                Text="{Binding SelectedFilePath, Mode=OneWay}"
                                IsReadOnly="True"
                                Watermark="{Binding L[CoverPicker_FileHint]}"
                                FontSize="12" />
                            <!-- Кнопка выбора файла -->
                            <Button Grid.Column="1"
                                Command="{Binding SelectFileCommand}"
                                Padding="8,6"
                                Margin="8,0,0,0"
                                ToolTip.Tip="{Binding L[CoverPicker_BrowseFile]}">
                                <PathIcon Data="{StaticResource Icon.FolderOpen}" Width="18"
                                    Height="18" />
                            </Button>
                        </Grid>
                        <Border Width="80" Height="80"
                            CornerRadius="6" ClipToBounds="True"
                            Background="{DynamicResource BgSkeletonBrush}"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding IsPreviewLocal}">
                            <Image Source="{Binding LocalPreviewBitmap}"
                                Stretch="UniformToFill"
                                Width="80" Height="80" />
                        </Border>
                    </StackPanel>

                    <!-- Кнопка загрузки обложки в YouTube -->
                    <Button Command="{Binding UploadThumbnailCommand}"
                        IsVisible="{Binding ShowUploadThumbnailButton}"
                        Padding="8,6"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Panel>
                                <PathIcon Data="{StaticResource Icon.CloudUpload}"
                                    Width="14" Height="14"
                                    IsVisible="{Binding !IsRecalculatingColor}" />
                                <PathIcon Data="{StaticResource Icon.Sync}"
                                    Width="14" Height="14"
                                    IsVisible="{Binding IsRecalculatingColor}"
                                    Classes="spinning" />
                            </Panel>
                            <TextBlock Text="{Binding L[EditPlaylist_UploadThumbnail]}"
                                FontSize="12" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ═══ Custom Color ═══ -->
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding L[EditPlaylist_Color]}"
                FontSize="13" FontWeight="SemiBold"
                Foreground="{DynamicResource TextSecondaryBrush}" />
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0"
                    Text="{Binding CustomColor, Mode=TwoWay}"
                    Watermark="#FF6B35"
                    FontSize="12" />
                <Border Grid.Column="1"
                    Width="32" Height="32"
                    CornerRadius="6"
                    Margin="8,0,0,0"
                    BorderBrush="{DynamicResource BgHighlightBrush}"
                    BorderThickness="1"
                    Background="{Binding ColorPreviewBrush}" />
            </Grid>
            <TextBlock Text="{Binding L[EditPlaylist_ColorHint]}"
                FontSize="11"
                Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- ═══ Computed Color (readonly + кнопка пересчёта) ═══ -->
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding L[EditPlaylist_ComputedColor]}"
                FontSize="13" FontWeight="SemiBold"
                Foreground="{DynamicResource TextSecondaryBrush}" />
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBox Grid.Column="0"
                    Text="{Binding ComputedColor, Mode=OneWay}"
                    IsReadOnly="True"
                    Watermark="{Binding L[EditPlaylist_ComputedColorNone]}"
                    FontSize="12"
                    Foreground="{DynamicResource TextMutedBrush}" />
                <Border Grid.Column="1"
                    Width="32" Height="32"
                    CornerRadius="6"
                    Margin="8,0,0,0"
                    BorderBrush="{DynamicResource BgHighlightBrush}"
                    BorderThickness="1"
                    Background="{Binding ComputedColorPreviewBrush}" />
                <!-- Кнопка пересчёта цвета -->
                <Button Grid.Column="2"
                    Command="{Binding RecalculateColorCommand}"
                    Padding="6"
                    Margin="4,0,0,0"
                    ToolTip.Tip="{Binding L[EditPlaylist_RecalculateColor]}">
                    <Panel>
                        <PathIcon Data="{StaticResource Icon.Refresh}"
                            Width="18" Height="18"
                            IsVisible="{Binding !IsRecalculatingColor}" />
                        <PathIcon Data="{StaticResource Icon.Sync}"
                            Width="18" Height="18"
                            IsVisible="{Binding IsRecalculatingColor}"
                            Classes="spinning" />
                    </Panel>
                </Button>
            </Grid>
            <TextBlock Text="{Binding L[EditPlaylist_ComputedColorHint]}"
                FontSize="11"
                Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- ═══ YouTube Sync Section ═══ -->
        <Border Background="{DynamicResource BgElevatedBrush}"
            CornerRadius="8" Padding="14,12"
            IsVisible="{Binding ShowSyncSection}">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <!-- YouTube Sync: иконка CloudSync -->
                    <PathIcon Grid.Column="0"
                        Data="{StaticResource Icon.CloudSync}"
                        Width="20" Height="20"
                        Foreground="{DynamicResource AccentBrush}"
                        VerticalAlignment="Center" Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding L[EditPlaylist_Sync]}"
                            FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L[EditPlaylist_SyncDesc]}"
                            FontSize="11"
                            Foreground="{DynamicResource TextMutedBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="2"
                        IsChecked="{Binding IsSyncedToCloud, Mode=TwoWay}"
                        IsEnabled="{Binding IsAuthenticated}"
                        VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>

                <Border Padding="10,6" CornerRadius="4"
                    IsVisible="{Binding HasYoutubeBinding}">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.1" />
                    </Border.Background>
                    <!-- Sync active badge -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource Icon.CheckCircleOutline}"
                            Width="14" Height="14"
                            Foreground="{DynamicResource AccentBrush}"
                            VerticalAlignment="Center" />
                        <TextBlock Text="{Binding L[EditPlaylist_SyncActive]}" FontSize="11"
                            Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Padding="10,6" CornerRadius="4"
                    IsVisible="{Binding !IsAuthenticated}">
                    <Border.Background>
                        <SolidColorBrush Color="Orange" Opacity="0.1" />
                    </Border.Background>
                    <!-- Login required warning -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource Icon.AlertOutline}"
                            Width="14" Height="14"
                            Foreground="Orange" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding L[EditPlaylist_LoginRequired]}" FontSize="11"
                            Foreground="Orange" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Create Copy кнопка -->
        <Button Command="{Binding CreateCopyCommand}"
            IsVisible="{Binding IsForEdit}"
            HorizontalAlignment="Left"
            Padding="10,6"
            Margin="0,4,0,0"
            Classes="ghost-btn">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource Icon.ContentCopy}" Width="14" Height="14" />
                <TextBlock Text="{Binding L[EditPlaylist_CreateCopy]}" FontSize="12" />
            </StackPanel>
        </Button>

        <!-- ═══ Validation Error / Success Message ═══ -->
        <TextBlock Text="{Binding ErrorMessage}"
            Foreground="{DynamicResource SystemError}"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            FontSize="13" FontWeight="SemiBold"
            TextWrapping="Wrap" Margin="0,4,0,0" />
    </StackPanel>
</UserControl>