<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:svm="using:LMP.Features.Shared"
    xmlns:h="using:LMP.Core.Helpers"
    x:Class="LMP.UI.Controls.TrackListControl"
    x:Name="Root"
    x:CompileBindings="True">

    <UserControl.Resources>
        <MenuFlyout x:Key="SharedTrackMenuFlyout"
            x:DataType="svm:TrackItemViewModel"
            Opened="OnMenuFlyoutOpened"
            Closed="OnMenuFlyoutClosed">

            <MenuItem Header="{Binding L[Player_Play]}" Command="{Binding PlayCommand}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="Play" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding L[Queue_Add]}" Command="{Binding AddToQueueCommand}"
                IsVisible="{Binding ShowAddToQueue}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="PlaylistPlus" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding L[AddToPlaylist_Title]}"
                Command="{Binding AddToPlaylistCommand}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="PlaylistPlus" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator Classes="menu-separator" />
            <MenuItem Header="{Binding L[Track_StartRadio]}" Command="{Binding StartRadioCommand}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="RadioTower" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding L[Track_CopyLink]}" Command="{Binding CopyLinkCommand}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="LinkVariant" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding DownloadStatusText}"
                Command="{Binding SaveToDownloadsCommand}"
                IsEnabled="{Binding !Track.IsDownloaded}">
                <MenuItem.Icon>
                    <mi:MaterialIcon
                        Kind="{Binding Track.IsDownloaded,
                        Converter={StaticResource BoolToIconConverter},
                        ConverterParameter='Check|Download'}" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator Classes="menu-separator" IsVisible="{Binding IsPlaylistContext}" />
            <MenuItem Header="{Binding L[Playlist_RemoveFrom]}" Classes="danger"
                Command="{Binding RemoveFromPlaylistCommand}"
                IsVisible="{Binding IsPlaylistContext}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="PlaylistRemove" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator Classes="menu-separator" IsVisible="{Binding IsQueueContext}" />
            <MenuItem Header="{Binding L[Queue_Remove]}" Classes="danger"
                Command="{Binding RemoveFromQueueCommand}"
                IsVisible="{Binding IsQueueContext}">
                <MenuItem.Icon>
                    <mi:MaterialIcon Kind="Close" />
                </MenuItem.Icon>
            </MenuItem>
        </MenuFlyout>
    </UserControl.Resources>

    <!--
        ScrollViewer НЕ здесь — он ВСЕГДА в родительском View.
        ItemsRepeater находит ScrollViewer-предка через visual tree →
        получает реальный viewport → виртуализация работает (~15 элементов).
    -->
    <Panel>
        <StackPanel IsVisible="{Binding !IsLoading, ElementName=Root}">

            <!-- ═══ ITEMS REPEATER ═══ -->
            <ItemsRepeater x:Name="MainRepeater"
                ItemsSource="{Binding Items, ElementName=Root}"
                DragDrop.AllowDrop="{Binding EnableReordering, ElementName=Root}"
                DragDrop.DragOver="OnDragOver"
                DragDrop.Drop="OnDrop"
                DragDrop.DragLeave="OnDragLeave">

                <ItemsRepeater.Layout>
                    <StackLayout Spacing="0" />
                </ItemsRepeater.Layout>

                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="svm:TrackItemViewModel">
                        <Border Classes="track-row"
                            Classes.is-active="{Binding IsActive}"
                            Classes.menu-open="{Binding IsMenuOpen}"
                            Height="60"
                            UseLayoutRounding="True"
                            PointerPressed="OnItemPointerPressed"
                            PointerMoved="OnItemPointerMoved"
                            PointerReleased="OnItemPointerReleased">

                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, 60"
                                Background="Transparent">

                                <!-- КОЛОНКА 0: Обложка -->
                                <Button Grid.Column="0" Classes="cover-btn"
                                    Command="{Binding PlayCommand}"
                                    Width="44" Height="44" Margin="0,0,12,0"
                                    ToolTip.Tip="{Binding L[Player_Play]}">
                                    <Panel>
                                        <Border CornerRadius="6" ClipToBounds="True"
                                            Background="{DynamicResource BgSkeletonBrush}">
                                            <Image Stretch="UniformToFill" Width="44" Height="44"
                                                RenderOptions.BitmapInterpolationMode="LowQuality"
                                                h:DebouncedImage.Source="{Binding ThumbnailUrl}" />
                                        </Border>
                                        <Panel Classes="cover-overlay" IsHitTestVisible="False">
                                            <Border CornerRadius="6"
                                                Background="{DynamicResource BgOverlayBrush}" />
                                            <mi:MaterialIcon
                                                Kind="{Binding IsPlaying,
                                                Converter={StaticResource BoolToIconConverter},
                                                ConverterParameter='Pause|Play'}"
                                                Classes="play-icon" Width="24" Height="24"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Panel>
                                        <Border IsVisible="{Binding IsPlaying}"
                                            Width="12" Height="12" CornerRadius="6"
                                            Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Margin="0,0,2,2" IsHitTestVisible="False">
                                            <mi:MaterialIcon Kind="VolumeHigh" Width="8" Height="8"
                                                Foreground="{DynamicResource TextDarkBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                    </Panel>
                                </Button>

                                <!-- КОЛОНКА 1: Информация -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="2" IsHitTestVisible="False">
                                    <TextBlock Text="{Binding Title}" Classes="track-title"
                                        TextTrimming="CharacterEllipsis" MaxLines="1"
                                        FontSize="14" />
                                    <TextBlock Text="{Binding Author}"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        TextTrimming="CharacterEllipsis" MaxLines="1"
                                        FontSize="12" />
                                </StackPanel>

                                <!-- КОЛОНКА 2: Статус -->
                                <Panel Grid.Column="2" VerticalAlignment="Center"
                                    Margin="8,0" IsHitTestVisible="False">
                                    <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                                        Foreground="{DynamicResource AccentBrush}"
                                        IsVisible="{Binding Track.IsDownloaded}"
                                        ToolTip.Tip="{Binding L[Track_Downloaded]}" />
                                    <mi:MaterialIcon Kind="CloudCheck" Width="16" Height="16"
                                        Foreground="{DynamicResource AccentBrush}"
                                        ToolTip.Tip="{Binding L[Track_Cached]}">
                                        <mi:MaterialIcon.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="Track.IsCached" />
                                                <Binding Path="!Track.IsDownloaded" />
                                            </MultiBinding>
                                        </mi:MaterialIcon.IsVisible>
                                    </mi:MaterialIcon>
                                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="1"
                                        Width="32" Height="3" IsVisible="{Binding IsDownloading}"
                                        Foreground="{DynamicResource AccentBrush}" />
                                </Panel>

                                <!-- КОЛОНКА 3: Лайк -->
                                <Button Grid.Column="3" Classes="icon-btn like-btn"
                                    Classes.is-liked="{Binding Track.IsLiked}"
                                    Command="{Binding ToggleLikeCommand}"
                                    ToolTip.Tip="{Binding L[Track_ToggleLike]}">
                                    <mi:MaterialIcon
                                        Kind="{Binding Track.IsLiked,
                                        Converter={StaticResource BoolToIconConverter},
                                        ConverterParameter='Heart|HeartOutline'}"
                                        Width="16" Height="16" />
                                </Button>

                                <!-- КОЛОНКА 4: Длительность + Меню -->
                                <Panel Grid.Column="4">
                                    <TextBlock Text="{Binding FormattedDuration}"
                                        Classes="duration-text" VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        FontSize="12" Margin="0,0,8,0"
                                        IsHitTestVisible="False" />
                                    <Button Classes="icon-btn more-btn"
                                        HorizontalAlignment="Right" Width="32" Height="32"
                                        Click="OnMoreButtonClicked"
                                        ToolTip.Tip="{Binding L[Track_MoreOptions]}">
                                        <mi:MaterialIcon Kind="DotsHorizontal" Width="20"
                                            Height="20"
                                            Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Button>
                                </Panel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ═══ FOOTER ═══ -->
            <StackPanel Margin="0,8,0,16"
                DataContext="{Binding #Root}"
                IsHitTestVisible="False">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                        <Binding Path="IsLoadingMore" />
                        <Binding Path="IsFooterVisible" />
                    </MultiBinding>
                </StackPanel.IsVisible>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,16,0,24" Opacity="0.6"
                    IsVisible="{Binding IsFetchingFromNetwork}">
                    <TextBlock Text="{Binding LoadingMoreText}" FontSize="13"
                        Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot1" Margin="2,0,0,0" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot2" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot3" />
                </StackPanel>

                <Border IsVisible="{Binding IsFooterVisible}"
                    Margin="0,16,0,32" HorizontalAlignment="Center" Opacity="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding EndOfListText}"
                            Foreground="{DynamicResource TextMutedBrush}" FontSize="13" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Panel>
</UserControl>