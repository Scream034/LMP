<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Core.Behaviors"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Home"
    xmlns:svm="using:MyLiteMusicPlayer.Features.Shared"
    x:Class="MyLiteMusicPlayer.UI.Controls.TrackListControl"
    x:Name="Root"
    x:CompileBindings="True">

    <UserControl.Styles>
        <!-- Стили для строки трека -->
        <Style Selector="Border.track-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.track-row:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
        <Style Selector="Border.track-row.isActive">
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
        </Style>
        <Style Selector="Border.track-row.isActive:pointerover">
            <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
        </Style>
        
        <!-- Анимация точек -->
        <Style Selector="TextBlock.dot1">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="TextBlock.dot2">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.2">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="TextBlock.dot3">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.4">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- 1. НАЧАЛЬНАЯ ЗАГРУЗКА -->
        <Panel IsVisible="{Binding IsLoading, ElementName=Root}" ZIndex="10">
            <Panel IsVisible="{Binding EnableSmoothLoading, ElementName=Root}">
                <ContentControl Classes="loading-initial"
                    IsVisible="{Binding !UseSearchLoader, ElementName=Root}" />
                
                <!-- Поиск: скелетоны + лупа -->
                <Grid HorizontalAlignment="Stretch" Margin="0,20"
                      IsVisible="{Binding UseSearchLoader, ElementName=Root}">
                    
                    <StackPanel Classes="breathing skeleton-list-container">
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>

                    <Canvas IsHitTestVisible="False" HorizontalAlignment="Center" 
                            Width="300" Height="200">
                        <mi:MaterialIcon Kind="Magnify" Width="32" Height="32"
                            Classes="scanner-smooth" />
                    </Canvas>

                    <!-- Локализованный текст через свойство контрола -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Bottom" Margin="0,280,0,0">
                        <TextBlock Text="{Binding SearchingText, ElementName=Root}" 
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" Opacity="0.8" />
                    </StackPanel>
                </Grid>
            </Panel>

            <ProgressBar IsIndeterminate="True"
                Width="150"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource AccentBrush}"
                IsVisible="{Binding !EnableSmoothLoading, ElementName=Root}" />
        </Panel>

        <!-- 2. КОНТЕНТ -->
        <Grid RowDefinitions="*, Auto" IsVisible="{Binding !IsLoading, ElementName=Root}">

            <ListBox x:Name="MainListBox"
                Grid.Row="0"
                ItemsSource="{Binding Items, ElementName=Root}"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="{Binding ScrollVisibility, ElementName=Root}">

                <i:Interaction.Behaviors>
                    <b:InfiniteScrollBehavior
                        Command="{Binding LoadMoreCommand, ElementName=Root}"
                        IsEnabled="{Binding UseInternalScroll, ElementName=Root}"
                        Threshold="300" />
                </i:Interaction.Behaviors>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Name="PART_ContentPresenter"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Content="{TemplateBinding Content}"
                                    Padding="{TemplateBinding Padding}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </ControlTemplate>
                        </Setter>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="svm:TrackItemViewModel">
                        <Border Classes="track-row" Classes.isActive="{Binding IsActive}">
                            <ContentControl Content="{Binding}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 3. ФУТЕР -->
            <StackPanel Grid.Row="1" Margin="0,8,0,16">
                
                <!-- Загрузка из сети -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,16,0,24"
                            Opacity="0.6"
                            IsVisible="{Binding IsFetchingFromNetwork, ElementName=Root}">
                    
                    <TextBlock Text="{Binding LoadingMoreText, ElementName=Root}"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}" 
                               Classes="dot1" Margin="2,0,0,0" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}" 
                               Classes="dot2" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}" 
                               Classes="dot3" />
                </StackPanel>

                <!-- Локальная подгрузка -->
                <ContentControl Classes="loading-skeletons">
                    <ContentControl.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsLoadingMore" ElementName="Root" />
                            <Binding Path="!IsFetchingFromNetwork" ElementName="Root" />
                        </MultiBinding>
                    </ContentControl.IsVisible>
                </ContentControl>

                <!-- Конец списка -->
                <Border IsVisible="{Binding ReachedEnd, ElementName=Root}"
                        Margin="0,16,0,32"
                        HorizontalAlignment="Center"
                        Opacity="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                                         Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding EndOfListText, ElementName=Root}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="13" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
