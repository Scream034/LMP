<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:b="using:LMP.Core.Behaviors"
    xmlns:svm="using:LMP.Features.Shared"
    xmlns:asyncImage="using:AsyncImageLoader"
    x:Class="LMP.UI.Controls.TrackListControl"
    x:Name="Root"
    x:CompileBindings="True">

    <Grid>

        <!-- 1. СОСТОЯНИЕ ЗАГРУЗКИ -->
        <Panel IsVisible="{Binding IsLoading, ElementName=Root}" ZIndex="10">

            <!-- Плавная загрузка со скелетонами -->
            <Panel IsVisible="{Binding EnableSmoothLoading, ElementName=Root}">

                <!-- Обычный лоадер -->
                <ContentControl Classes="loading-initial"
                    IsVisible="{Binding !UseSearchLoader, ElementName=Root}" />

                <!-- Лоадер для поиска (с лупой) -->
                <Grid HorizontalAlignment="Stretch" Margin="0,20"
                    IsVisible="{Binding UseSearchLoader, ElementName=Root}">

                    <StackPanel Classes="breathing skeleton-list-container">
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>

                    <Canvas IsHitTestVisible="False" HorizontalAlignment="Center"
                        Width="300" Height="200">
                        <mi:MaterialIcon Kind="Magnify" Width="32" Height="32"
                            Classes="scanner-smooth" />
                    </Canvas>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Bottom" Margin="0,280,0,0">
                        <TextBlock Text="{Binding SearchingText, ElementName=Root}"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentBrush}" Opacity="0.8" />
                    </StackPanel>
                </Grid>
            </Panel>

            <!-- Простой индикатор загрузки -->
            <ProgressBar IsIndeterminate="True"
                Width="150"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource AccentBrush}"
                IsVisible="{Binding !EnableSmoothLoading, ElementName=Root}" />
        </Panel>

        <!-- 2. ОСНОВНОЙ КОНТЕНТ -->
        <Grid RowDefinitions="*, Auto" IsVisible="{Binding !IsLoading, ElementName=Root}">

            <ListBox x:Name="MainListBox"
                Classes="track-list"
                Grid.Row="0"
                ItemsSource="{Binding Items, ElementName=Root}"
                Background="Transparent"
                SelectionMode="Single"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="{Binding ScrollVisibility, ElementName=Root}">

                <i:Interaction.Behaviors>
                    <b:InfiniteScrollBehavior
                        Command="{Binding LoadMoreCommand, ElementName=Root}"
                        IsEnabled="{Binding UseInternalScroll, ElementName=Root}"
                        Threshold="300" />
                </i:Interaction.Behaviors>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="svm:TrackItemViewModel">
                        <Border Classes="track-row"
                            Classes.is-active="{Binding IsActive}"
                            Classes.menu-open="{Binding IsMenuOpen}"
                            PointerReleased="OnTrackRowPointerReleased">

                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, 60"
                                Background="Transparent">

                                <!-- КОЛОНКА 0: Обложка (кликабельная) -->
                                <Button Grid.Column="0"
                                    Classes="cover-btn"
                                    Command="{Binding PlayCommand}"
                                    Width="44" Height="44"
                                    Margin="0,0,12,0">
                                    <Panel>
                                        <!-- Обложка -->
                                        <Border CornerRadius="6" ClipToBounds="True"
                                            Background="{DynamicResource BgSkeletonBrush}">
                                            <Image
                                                asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                                Stretch="UniformToFill"
                                                Width="44" Height="44" />
                                        </Border>

                                        <!-- Оверлей (появляется при наведении ИЛИ когда активен) -->
                                        <Panel Classes="cover-overlay">
                                            <Panel.IsVisible>
                                                <MultiBinding
                                                    Converter="{x:Static BoolConverters.Or}">
                                                    <Binding Path="IsActive" />
                                                    <Binding Path="$parent[Button].IsPointerOver" />
                                                </MultiBinding>
                                            </Panel.IsVisible>

                                            <Border CornerRadius="6" Background="#99000000" />

                                            <!-- Play (когда НЕ играет) -->
                                            <mi:MaterialIcon Kind="Play"
                                                Classes="play-icon"
                                                Width="24" Height="24"
                                                Foreground="White"
                                                IsVisible="{Binding !IsPlaying}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />

                                            <!-- Pause (когда играет) -->
                                            <mi:MaterialIcon Kind="Pause"
                                                Classes="play-icon"
                                                Width="24" Height="24"
                                                Foreground="White"
                                                IsVisible="{Binding IsPlaying}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Panel>

                                        <!-- Индикатор "сейчас играет" (маленький, в углу) -->
                                        <Border IsVisible="{Binding IsPlaying}"
                                            Width="12" Height="12"
                                            CornerRadius="6"
                                            Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,2,2">
                                            <mi:MaterialIcon Kind="VolumeHigh"
                                                Width="8" Height="8"
                                                Foreground="White"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                    </Panel>
                                </Button>

                                <!-- КОЛОНКА 1: Информация о треке -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding Title}"
                                        Classes="track-title"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1"
                                        FontSize="14" />

                                    <TextBlock Text="{Binding Author}"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1"
                                        FontSize="12" />
                                </StackPanel>

                                <!-- КОЛОНКА 2: Статус скачивания -->
                                <Panel Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                    <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                                        Foreground="{DynamicResource AccentBrush}"
                                        IsVisible="{Binding IsDownloaded}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="1"
                                        Width="32" Height="3"
                                        IsVisible="{Binding IsDownloading}"
                                        Foreground="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Panel>

                                <!-- КОЛОНКА 3: Кнопка "Лайк" -->
                                <Button Grid.Column="3"
                                    Classes="icon-btn like-btn"
                                    Classes.is-liked="{Binding IsLiked}"
                                    Command="{Binding ToggleLikeCommand}"
                                    Width="32" Height="32"
                                    Margin="4,0">
                                    <mi:MaterialIcon
                                        Kind="{Binding IsLiked, Converter={StaticResource BoolToIconConverter}, ConverterParameter='Heart|HeartOutline'}"
                                        Width="16" Height="16" />
                                </Button>

                                <!-- КОЛОНКА 4: Длительность / Действия -->
                                <Panel Grid.Column="4">

                                    <!-- РЕЖИМ: Обычный (не очередь) -->
                                    <Panel IsVisible="{Binding !#Root.IsQueueContext}">

                                        <TextBlock Text="{Binding FormattedDuration}"
                                            Classes="duration-text"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            FontSize="12"
                                            Margin="0,0,8,0" />

                                        <Button x:Name="MoreMenuButton"
                                            Classes="icon-btn more-btn"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            Width="32" Height="32"
                                            ToolTip.Tip="More options">
                                            <mi:MaterialIcon Kind="DotsHorizontal" Width="20"
                                                Height="20"
                                                Foreground="{DynamicResource TextPrimaryBrush}" />

                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight"
                                                    Opened="OnMenuFlyoutOpened"
                                                    Closed="OnMenuFlyoutClosed">

                                                    <MenuItem Header="{Binding L[Player_Play]}"
                                                        Command="{Binding PlayCommand}">
                                                        <MenuItem.Icon>
                                                            <mi:MaterialIcon Kind="Play" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                    <MenuItem Header="{Binding L[Queue_Add]}"
                                                        Command="{Binding AddToQueueCommand}">
                                                        <MenuItem.Icon>
                                                            <mi:MaterialIcon Kind="PlaylistPlus" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                    <Separator Classes="menu-separator" />

                                                    <MenuItem Header="{Binding L[Track_StartRadio]}"
                                                        Command="{Binding StartRadioCommand}">
                                                        <MenuItem.Icon>
                                                            <mi:MaterialIcon Kind="RadioTower" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                    <MenuItem Header="{Binding DownloadStatusText}"
                                                        Command="{Binding DownloadTrackCommand}"
                                                        IsEnabled="{Binding !IsDownloaded}">
                                                        <MenuItem.Icon>
                                                            <mi:MaterialIcon
                                                                Kind="{Binding IsDownloaded, Converter={StaticResource BoolToIconConverter}, ConverterParameter='Check|Download'}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                    <Separator Classes="menu-separator"
                                                        IsVisible="{Binding IsPlaylistContext}" />

                                                    <MenuItem
                                                        Header="{Binding L[Playlist_RemoveFrom]}"
                                                        Classes="danger"
                                                        Command="{Binding RemoveFromPlaylistCommand}"
                                                        IsVisible="{Binding IsPlaylistContext}">
                                                        <MenuItem.Icon>
                                                            <mi:MaterialIcon Kind="PlaylistRemove" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Panel>

                                    <!-- РЕЖИМ: Очередь -->
                                    <Panel IsVisible="{Binding #Root.IsQueueContext}">

                                        <TextBlock Text="{Binding FormattedDuration}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            FontSize="12" />

                                        <Button Classes="icon-btn remove-btn"
                                            HorizontalAlignment="Right"
                                            Width="28" Height="28"
                                            Command="{Binding RemoveFromQueueCommand}"
                                            ToolTip.Tip="Remove from queue">
                                            <mi:MaterialIcon Kind="Close" Width="16" Height="16"
                                                Foreground="{DynamicResource TextMutedBrush}" />
                                        </Button>
                                    </Panel>

                                </Panel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 3. ФУТЕР -->
            <StackPanel Grid.Row="1" Margin="0,8,0,16">

                <!-- Индикатор сетевой загрузки -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,24"
                    Opacity="0.6"
                    IsVisible="{Binding IsFetchingFromNetwork, ElementName=Root}">
                    <TextBlock Text="{Binding LoadingMoreText, ElementName=Root}"
                        FontSize="13"
                        Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot1" Margin="2,0,0,0" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot2" />
                    <TextBlock Text="." FontSize="13" Foreground="{DynamicResource AccentBrush}"
                        Classes="loading-dot3" />
                </StackPanel>

                <!-- Скелетоны загрузки -->
                <ContentControl Classes="loading-skeletons">
                    <ContentControl.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsLoadingMore" ElementName="Root" />
                            <Binding Path="!IsFetchingFromNetwork" ElementName="Root" />
                        </MultiBinding>
                    </ContentControl.IsVisible>
                </ContentControl>

                <!-- Индикатор конца списка -->
                <Border IsVisible="{Binding ReachedEnd, ElementName=Root}"
                    Margin="0,16,0,32"
                    HorizontalAlignment="Center"
                    Opacity="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding EndOfListText, ElementName=Root}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            FontSize="13" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>