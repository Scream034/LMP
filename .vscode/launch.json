{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🎵 Launch MyLiteMusicPlayer (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net10.0/MyLiteMusicPlayer.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole",
            "logging": {
                "moduleLoad": false
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_MODERN_CONTROLS": "1"
            }
        }
    ]
}