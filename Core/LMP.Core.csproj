<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      net11.0 — preview (GA ожидается ноябрь 2026).
      Осознанный выбор: синхронизировано с корневым проектом.
    -->
    <TargetFramework>net11.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>LMP.Core</AssemblyName>
    <RootNamespace>LMP.Core</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Label="Package Versions">
    <EfCoreVersion>10.0.2</EfCoreVersion>
    <MsExtVersion>10.0.2</MsExtVersion>
    <ReactiveUISourceGenVersion>2.6.30</ReactiveUISourceGenVersion>
    <CommunityToolkitMvvmVersion>8.4.2</CommunityToolkitMvvmVersion>
    <AvaloniaVersion>12.0.4</AvaloniaVersion>
    <AsyncImageLoaderVersion>3.8.0</AsyncImageLoaderVersion>
    <SkiaSharpVersion>3.119.4</SkiaSharpVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <!--
      Синхронизировано с LMP.csproj: SettingsRepository<T> и LocalizationService
      используют reflection-based JSON, который отключается при PublishTrimmed.
    -->
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
  </PropertyGroup>

  <ItemGroup Label="UI Core Dependencies">
    <PackageReference Include="Avalonia" Version="$(AvaloniaVersion)" />
    <PackageReference Include="AsyncImageLoader.Avalonia" Version="$(AsyncImageLoaderVersion)" />
    <PackageReference Include="SkiaSharp" Version="$(SkiaSharpVersion)" />
  </ItemGroup>

  <ItemGroup Label="Entity Framework">
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="$(EfCoreVersion)" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="$(EfCoreVersion)" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="$(EfCoreVersion)">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!-- Переопределение транзитивной зависимости для устранения уязвимости GHSA-2m69-gcr7-jv3q
    (SQLitePCLRaw.lib.e_sqlite3) -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
  </ItemGroup>

  <ItemGroup Label="MVVM">
    <PackageReference Include="ReactiveUI" Version="23.2.28" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="$(CommunityToolkitMvvmVersion)" />
    <!--
      ReactiveUI.SourceGenerators 2.6.30 — compile-time замена ReactiveUI.Fody.
      PrivateAssets="all": генератор не попадает в transitive-зависимости потребителей.
    -->
    <PackageReference Include="ReactiveUI.SourceGenerators" Version="$(ReactiveUISourceGenVersion)">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Label="Microsoft Extensions">
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="$(MsExtVersion)" />
  </ItemGroup>

  <ItemGroup Label="Audio">
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="Concentus" Version="2.2.2" />
  </ItemGroup>

  <ItemGroup Label="Scripting">
    <PackageReference Include="Acornima" Version="1.6.2" />
  </ItemGroup>

  <ItemGroup Label="Diagnostics">
    <PackageReference Include="Microsoft.Diagnostics.NETCore.Client" Version="0.2.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Синхронизировано до $(EfCoreVersion) для работы с базами SQLite браузеров -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="$(EfCoreVersion)" />
    <!--
      Обновлено с 8.0.0 → 9.0.0: алигн с TFM net11.0 / net10-compatible runtime.
      На Windows DPAPI доступен inbox, пакет нужен только для явной ссылки на тип.
    -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SharpJaad.AAC\SharpJaad.AAC.csproj" />
  </ItemGroup>

</Project>