<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="MyLiteMusicPlayer.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <DockPanel>
        <!-- Верхняя панель (Header) -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding L[Library_Title]}" FontSize="32" FontWeight="Bold"/>
                
                <Button Command="{Binding OpenCreateCommand}" 
                        Content="{Binding L[Library_NewPlaylist]}"
                        Classes="accent"
                        IsVisible="{Binding !IsCreatingPlaylist}"
                        VerticalAlignment="Center"/>
                        
                <Button Command="{Binding SyncAccountPlaylistsCommand}" 
                        Content="{Binding L[Library_SyncYoutube]}"
                        IsEnabled="{Binding !IsLoading}"
                        VerticalAlignment="Center"/>
                
                <mi:MaterialIcon Kind="Loading" Classes="spinning" 
                                 IsVisible="{Binding IsLoading}"
                                 Width="24" Height="24" 
                                 Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Панель создания плейлиста -->
        <Border DockPanel.Dock="Top" 
                IsVisible="{Binding IsCreatingPlaylist}"
                Background="{StaticResource BgElevatedBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <mi:MaterialIcon Kind="PlaylistPlus" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBox Text="{Binding NewPlaylistName}" 
                         Watermark="{Binding L[Library_PlaylistNamePlaceholder]}" 
                         Width="300" VerticalAlignment="Center">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SavePlaylistCommand}"/>
                        <KeyBinding Gesture="Escape" Command="{Binding CancelCreateCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Command="{Binding SavePlaylistCommand}" Classes="icon-btn">
                    <mi:MaterialIcon Kind="Check" Foreground="{StaticResource AccentBrush}"/>
                </Button>
                <Button Command="{Binding CancelCreateCommand}" Classes="icon-btn">
                    <mi:MaterialIcon Kind="Close" Foreground="{StaticResource SystemErrorBrush}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Сетка плейлистов (ИСПРАВЛЕНО: ListBox + WrapPanel) -->
        <ScrollViewer>
            <ListBox ItemsSource="{Binding Playlists}" 
                     Background="Transparent" 
                     Padding="0">
                
                <!-- Задаем панель элементов как WrapPanel для сетки -->
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <!-- Стиль для элемента списка (убираем подсветку выделения) -->
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>

                <!-- Шаблон элемента -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}" Classes="playlist-card"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </DockPanel>
</UserControl>