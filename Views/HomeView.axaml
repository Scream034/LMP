<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="MyLiteMusicPlayer.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto, *">

        <!-- Верхняя часть: Приветствие и Категории -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding Greeting}"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,16" />

            <!-- Categories Selector (Таблетки) -->
            <ListBox ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}"
                     Background="Transparent"
                     Margin="0,0,0,8">
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="0" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <!-- Шаблон текста кнопки категории -->
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Стили для таблеток категорий -->
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="Margin" Value="0,0,10,0" />
                        <Setter Property="CornerRadius" Value="20" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>

                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource BgHighlightBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    </Style>

                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                    
                    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#DDDDDD" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </StackPanel>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MainScrollViewer"
                      ScrollChanged="OnScrollChanged">
            <StackPanel>
                <ProgressBar IsIndeterminate="True"
                             HorizontalAlignment="Center"
                             IsVisible="{Binding IsLoading}"
                             Height="4" Width="200"
                             Margin="0,0,0,20" />

                <!-- 
                   Список треков.
                   Мы НЕ задаем ItemTemplate, так как он определен глобально в App.axaml.
                   Avalonia сама найдет шаблон для TrackItemViewModel.
                -->
                <ListBox ItemsSource="{Binding ActiveTracks}" 
                         Background="Transparent"
                         SelectionMode="Single">
                    
                    <!-- Убираем отступы у элементов списка для плотного вида -->
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                         <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20"
                            IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Loading more..."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Panel Height="100" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>