<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.Views.HomeView"
    x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- 1. Header & Categories (Fixed at top) -->
        <StackPanel Grid.Row="0" Margin="24,16,24,16" Spacing="16">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Text="{Binding Greeting}"
                    FontSize="32" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Grid.Column="1"
                    Command="{Binding ToggleDebugCommand}"
                    Background="Transparent"
                    Padding="8"
                    ToolTip.Tip="Показать отладку">
                    <mi:MaterialIcon Kind="Bug" Width="20" Height="20"
                        Foreground="{Binding ShowDebugInfo, Converter={StaticResource BoolToSelector}, ConverterParameter='#1DB954|#666'}" />
                </Button>
            </Grid>

            <ListBox ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="CornerRadius" Value="20" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </StackPanel>

        <!-- 2. Debug Stats Panel (Optional) -->
        <Border Grid.Row="1"
            IsVisible="{Binding ShowDebugInfo}"
            Background="#1A1A1A"
            CornerRadius="8"
            Padding="16,12"
            Margin="24,0,24,16">
            <Grid ColumnDefinitions="*, *, *, *" RowDefinitions="Auto, Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TOTAL" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.TotalTracks}" FontSize="18" FontWeight="Bold"
                        Foreground="#1DB954" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DISPLAYED" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.DisplayedTracks}" FontSize="18"
                        FontWeight="Bold" Foreground="White" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CACHED" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.CachedTracks}" FontSize="18" FontWeight="Bold"
                        Foreground="#FFA500" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="LAST BATCH" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.LastBatchTimeMs, StringFormat='{}{0}ms'}"
                        FontSize="18" FontWeight="Bold" Foreground="#00BFFF" />
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Text="{Binding Stats.Source, StringFormat='Source: {0}'}" FontSize="11"
                    Foreground="#888" Margin="0,8,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                    Text="{Binding Stats.MemoryUsage}" FontSize="11" Foreground="#888"
                    Margin="0,8,0,0" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- 3. Main Virtualized List -->
        <!-- Убран внешний ScrollViewer. ListBox сам имеет встроенный ScrollViewer. -->
        <ListBox Grid.Row="2"
            ItemsSource="{Binding ActiveTracks}"
            Background="Transparent"
            SelectionMode="Single"
            Padding="24,0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- VirtualizingStackPanel обеспечивает переиспользование визуальных элементов -->
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>

            <!-- Footer Section (Button & Progress) -->
            <!-- Мы добавляем кнопку загрузки прямо в шаблон ListBox, чтобы она скроллилась вместе
            со списком -->
            <ListBox.Template>
                <ControlTemplate>
                    <DockPanel>
                        <!-- Заглушка, если идет первая загрузка -->
                        <StackPanel DockPanel.Dock="Top"
                            IsVisible="{Binding IsLoading}"
                            Margin="0,40" Spacing="16">
                            <ProgressBar IsIndeterminate="True"
                                Foreground="{StaticResource AccentBrush}" Height="4" Width="200" />
                            <TextBlock Text="Ищем музыку..." HorizontalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <ScrollViewer Name="PART_ScrollViewer"
                            Background="{TemplateBinding Background}"
                            HorizontalScrollBarVisibility="{TemplateBinding (ScrollViewer.HorizontalScrollBarVisibility)}"
                            VerticalScrollBarVisibility="{TemplateBinding (ScrollViewer.VerticalScrollBarVisibility)}">
                            <StackPanel>
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />

                                <!-- Load More Section (внутри скролла) -->
                                <StackPanel Margin="0,24,0,80" HorizontalAlignment="Center"
                                    IsVisible="{Binding HasMoreItems}">

                                    <Button Command="{Binding LoadMoreCommand}"
                                        Background="{StaticResource BgElevatedBrush}"
                                        CornerRadius="20" Padding="32,12">
                                        <Button.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="!IsLoading" />
                                                <Binding Path="!IsLoadingMore" />
                                                <Binding Path="!WaitingForMore" />
                                            </MultiBinding>
                                        </Button.IsVisible>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Загрузить еще" />
                                            <mi:MaterialIcon Kind="ChevronDown" Width="16"
                                                Height="16" IsVisible="{Binding !IsPrefetching}" />
                                            <mi:MaterialIcon Kind="CloudSync" Width="16" Height="16"
                                                Foreground="#1DB954"
                                                IsVisible="{Binding IsPrefetching}" />
                                        </StackPanel>
                                    </Button>

                                    <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding IsLoadingMore}">
                                        <ProgressBar IsIndeterminate="True" Width="20" Height="20"
                                            Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Добавляем треки..."
                                            Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>

                                    <StackPanel IsVisible="{Binding WaitingForMore}" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10"
                                            HorizontalAlignment="Center">
                                            <ProgressBar IsIndeterminate="True" Width="20"
                                                Height="20" Foreground="#FFA500" />
                                            <TextBlock Text="Получаем данные из YouTube..."
                                                Foreground="#FFA500" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </ControlTemplate>
            </ListBox.Template>
        </ListBox>
    </Grid>
</UserControl>