<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.Views.HomeView"
    x:DataType="vm:HomeViewModel">

    <UserControl.Styles>
        <!-- Анимация пульсации для Skeleton элементов -->
        <Style Selector="Border.skeleton">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.75">
                        <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- 1. Header & Categories -->
        <StackPanel Grid.Row="0" Margin="24,16,24,16" Spacing="16">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Text="{Binding Greeting}"
                    FontSize="32" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Grid.Column="1"
                    Command="{Binding ToggleDebugCommand}"
                    Background="Transparent" Padding="8">
                    <mi:MaterialIcon Kind="Bug" Width="20" Height="20"
                        Foreground="{Binding ShowDebugInfo, Converter={StaticResource BoolToSelector}, ConverterParameter='#1DB954|#666'}" />
                </Button>
            </Grid>

            <!-- Список категорий -->
            <ListBox ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="CornerRadius" Value="20" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </StackPanel>

        <!-- 2. Debug Stats Panel -->
        <Border Grid.Row="1" IsVisible="{Binding ShowDebugInfo}"
            Background="#1A1A1A" CornerRadius="8" Padding="16,12" Margin="24,0,24,16">
            <Grid ColumnDefinitions="*, *, *, *" RowDefinitions="Auto, Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TOTAL" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.TotalTracks}" FontSize="18" FontWeight="Bold"
                        Foreground="#1DB954" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DISPLAYED" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.DisplayedTracks}" FontSize="18"
                        FontWeight="Bold" Foreground="White" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CACHED" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.CachedTracks}" FontSize="18" FontWeight="Bold"
                        Foreground="#FFA500" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="MEMORY" FontSize="10" Foreground="#666" />
                    <TextBlock Text="{Binding Stats.MemoryUsage}" FontSize="14" FontWeight="Bold"
                        Foreground="#00BFFF" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. Основной список треков -->
        <ListBox Grid.Row="2"
            ItemsSource="{Binding ActiveTracks}"
            Background="Transparent"
            Padding="24,0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Template>
                <ControlTemplate>
                    <DockPanel>
                        <!-- Заглушка первой загрузки -->
                        <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsLoading}"
                            Margin="0,40" Spacing="16">
                            <ProgressBar IsIndeterminate="True"
                                Foreground="{StaticResource AccentBrush}" Height="4" Width="200" />
                            <TextBlock Text="Ищем горячие новинки..." HorizontalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <ScrollViewer Name="PART_ScrollViewer">
                            <StackPanel>
                                <ItemsPresenter Name="PART_ItemsPresenter" />

                                <!-- СЕКЦИЯ ЗАГРУЗКИ (SKELETONS) -->
                                <StackPanel Margin="0,10,0,80" Spacing="8">

                                    <!-- Кнопка "Загрузить еще" -->
                                    <Button Command="{Binding LoadMoreCommand}"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource BgElevatedBrush}"
                                        CornerRadius="20" Padding="32,12">
                                        <Button.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="!IsLoadingMore" />
                                                <Binding Path="!IsPrefetching" />
                                                <Binding Path="HasMoreItems" />
                                            </MultiBinding>
                                        </Button.IsVisible>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <mi:MaterialIcon Kind="ChevronDown" />
                                            <TextBlock Text="Показать больше" />
                                        </StackPanel>
                                    </Button>

                                    <!-- СКЕЛЕТЫ (Исправленный синтаксис Effect) -->
                                    <StackPanel Spacing="10" Margin="0,10">
                                        <StackPanel.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                <Binding Path="IsLoadingMore" />
                                                <Binding Path="IsPrefetching" />
                                            </MultiBinding>
                                        </StackPanel.IsVisible>

                                        <!-- Скелет 1 (Слабое размытие) -->
                                        <Grid ColumnDefinitions="50, *, 80" Margin="0,4">
                                            <Grid.Effect>
                                                <BlurEffect Radius="3" />
                                            </Grid.Effect>
                                            <Border Grid.Column="0" Width="48" Height="48"
                                                Background="#222" CornerRadius="4"
                                                Classes="skeleton" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="12,0">
                                                <Border Width="200" Height="14" Background="#222"
                                                    HorizontalAlignment="Left" CornerRadius="2"
                                                    Classes="skeleton" />
                                                <Border Width="120" Height="10" Background="#181818"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"
                                                    CornerRadius="2" Classes="skeleton" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Скелет 2 (Среднее размытие) -->
                                        <Grid ColumnDefinitions="50, *, 80" Margin="0,4">
                                            <Grid.Effect>
                                                <BlurEffect Radius="6" />
                                            </Grid.Effect>
                                            <Border Grid.Column="0" Width="48" Height="48"
                                                Background="#222" CornerRadius="4"
                                                Classes="skeleton" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="12,0">
                                                <Border Width="180" Height="14" Background="#222"
                                                    HorizontalAlignment="Left" CornerRadius="2"
                                                    Classes="skeleton" />
                                                <Border Width="100" Height="10" Background="#181818"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"
                                                    CornerRadius="2" Classes="skeleton" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Скелет 3 (Сильное размытие) -->
                                        <Grid ColumnDefinitions="50, *, 80" Margin="0,4">
                                            <Grid.Effect>
                                                <BlurEffect Radius="12" />
                                            </Grid.Effect>
                                            <Border Grid.Column="0" Width="48" Height="48"
                                                Background="#222" CornerRadius="4"
                                                Classes="skeleton" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="12,0">
                                                <Border Width="220" Height="14" Background="#222"
                                                    HorizontalAlignment="Left" CornerRadius="2"
                                                    Classes="skeleton" />
                                                <Border Width="140" Height="10" Background="#181818"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"
                                                    CornerRadius="2" Classes="skeleton" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock
                                            Text="Подгружаем новые треки из бездны интернета..."
                                            HorizontalAlignment="Center" FontSize="12"
                                            Foreground="#444" Margin="0,10" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </ControlTemplate>
            </ListBox.Template>
        </ListBox>
    </Grid>
</UserControl>