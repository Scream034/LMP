<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Behaviors"
    x:Class="MyLiteMusicPlayer.Views.HomeView"
    x:DataType="vm:HomeViewModel">

    <ScrollViewer>
        <i:Interaction.Behaviors>
            <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="200" />
        </i:Interaction.Behaviors>

        <StackPanel Margin="24,16">
            <!-- 1. Header & Categories -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                <TextBlock Text="{Binding Greeting}"
                    FontSize="32" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Grid.Column="1"
                    Command="{Binding ToggleDebugCommand}"
                    Background="Transparent" Padding="8">
                    <mi:MaterialIcon Kind="Bug" Width="20" Height="20"
                        Foreground="{Binding ShowDebugInfo, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextMutedBrush'}" />
                </Button>
            </Grid>

            <!-- Категории -->
            <ListBox ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent" Margin="0,0,0,16">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="CornerRadius" Value="20" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>

            <!-- 2. Debug Panel -->
            <Border IsVisible="{Binding ShowDebugInfo}"
                Background="{StaticResource BgSecondaryBrush}" CornerRadius="8" Padding="16,12"
                Margin="0,0,0,16">
                <Grid ColumnDefinitions="*, *, *, *">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding L[Home_Debug_Total]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.TotalTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding L[Home_Debug_Displayed]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.DisplayedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding L[Home_Debug_Cached]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.CachedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource SystemWarnOrangeBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="{Binding L[Home_Debug_Memory]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.MemoryUsage}" FontSize="14"
                            FontWeight="Bold" Foreground="{StaticResource SystemInfoBlueBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Начальная загрузка (с блюром) -->
            <ContentControl Classes="loading-initial" IsVisible="{Binding IsLoading}" />

            <!-- 4. Список треков -->
            <ItemsControl ItemsSource="{Binding ActiveTracks}" IsVisible="{Binding !IsLoading}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 5. Загрузка из сети (с блюром) -->
            <ContentControl Classes="loading-network" IsVisible="{Binding IsFetchingFromNetwork}" />

            <!-- 6. Скелеты подгрузки (с блюром) -->
            <ContentControl Classes="loading-skeletons" IsVisible="{Binding IsLoadingMore}" />

            <!-- 7. Достигли конца -->
            <Border IsVisible="{Binding ReachedEnd}" Margin="0,24,0,80"
                HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.5">
                    <mi:MaterialIcon Kind="CheckCircle" Width="20" Height="20"
                        Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding L[Home_EndOfList]}"
                        Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>