<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Behaviors"
    x:Class="MyLiteMusicPlayer.Views.HomeView"
    x:DataType="vm:HomeViewModel"
    x:CompileBindings="True">

    <Grid RowDefinitions="Auto, *">

        <!-- 1. HEADER (Greeting, Categories, Debug) -->
        <StackPanel Grid.Row="0" Margin="24,16,24,0">
            <!-- Greeting & Debug Button -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                <TextBlock Text="{Binding Greeting}"
                    FontSize="32" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    RenderOptions.TextRenderingMode="Antialias" />

                <Button Grid.Column="1"
                    Command="{Binding ToggleDebugCommand}"
                    Background="Transparent" Padding="8"
                    Cursor="Hand">
                    <mi:MaterialIcon Kind="Bug" Width="20" Height="20"
                        Foreground="{Binding ShowDebugInfo, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextMutedBrush'}" />
                </Button>
            </Grid>

            <!-- Debug Panel -->
            <Border IsVisible="{Binding ShowDebugInfo}"
                Background="{StaticResource BgSecondaryBrush}" CornerRadius="8" Padding="16,12"
                Margin="0,0,0,16">
                <Grid ColumnDefinitions="*, *, *, *">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding L[Home_Debug_Total]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.TotalTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding L[Home_Debug_Displayed]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.DisplayedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding L[Home_Debug_Cached]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.CachedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{StaticResource SystemWarnOrangeBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="{Binding L[Home_Debug_Memory]}" FontSize="10"
                            Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.MemoryUsage}" FontSize="14"
                            FontWeight="Bold" Foreground="{StaticResource SystemInfoBlueBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Categories -->
            <ListBox ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent" Margin="0,0,0,16"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="CornerRadius" Value="20" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Transitions">
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                            </Transitions>
                        </Setter>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </StackPanel>

        <!-- 2. MAIN CONTENT WRAPPER -->
        <!-- Using a ScrollViewer that wraps both ListBox and Loaders -->
        <ScrollViewer Grid.Row="1" Margin="24,0,24,0">
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>

            <StackPanel>
                <!-- Initial Loading Overlay -->
                <ContentControl Classes="loading-initial" 
                                IsVisible="{Binding IsLoading}" 
                                ZIndex="10" />

                <!-- The List of Tracks -->
                <!-- Note: Internal scroll is disabled so it expands fully, allowing the page scroller to work -->
                <ListBox ItemsSource="{Binding ActiveTracks}" 
                         IsVisible="{Binding !IsLoading}"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- BOTTOM LOADERS (Scrolls with content) -->
                <StackPanel Margin="0,0,0,20">
                    <!-- Network Loading Indicator -->
                    <ContentControl Classes="loading-network" IsVisible="{Binding IsFetchingFromNetwork}" />
                    
                    <!-- Skeletons for pagination -->
                    <ContentControl Classes="loading-skeletons" IsVisible="{Binding IsLoadingMore}" />

                    <!-- End of List -->
                    <Border IsVisible="{Binding ReachedEnd}" Margin="0,16,0,80" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.5">
                            <mi:MaterialIcon Kind="CheckCircle" Width="20" Height="20"
                                Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding L[Home_EndOfList]}"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>