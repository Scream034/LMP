<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:controls="using:MyLiteMusicPlayer.Views.Controls"
    x:Class="MyLiteMusicPlayer.Views.PlaylistView"
    x:DataType="vm:PlaylistViewModel"
    x:CompileBindings="True">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Row 0: HEADER (Fixed) -->
        <Border Grid.Row="0" Padding="24,24,24,16" BorderBrush="{StaticResource BgHighlightBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,24">
                    <!-- Playlist Cover -->
                    <Border Grid.Column="0" Width="190" Height="190" CornerRadius="8"
                        ClipToBounds="True" Background="{StaticResource BgSkeletonBrush}" BoxShadow="{StaticResource CardShadow}">
                        <Panel>
                            <mi:MaterialIcon Kind="MusicNote" Width="64" Height="64"
                                Foreground="{StaticResource TextMutedBrush}"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                            
                            <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl, Converter={StaticResource WebUrlConverter}}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='http'}" />
                            <Image Source="{Binding ThumbnailUrl, Converter={StaticResource BitmapAssetConverter}}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='avares'}" />
                        </Panel>
                    </Border>

                    <!-- Metadata -->
                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="PLAYLIST" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="{Binding PlaylistName}" FontSize="48" FontWeight="Black" Margin="0,4,0,12" TextWrapping="Wrap" MaxLines="2" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding FormattedTrackCount}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="•" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding FormattedDuration}" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <Button Classes="play-circle" Command="{Binding PlayAllCommand}" Width="56" Height="56">
                        <mi:MaterialIcon Kind="Play" Width="28" Height="28" Foreground="{StaticResource TextDarkBrush}" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding ShufflePlayCommand}" ToolTip.Tip="Shuffle">
                        <mi:MaterialIcon Kind="Shuffle" Width="24" Height="24" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding DownloadAllCommand}" ToolTip.Tip="Download All">
                        <mi:MaterialIcon Kind="Download" Width="24" Height="24" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding RefreshPlaylistCommand}" IsVisible="{Binding IsCloud}" ToolTip.Tip="Sync with YouTube">
                        <mi:MaterialIcon Kind="Sync" Width="24" Height="24" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Row 1: LIST (Internal Scroll) -->
        <controls:TrackListControl Grid.Row="1" Margin="24,0"
            Items="{Binding Items}"
            IsLoading="{Binding IsLoading}"
            IsLoadingMore="{Binding IsLoadingMore}"
            IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
            ReachedEnd="{Binding ReachedEnd}"
            LoadMoreCommand="{Binding LoadMoreCommand}"
            UseInternalScroll="True" />
    </Grid>
</UserControl>