<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:controls="using:MyLiteMusicPlayer.Views.Controls"
    x:Class="MyLiteMusicPlayer.Views.PlaylistView"
    x:DataType="vm:PlaylistViewModel"
    x:CompileBindings="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding HeaderHeight, Mode=TwoWay}" MinHeight="200"
                MaxHeight="340" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
            BorderBrush="{StaticResource BgHighlightBrush}"
            BorderThickness="0,0,0,1"
            Background="{StaticResource BgBaseBrush}"
            Padding="24,16">

            <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                HorizontalAlignment="Left" VerticalAlignment="Bottom">

                <Grid RowDefinitions="*, Auto" Width="800">

                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                        <!-- Playlist Cover -->
                        <Border Grid.Column="0" Width="190" Height="190" CornerRadius="8"
                            ClipToBounds="True" Background="{StaticResource BgSkeletonBrush}"
                            BoxShadow="{StaticResource CardShadow}">
                            <Panel>
                                <mi:MaterialIcon Kind="MusicNote" Width="64" Height="64"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />

                                <Image
                                    asyncImage:ImageLoader.Source="{Binding ThumbnailUrl, Converter={StaticResource WebUrlConverter}}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='http'}" />
                                <Image
                                    Source="{Binding ThumbnailUrl, Converter={StaticResource BitmapAssetConverter}}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='avares'}" />
                            </Panel>
                        </Border>

                        <!-- Metadata -->
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Bottom">
                            <TextBlock Text="PLAYLIST" FontSize="12" FontWeight="Bold"
                                Foreground="{StaticResource TextSecondaryBrush}" LetterSpacing="1" />

                            <!-- ИСПРАВЛЕНИЕ ОБРЕЗАНИЯ ТЕКСТА:
                                 1. LineHeight удален.
                                 2. Padding="0,0,0,12" (снизу) дает место для хвостиков букв р, у, д.
                                 3. ClipToBounds="False" разрешает рисовать за пределами блока. -->
                            <TextBlock Text="{Binding PlaylistName}"
                                FontSize="48"
                                FontWeight="Black"
                                Margin="0,4,0,0"
                                Padding="0,0,0,12"
                                TextWrapping="Wrap"
                                MaxLines="2"
                                ClipToBounds="False" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding FormattedTrackCount}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="•" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding FormattedDuration}"
                                    Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- В блоке Actions -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="24"
                        VerticalAlignment="Center">

                        <!-- Play All -->
                        <Button Classes="play-circle" Command="{Binding PlayAllCommand}" Width="56"
                            Height="56">
                            <Panel>
                                <mi:MaterialIcon Kind="Play" Width="28" Height="28"
                                    Foreground="{StaticResource TextDarkBrush}"
                                    IsVisible="{Binding !IsPlayingThisPlaylist}" />
                                <mi:MaterialIcon Kind="Pause" Width="28" Height="28"
                                    Foreground="{StaticResource TextDarkBrush}"
                                    IsVisible="{Binding IsPlayingThisPlaylist}" />
                            </Panel>
                        </Button>

                        <!-- Shuffle -->
                        <Button Classes="icon-btn" Command="{Binding ShufflePlayCommand}"
                            ToolTip.Tip="{Binding L[Playlist_ShufflePlay]}">
                            <mi:MaterialIcon Kind="ShuffleVariant" Width="24" Height="24"
                                Foreground="{Binding IsShuffleActive, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}">
                                <mi:MaterialIcon.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                                    </Transitions>
                                </mi:MaterialIcon.Transitions>
                            </mi:MaterialIcon>
                        </Button>

                        <!-- НОВАЯ КНОПКА: Add to Queue -->
                        <Button Classes="icon-btn" Command="{Binding AddToQueueCommand}"
                            ToolTip.Tip="{Binding L[Queue_Add]}">
                            <mi:MaterialIcon Kind="PlaylistPlus" Width="24" Height="24" />
                        </Button>

                        <!-- Download -->
                        <Button Classes="icon-btn" Command="{Binding DownloadAllCommand}"
                            ToolTip.Tip="Download All">
                            <mi:MaterialIcon Kind="Download" Width="24" Height="24"
                                Foreground="{Binding IsDownloadingActive, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                        </Button>

                        <!-- Sync -->
                        <Button Classes="icon-btn" Command="{Binding RefreshPlaylistCommand}"
                            IsVisible="{Binding IsCloud}" ToolTip.Tip="Sync with YouTube">
                            <mi:MaterialIcon Kind="Sync" Width="24" Height="24" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Viewbox>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Row="1"
            ResizeDirection="Rows"
            Background="Transparent"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ShowsPreview="False">
            <GridSplitter.Template>
                <ControlTemplate>
                    <Border Background="Transparent" Padding="0,2" Cursor="SizeNorthSouth">
                        <Border Height="2" Width="40" Background="{StaticResource BgHighlightBrush}"
                            CornerRadius="1" />
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- LIST -->
        <controls:TrackListControl Grid.Row="2" Margin="24,0"
            Items="{Binding Items}"
            IsLoading="{Binding IsLoading}"
            IsLoadingMore="{Binding IsLoadingMore}"
            IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
            ReachedEnd="{Binding ReachedEnd}"
            LoadMoreCommand="{Binding LoadMoreCommand}"
            UseInternalScroll="True"
            EnableSmoothLoading="{Binding EnableSmoothLoading}" />
    </Grid>
</UserControl>