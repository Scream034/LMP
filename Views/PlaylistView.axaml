<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Behaviors"
    x:Class="MyLiteMusicPlayer.Views.PlaylistView"
    x:DataType="vm:PlaylistViewModel">

    <!-- ИСПРАВЛЕНО: Grid с 3 строками для размещения лоадера внизу -->
    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Row 0: ШАПКА -->
        <Border Grid.Row="0" Padding="0,0,0,16" BorderBrush="{StaticResource BgHighlightBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,24">
                    <Border Grid.Column="0" Width="160" Height="160" CornerRadius="4"
                        ClipToBounds="True" Background="{StaticResource BgSkeletonBrush}">
                        <Panel>
                            <mi:MaterialIcon Kind="MusicNote" Width="64" Height="64"
                                Foreground="{StaticResource TextMutedBrush}"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                            
                            <!-- Картинки -->
                            <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl, Converter={StaticResource WebUrlConverter}}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='http'}" />
                            <Image Source="{Binding ThumbnailUrl, Converter={StaticResource BitmapAssetConverter}}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='avares'}" />
                        </Panel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding L[Playlist_Type]}" FontSize="12" FontWeight="Bold"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding PlaylistName}" FontSize="32" FontWeight="Black"
                            Margin="0,4,0,12" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding FormattedTrackCount}"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="•" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding FormattedDuration}"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Button Classes="play-circle" Command="{Binding PlayAllCommand}" Width="48" Height="48">
                        <mi:MaterialIcon Kind="Play" Width="24" Height="24" Foreground="{StaticResource TextDarkBrush}" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding ShufflePlayCommand}" ToolTip.Tip="Shuffle">
                        <mi:MaterialIcon Kind="Shuffle" Width="24" Height="24" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding DownloadAllCommand}" ToolTip.Tip="Download All">
                        <mi:MaterialIcon Kind="Download" Width="24" Height="24" />
                    </Button>
                    <Button Classes="icon-btn" Command="{Binding RefreshPlaylistCommand}" IsVisible="{Binding IsCloud}" ToolTip.Tip="Refresh">
                        <mi:MaterialIcon Kind="Sync" Width="24" Height="24" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Загрузка (начальная) -->
        <ContentControl Grid.Row="1" Classes="loading-initial" 
                        IsVisible="{Binding IsLoading}" 
                        VerticalAlignment="Center"/>

        <!-- Row 1: СПИСОК -->
        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Items}" 
                 Background="Transparent" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 IsVisible="{Binding !IsLoading}">
            
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListBox.Styles>
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Row 2: СКЕЛЕТОНЫ ПОДГРУЗКИ (ИСПРАВЛЕНО: Вынесено из ListBox) -->
        <ContentControl Grid.Row="2" 
                        Classes="loading-skeletons" 
                        IsVisible="{Binding IsLoadingMore}"
                        Margin="0,8,0,0"/>
    </Grid>
</UserControl>