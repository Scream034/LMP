<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:views="using:MyLiteMusicPlayer.Views"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Lite Music Player"
    Width="1200" Height="800"
    MinWidth="900" MinHeight="600"
    Background="{StaticResource BgPrimaryBrush}"
    WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*, Auto">

        <!-- Основной контент -->
        <Grid Grid.Row="0" ColumnDefinitions="240, *">


            <!-- САЙДБАР -->

            <Border Grid.Column="0"
                Background="{StaticResource BgSecondaryBrush}"
                Padding="16,16,16,16">

                <Panel>
                    <!-- Основное содержимое сайдбара -->
                    <Grid RowDefinitions="Auto, Auto, *, Auto">

                        <!-- Логотип -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12"
                            Margin="4,4,4,28">
                            <mi:MaterialIcon Kind="Music" Width="36" Height="36"
                                Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="LitePlayer"
                                FontSize="22" FontWeight="Bold"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <!-- Навигация -->
                        <StackPanel Grid.Row="1" Spacing="6">
                            <!-- Home -->
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Home'}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Home"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="Home" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Home]}"
                                        VerticalAlignment="Center"
                                        FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- Search -->
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Search'}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Search"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="Magnify" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Search]}"
                                        VerticalAlignment="Center"
                                        FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- Library -->
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Library'}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Library"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="BookMusic" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Library]}"
                                        VerticalAlignment="Center"
                                        FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- Playlist (виден только если на странице плейлиста) -->
                            <Button Classes="sidebar-btn active"
                                IsVisible="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Playlist'}"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="PlaylistMusic" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Playlist]}"
                                        VerticalAlignment="Center"
                                        FontSize="15" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Пустое пространство -->
                        <Panel Grid.Row="2" />

                        <!-- Настройки внизу -->
                        <Button Grid.Row="3"
                            Classes="sidebar-btn"
                            Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Settings'}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            IsEnabled="{Binding !IsNavigationLocked}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <mi:MaterialIcon Kind="Cog" Width="24" Height="24" />
                                <TextBlock Text="{Binding L[Nav_Settings]}"
                                    VerticalAlignment="Center"
                                    FontSize="15" />
                            </StackPanel>
                        </Button>
                    </Grid>


                    <!-- ОВЕРЛЕЙ БЛОКИРОВКИ НАВИГАЦИИ -->
                    <Border IsVisible="{Binding IsNavigationLocked}"
                        Background="#E8121212"
                        CornerRadius="8"
                        Margin="-16">
                        <Grid RowDefinitions="*, Auto, *">
                            <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                Spacing="20">

                                <!-- Анимированная иконка облака (64x64) -->
                                <Panel Width="64" Height="64" HorizontalAlignment="Center">
                                    <!-- Акцентный фон (пульсирует в противофазе с облаком) -->
                                    <Border Classes="cloud-bg-accent-large"
                                        CornerRadius="32"
                                        Width="64" Height="64" />

                                    <!-- Облако -->
                                    <Panel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <!-- Тёмный базовый слой -->
                                        <mi:MaterialIcon Kind="Cloud"
                                            Width="32" Height="32"
                                            Classes="cloud-dark" />
                                        <!-- Яркий пульсирующий слой -->
                                        <mi:MaterialIcon Kind="Cloud"
                                            Width="32" Height="32"
                                            Classes="cloud-bright-large" />
                                    </Panel>
                                </Panel>

                                <!-- Текст причины блокировки -->
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NavigationLockReason}"
                                        FontSize="14"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap"
                                        MaxWidth="180"
                                        HorizontalAlignment="Center" />

                                    <TextBlock Text="{Binding L[Nav_PleaseWait]}"
                                        FontSize="12"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        TextAlignment="Center"
                                        HorizontalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Panel>
            </Border>

            <!-- ОСНОВНОЙ КОНТЕНТ -->

            <Border Grid.Column="1"
                Background="{StaticResource BgPrimaryBrush}"
                ClipToBounds="True">
                <Panel>
                    <!-- Контент страницы -->
                    <ContentControl Content="{Binding CurrentPage}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.DataTemplates>
                                        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                                            <views:HomeView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
                                            <views:SearchView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                                            <views:LibraryView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                                            <views:SettingsView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type vm:PlaylistViewModel}">
                                            <views:PlaylistView />
                                        </DataTemplate>
                                    </ContentControl.DataTemplates>
                                </ContentControl>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- Затемнение контента при блокировке -->
                    <Border IsVisible="{Binding IsNavigationLocked}"
                        Background="#60000000"
                        IsHitTestVisible="True" />
                </Panel>
            </Border>
        </Grid>

        <!-- ПЛЕЕР-БАР (скрыт если нет трека) -->
        <views:PlayerBarView Grid.Row="1"
            DataContext="{Binding PlayerBar}"
            IsVisible="{Binding HasTrack}" />

    </Grid>
</Window>