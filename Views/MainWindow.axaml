<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:views="using:MyLiteMusicPlayer.Views"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader"
    x:Class="MyLiteMusicPlayer.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Lite Music Player"
    Width="1280" Height="800"
    MinWidth="1024" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource BgPrimaryBrush}">

    <Grid RowDefinitions="*, Auto">
        <!-- Main Content Area -->
        <Grid Grid.Row="0" ColumnDefinitions="240, *">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                Background="{StaticResource BgSecondaryBrush}"
                Padding="8">
                <DockPanel>
                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,24">
                        <TextBlock Text="♪ Lite Player"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4">
                        <Button Classes="sidebar-btn" Command="{Binding NavigateHomeCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <mi:MaterialIcon Kind="Home" Width="24" Height="24" />
                                <TextBlock Text="{Binding L[Sidebar_Home]}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="sidebar-btn" Command="{Binding NavigateSearchCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <mi:MaterialIcon Kind="Magnify" Width="24" Height="24" />
                                <TextBlock Text="{Binding L[Sidebar_Search]}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="sidebar-btn" Command="{Binding NavigateLibraryCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <mi:MaterialIcon Kind="BookMusic" Width="24" Height="24" />
                                <TextBlock Text="{Binding L[Sidebar_Library]}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Divider -->
                    <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="{StaticResource BgHighlightBrush}"
                        Margin="16,16" />

                    <!-- User Section (REDESIGNED) -->
                    <Border DockPanel.Dock="Bottom" Padding="4">
                        <Button Classes="sidebar-btn" Command="{Binding NavigateSettingsCommand}"
                            Padding="8,12">
                            <Grid ColumnDefinitions="Auto, *">

                                <!-- Avatar Circle -->
                                <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="20"
                                    ClipToBounds="True"
                                    Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource BgHighlightBrush}"
                                    BorderThickness="1">
                                    <Panel>
                                        <!-- Fallback Icon -->
                                        <mi:MaterialIcon Kind="Account"
                                            Width="24" Height="24"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            IsVisible="{Binding UserAvatarUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />

                                        <!-- Real Avatar -->
                                        <Image
                                            asyncImage:ImageLoader.Source="{Binding UserAvatarUrl}"
                                            Stretch="UniformToFill"
                                            IsVisible="{Binding IsAuthenticated}" />
                                    </Panel>
                                </Border>

                                <!-- Text & Settings Icon -->
                                <Grid Grid.Column="1" Margin="12,0,0,0" RowDefinitions="*,*">
                                    <TextBlock Grid.Row="0"
                                        Text="{Binding UserName, FallbackValue='Guest'}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        VerticalAlignment="Bottom"
                                        TextTrimming="CharacterEllipsis" />

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Top">
                                        <mi:MaterialIcon Kind="Cog" Width="12" Height="12"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding L[Sidebar_Settings]}"
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Button>
                    </Border>

                    <!-- Spacer -->
                    <Border />
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1"
                Background="{StaticResource BgPrimaryBrush}"
                Padding="24">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:HomeViewModel">
                            <views:HomeView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SearchViewModel">
                            <views:SearchView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LibraryViewModel">
                            <views:LibraryView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:PlaylistViewModel">
                            <views:PlaylistView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>

        <!-- Player Bar -->
        <views:PlayerBarView Grid.Row="1"
            DataContext="{Binding PlayerBar}"
            IsVisible="{Binding HasTrack}" />
    </Grid>
</Window>