<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader"
    x:Class="MyLiteMusicPlayer.Views.PlayerBarView"
    x:DataType="vm:PlayerBarViewModel">

    <UserControl.Styles>
        <!-- Анимация пульсации для Seek -->
        <Style Selector="Border.seek-busy-indicator">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3" />
                        <Setter Property="BorderThickness" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="BorderThickness" Value="2" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3" />
                        <Setter Property="BorderThickness" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Стиль для полосок громкости (убираем дублирование) -->
        <Style Selector="Border.volume-bar">
            <Setter Property="Width" Value="4" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Кастомный Слайдер (Spotify Style) -->
        <Style Selector="Slider.spotify-slider">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource BgHighlightBrush}" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
        <Style Selector="Slider.spotify-slider /template/ Track">
            <Setter Property="Minimum" Value="{TemplateBinding Minimum}" />
            <Setter Property="Maximum" Value="{TemplateBinding Maximum}" />
            <Setter Property="Value" Value="{TemplateBinding Value}" />
            <Setter Property="Height" Value="4" />
        </Style>
        <Style Selector="Slider.spotify-slider /template/ Thumb">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.spotify-slider:pointerover /template/ Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scale(1.2)" />
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource BgSecondaryBrush}" Height="94"
        BorderBrush="{StaticResource BgHighlightBrush}" BorderThickness="0,1,0,0">
        <Grid>
            <!-- Индикатор загрузки -->
            <ProgressBar VerticalAlignment="Top" Height="2" IsIndeterminate="True"
                Background="Transparent" Foreground="{StaticResource AccentBrush}"
                IsVisible="{Binding IsLoading}" />

            <Grid ColumnDefinitions="3*, 4*, 3*" Margin="16,0">

                <!-- ЛЕВО: Инфо -->
                <Grid Grid.Column="0" ColumnDefinitions="Auto, *, Auto">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4"
                        ClipToBounds="True">
                        <Panel>
                            <mi:MaterialIcon Kind="MusicNote" Width="24" Height="24"
                                Foreground="{StaticResource TextMutedBrush}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                            <Image asyncImage:ImageLoader.Source="{Binding SafeThumbnail}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}}" />
                        </Panel>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                        <TextBlock Text="{Binding SafeTitle}" FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SafeAuthor}" FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <Button Classes="icon-btn" Command="{Binding ToggleLikeCommand}">
                            <mi:MaterialIcon
                                Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}"
                                Foreground="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}"
                                Width="18" Height="18" />
                        </Button>
                        <Button Classes="icon-btn" Command="{Binding CopyLinkCommand}">
                            <mi:MaterialIcon Kind="ContentCopy" Width="16" Height="16"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ЦЕНТР: Управление -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                        <Button Classes="icon-btn" Command="{Binding ToggleShuffleCommand}">
                            <mi:MaterialIcon Kind="Shuffle"
                                Foreground="{Binding ShuffleEnabled, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                        </Button>
                        <Button Classes="icon-btn" Command="{Binding PreviousCommand}">
                            <mi:MaterialIcon Kind="SkipPrevious" />
                        </Button>
                        <Button Classes="play-circle" Command="{Binding PlayPauseCommand}"
                            Width="32" Height="32" Background="{StaticResource TextPrimaryBrush}">
                            <Panel>
                                <mi:MaterialIcon Kind="Pause"
                                    Foreground="{StaticResource TextDarkBrush}" Width="20"
                                    Height="20" IsVisible="{Binding IsPlaying}" />
                                <mi:MaterialIcon Kind="Play"
                                    Foreground="{StaticResource TextDarkBrush}" Width="20"
                                    Height="20" IsVisible="{Binding IsPaused}" />
                            </Panel>
                        </Button>
                        <Button Classes="icon-btn" Command="{Binding NextCommand}">
                            <mi:MaterialIcon Kind="SkipNext" />
                        </Button>
                        <Button Classes="icon-btn" Command="{Binding ToggleRepeatCommand}">
                            <mi:MaterialIcon
                                Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                    </StackPanel>

                    <!-- Seek Bar -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,4,0,0">
                        <TextBlock
                            Text="{Binding Position, Converter={StaticResource TimeSpanConverter}}"
                            FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                            Width="40" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Height="24" VerticalAlignment="Center">
                            <!-- Busy Indicator -->
                            <Border CornerRadius="6" Margin="-6,-4" IsVisible="{Binding IsSeekBusy}"
                                Classes="seek-busy-indicator"
                                BorderBrush="{StaticResource AccentBrush}" />
                            <Panel VerticalAlignment="Center">
                                <Border Height="4" CornerRadius="2"
                                    Background="{StaticResource BgElevatedBrush}"
                                    VerticalAlignment="Center" />
                                <ProgressBar Minimum="0" Maximum="{Binding DurationSeconds}"
                                    Value="{Binding BufferedSeconds}" Height="4"
                                    Background="Transparent"
                                    Foreground="{StaticResource BgHoverBrush}"
                                    VerticalAlignment="Center" CornerRadius="2" />
                                <Slider Minimum="0" Maximum="{Binding DurationSeconds}"
                                    Value="{Binding PositionSeconds}" Classes="spotify-slider"
                                    IsHitTestVisible="False" VerticalAlignment="Center" />
                            </Panel>
                            <!-- Зона клика (SeekHitBox) -->
                            <Border Name="SeekHitBox" Background="Transparent" Cursor="Hand"
                                PointerPressed="OnSeekAreaPressed" PointerMoved="OnSeekAreaMoved"
                                PointerReleased="OnSeekAreaReleased"
                                PointerExited="OnSeekAreaExited"
                                IsHitTestVisible="{Binding HasTrack}">
                                <Border.Styles>
                                    <Style Selector="Border[IsHitTestVisible=False]">
                                        <Setter Property="Opacity" Value="0.5" />
                                    </Style>
                                    <Style Selector="Border[IsHitTestVisible=True]">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                </Border.Styles>
                            </Border>
                            <!-- Tooltip -->
                            <Border Name="HoverTooltip"
                                Background="{StaticResource BgSkeletonBrush}"
                                BorderBrush="{StaticResource BgElevatedBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="False"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="0,-30,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform />
                                </Border.RenderTransform>
                                <TextBlock Name="HoverTimeText" Text="0:00" FontSize="11"
                                    FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </Grid>
                        <TextBlock Grid.Column="2"
                            Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}"
                            FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                            Width="40" TextAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Stream Info Section -->
                    <Button Classes="sidebar-btn"
                        Padding="4,2"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding LoadFormatsCommand}"
                        IsVisible="{Binding ShowStreamInfo}">

                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding L[Stream_SelectQuality]}"
                                        FontWeight="Bold" Margin="4" />
                                    <ListBox ItemsSource="{Binding AvailableFormats}"
                                        Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent"
                                                    Command="{Binding $parent[UserControl].DataContext.SwitchFormatCommand}"
                                                    CommandParameter="{Binding}">
                                                    <Grid ColumnDefinitions="*, Auto" Width="180">
                                                        <TextBlock Text="{Binding DisplayName}" />
                                                        <TextBlock Grid.Column="1"
                                                            Text="{Binding SizeMb, StringFormat='{}{0:F1} MB'}"
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            FontSize="11"
                                                            VerticalAlignment="Center"
                                                            Margin="8,0,0,0" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>

                        <!-- Содержимое кнопки (Текущая инфа) -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding StreamInfo}" FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}"
                                VerticalAlignment="Center" />

                            <!-- Значок стрелочки, намекающий на меню -->
                            <mi:MaterialIcon Kind="ChevronUp" Width="12" Height="12"
                                Foreground="{StaticResource TextMutedBrush}" />

                            <TextBlock Text="•" FontSize="9"
                                Foreground="{StaticResource BgHighlightBrush}"
                                IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}"
                                VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DownloadSpeedText}" FontSize="9"
                                Foreground="{StaticResource AccentBrush}"
                                IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- ПРАВО: Громкость (Кастомная) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Spacing="12">

                    <!-- Кнопка с 5 анимированными полосками -->
                    <Button Classes="icon-btn" Command="{Binding ToggleMuteCommand}" Padding="0"
                        Width="40">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                            <!-- Пример для одной полоски, применить ко всем пяти -->
                            <Border Classes="volume-bar" Height="6"
                                Background="{DynamicResource {Binding VolumeBarBrushKey}}"
                                Opacity="{Binding Bar1Opacity}" />
                            <Border Classes="volume-bar" Height="9"
                                Background="{DynamicResource {Binding VolumeBarBrushKey}}"
                                Opacity="{Binding Bar2Opacity}" />
                            <Border Classes="volume-bar" Height="12"
                                Background="{DynamicResource {Binding VolumeBarBrushKey}}"
                                Opacity="{Binding Bar3Opacity}" />
                            <Border Classes="volume-bar" Height="15"
                                Background="{DynamicResource {Binding VolumeBarBrushKey}}"
                                Opacity="{Binding Bar4Opacity}" />
                            <!-- Бар 5 (Толстеющий) -->
                            <Border Classes="volume-bar" Height="18"
                                Width="{Binding Bar5Thickness}"
                                Background="{DynamicResource {Binding VolumeBarBrushKey}}"
                                Opacity="{Binding Bar5Opacity}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                                        <DoubleTransition Property="Width" Duration="0:0:0.2"
                                            Easing="BackEaseOut" />
                                        <BrushTransition Property="Background" Duration="0:0:0.2" />
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Слайдер с анимированной шириной -->
                    <Grid Width="{Binding VolumeSliderWidth}" Height="24">
                        <Grid.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Width" Duration="0:0:0.4"
                                    Easing="CubicEaseOut" />
                            </Transitions>
                        </Grid.Transitions>

                        <Slider Classes="spotify-slider" Minimum="0" Maximum="{Binding MaxVolume}"
                            Value="{Binding Volume}" IsHitTestVisible="False"
                            VerticalAlignment="Center" />

                        <Border Name="VolumeHitBox" Background="Transparent" Cursor="Hand"
                            PointerPressed="OnVolumeAreaPressed" PointerMoved="OnVolumeAreaMoved"
                            PointerReleased="OnVolumeAreaReleased"
                            PointerExited="OnVolumeAreaExited" />
                        <Border Name="VolumeTooltip" Background="{StaticResource BgSkeletonBrush}"
                            BorderBrush="{StaticResource BgElevatedBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="6,2" IsVisible="False"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-30,0,0">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                            <TextBlock Name="VolumeTooltipText" Text="50%" FontSize="11"
                                FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>