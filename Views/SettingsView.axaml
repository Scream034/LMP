<!-- Views/SettingsView.axaml -->
<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    x:Class="MyLiteMusicPlayer.Views.SettingsView"
    x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style Selector="Grid.setting-row">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.setting-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.setting-desc">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="32" MaxWidth="700" Margin="32">

            <!-- Заголовок -->
            <TextBlock Text="{Binding L_Title}" FontSize="32" FontWeight="Bold" />

            <!-- СЕКЦИЯ: АККАУНТ И ЯЗЫК -->
            <StackPanel Spacing="16">
                <TextBlock Classes="section-header" Text="{Binding L_AccountLanguage}" />

                <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding UserEmail, FallbackValue='Not signed in'}"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{Binding IsAuthenticated, Converter={StaticResource BoolToSelector}, ConverterParameter='Authenticated|Guest Mode'}"
                            Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding LoginCommand}"
                            Content="{Binding L_Login}"
                            IsVisible="{Binding !IsAuthenticated}" Classes="accent" />
                        <Button Command="{Binding LogoutCommand}"
                            Content="{Binding L_Logout}"
                            IsVisible="{Binding IsAuthenticated}" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*, Auto" Classes="setting-row">
                    <TextBlock Classes="setting-title" Text="{Binding L_Language}" />
                    <ComboBox Grid.Column="1"
                        ItemsSource="{Binding Languages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        DisplayMemberBinding="{Binding Name}"
                        MinWidth="140" />
                </Grid>
            </StackPanel>

            <!-- СЕКЦИЯ: АУДИО -->
            <StackPanel Spacing="16">
                <TextBlock Classes="section-header" Text="{Binding L_Audio}" />

                <Grid Classes="setting-row" ColumnDefinitions="*, 200">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Classes="setting-title" Text="{Binding L_MaxVolume}" />
                        <TextBlock Classes="setting-desc" Text="{Binding L_MaxVolumeDesc}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MaxVolumeLimit, StringFormat='{}{0}%'}"
                            HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,4" />
                        <Slider Minimum="100" Maximum="400" Value="{Binding MaxVolumeLimit}"
                            TickFrequency="100" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Grid>

                <Grid Classes="setting-row" ColumnDefinitions="*, 200">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Classes="setting-title" Text="{Binding L_Gain}" />
                        <TextBlock Classes="setting-desc" Text="{Binding L_GainDesc}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TargetGainDb, StringFormat='{}{0:F1} dB'}"
                            HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,4" />
                        <Slider Minimum="-12" Maximum="12" Value="{Binding TargetGainDb}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- СЕКЦИЯ: ОБЩЕЕ -->
            <StackPanel Spacing="16">
                <TextBlock Classes="section-header" Text="{Binding L_General}" />

                <Grid Classes="setting-row" ColumnDefinitions="*, Auto">
                    <TextBlock Classes="setting-title" Text="{Binding L_Discord}" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding DiscordRpcEnabled}"
                        OnContent="" OffContent="" />
                </Grid>

                <Grid Classes="setting-row" ColumnDefinitions="*, Auto">
                    <TextBlock Classes="setting-title" Text="{Binding L_AutoPaste}" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoPlayOnPaste}"
                        OnContent="" OffContent="" />
                </Grid>

                <Grid Classes="setting-row" ColumnDefinitions="*, Auto">
                    <TextBlock Classes="setting-title" Text="{Binding L_SmoothLoading}" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableSmoothLoading}"
                        OnContent="" OffContent="" />
                </Grid>
            </StackPanel>

            <!-- СЕКЦИЯ: ХРАНИЛИЩЕ -->
            <StackPanel Spacing="16">
                <TextBlock Classes="section-header" Text="{Binding L_Storage}" />

                <Grid Classes="setting-row" ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="setting-title" Text="{Binding L_DownloadPath}" />
                        <TextBlock Classes="setting-desc" Text="{Binding DownloadPath}"
                            TextTrimming="CharacterEllipsis" MaxWidth="400" />
                    </StackPanel>
                    <Button Grid.Column="1"
                        Content="{Binding L_ChangeFolder}"
                        Command="{Binding BrowseDownloadPathCommand}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                    <Button Content="{Binding L_ClearHistory}"
                        Command="{Binding ClearHistoryCommand}"
                        Background="Transparent"
                        BorderBrush="{StaticResource BgHighlightBrush}"
                        BorderThickness="1" />
                    <Button Content="{Binding L_ResetApp}"
                        Command="{Binding ResetLibraryCommand}"
                        Foreground="#FF6B6B"
                        Background="Transparent" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>