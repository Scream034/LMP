<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MyLiteMusicPlayer"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="MyLiteMusicPlayer.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        
        <!-- ИСПРАВЛЕНИЕ 1: Material Icons 2.x+ подключаются так: -->
        <materialIcons:MaterialIconStyles />
        
        <!-- ИСПРАВЛЕНИЕ 2: Правильный путь к стилям AsyncImageLoader -->
        <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />
        
        <!-- Ваши стили (используем путь от корня /, чтобы избежать ошибок сборки) -->
        <StyleInclude Source="/Styles/SpotifyTheme.axaml" />
        <StyleInclude Source="/Templates/TrackRowTemplate.axaml" />
        <StyleInclude Source="/Templates/PlaylistCardTemplate.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- ИСПРАВЛЕНИЕ 3: Локальный путь для конвертеров -->
                <ResourceInclude Source="/Converters/AppConverters.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>