<Application xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyLiteMusicPlayer"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.App"
    RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Converters/AppConverters.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <!-- === TRACK TEMPLATE === -->
        <DataTemplate DataType="{x:Type vm:TrackItemViewModel}">
            <Panel Classes="track-row"
                Classes.is-active="{Binding IsActive}"
                Classes.is-playing="{Binding IsPlaying}"
                Background="Transparent"
                Margin="0,2">

                <!-- 1. BACKGROUND -->
                <Border Classes="track-bg" CornerRadius="6" />

                <!-- 2. CONTENT -->
                <Grid ColumnDefinitions="48, *, Auto, Auto, Auto" Margin="4">

                    <!-- IMAGE + CONTROLS -->
                    <Panel Grid.Column="0" Width="48" Height="48" HorizontalAlignment="Left">
                        <Border CornerRadius="4" ClipToBounds="True">
                            <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                Stretch="UniformToFill" />
                        </Border>

                        <Border CornerRadius="4" Classes="hover-overlay" />

                        <mi:MaterialIcon Kind="Play" Width="28" Height="28" Classes="icon-play"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <mi:MaterialIcon Kind="Pause" Width="28" Height="28" Classes="icon-pause"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <Button Command="{Binding PlayCommand}"
                            Background="Transparent"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Cursor="Hand" />
                    </Panel>

                    <!-- INFO -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="12,0">
                        <TextBlock Text="{Binding Title}"
                            Classes="track-title"
                            FontWeight="Medium" FontSize="14"
                            TextTrimming="CharacterEllipsis" MaxLines="1" />
                        <TextBlock Text="{Binding Author}"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" MaxLines="1" />
                    </StackPanel>

                    <!-- STATUS (Downloaded) -->
                    <Panel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0" Width="20">
                        <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                            Foreground="{StaticResource AccentBrush}"
                            IsVisible="{Binding IsDownloaded}" />
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="1" Width="20"
                            Height="4"
                            IsVisible="{Binding IsDownloading}"
                            Foreground="{StaticResource AccentBrush}" />
                    </Panel>

                    <!-- LIKE -->
                    <Button Grid.Column="3" Classes="icon-btn like-btn"
                        Command="{Binding ToggleLikeCommand}"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                        <mi:MaterialIcon
                            Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}"
                            Width="18" Height="18"
                            Foreground="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                    </Button>

                    <!-- DURATION -->
                    <TextBlock Grid.Column="4"
                        Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="13"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"
                        MinWidth="45"
                        TextAlignment="Right" />
                </Grid>

                <!-- 3. OUTLINE -->
                <Rectangle Classes="track-outline"
                    RadiusX="6" RadiusY="6"
                    Fill="Transparent"
                    StrokeThickness="1"
                    IsHitTestVisible="False" />
            </Panel>
        </DataTemplate>
        
        <!-- PlaylistCardTemplate is now handled via Styles in Templates/PlaylistCardTemplate.axaml -->
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />
        <StyleInclude Source="/Styles/SpotifyTheme.axaml" />
        <StyleInclude Source="avares://MyLiteMusicPlayer/Templates/LoadingSkeletons.axaml" />
        <StyleInclude Source="avares://MyLiteMusicPlayer/Templates/PlaylistCardTemplate.axaml" />

        <!--                   CSS LOGIC                       -->

        <!-- 1. BASE SETTINGS -->
        <Style Selector="Panel.track-row Border.track-bg">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Panel.track-row Border.hover-overlay">
            <Setter Property="Background" Value="#80000000" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Panel.track-row mi|MaterialIcon.icon-play">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Panel.track-row mi|MaterialIcon.icon-pause">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Panel.track-row Rectangle.track-outline">
            <Setter Property="Stroke" Value="Transparent" />
        </Style>

        <Style Selector="Panel.track-row TextBlock.track-title">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <!-- 2. HOVER -->
        <Style Selector="Panel.track-row:pointerover Border.track-bg">
            <Setter Property="Background" Value="{StaticResource BgHighlightBrush}" />
        </Style>

        <Style Selector="Panel.track-row:pointerover Border.hover-overlay">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Panel.track-row:pointerover:not(.is-playing) mi|MaterialIcon.icon-play">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- 3. ACTIVE TRACK -->
        <Style Selector="Panel.track-row.is-active Border.track-bg">
            <Setter Property="Background" Value="{StaticResource BgHighlightBrush}" />
        </Style>

        <Style Selector="Panel.track-row.is-active TextBlock.track-title">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style Selector="Panel.track-row.is-active Border.hover-overlay">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Panel.track-row.is-active:not(.is-playing) mi|MaterialIcon.icon-play">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- 4. PLAYING TRACK -->
        <Style Selector="Panel.track-row.is-playing mi|MaterialIcon.icon-pause">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Panel.track-row.is-playing mi|MaterialIcon.icon-play">
            <Setter Property="Opacity" Value="0" />
        </Style>
    </Application.Styles>
</Application>