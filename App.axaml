<Application xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyLiteMusicPlayer"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.App"
    RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <!-- ЕДИНЫЙ ШАБЛОН ТРЕКА (TrackRow) -->
        <DataTemplate DataType="{x:Type vm:TrackItemViewModel}">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" Background="Transparent"
                Margin="0,4" Classes="track-grid">
                <!-- 1. Картинка + Play -->
                <Panel Grid.Column="0" Width="48" Height="48" Margin="0,0,16,0">
                    <Border CornerRadius="4" ClipToBounds="True">
                        <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                            Stretch="UniformToFill" />
                    </Border>
                    <Button Command="{Binding PlayCommand}" Classes="play-overlay"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                        <mi:MaterialIcon
                            Kind="{Binding IsPlaying, Converter={StaticResource BoolToSelector}, ConverterParameter=Pause|Play}"
                            Width="24" Height="24" Foreground="White" />
                    </Button>
                </Panel>

                <!-- 2. Инфо -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Title}"
                        Foreground="{Binding IsCurrentTrack, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextPrimaryBrush'}"
                        FontWeight="Medium"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Author}" FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- 3. Статус скачивания -->
                <Panel Grid.Column="2" Margin="16,0" VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16"
                        Foreground="{StaticResource AccentBrush}" IsVisible="{Binding IsDownloaded}" />
                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="1" Width="50"
                        Height="4"
                        IsVisible="{Binding IsDownloading}"
                        Foreground="{StaticResource AccentBrush}" />
                </Panel>

                <!-- 4. Лайк -->
                <Button Grid.Column="3" Classes="icon-btn" Command="{Binding ToggleLikeCommand}"
                    Margin="0,0,16,0">
                    <mi:MaterialIcon
                        Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}"
                        Width="18" Height="18"
                        Foreground="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                </Button>

                <!-- 5. Длительность -->
                <TextBlock Grid.Column="4"
                    Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}"
                    VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                    Width="50" TextAlignment="Right" Margin="0,0,16,0" />
            </Grid>
        </DataTemplate>

        <!-- Шаблон карточки плейлиста -->
        <DataTemplate DataType="{x:Type vm:PlaylistCardViewModel}">
            <Button Command="{Binding OpenCommand}"
                Background="{StaticResource BgElevatedBrush}"
                CornerRadius="8"
                Padding="16"
                Width="180" Height="240"
                Margin="0,0,24,24">
                <StackPanel>
                    <Border Width="148" Height="148" CornerRadius="4" ClipToBounds="True"
                        Margin="0,0,0,16" BoxShadow="0 4 10 0 #40000000">
                        <Panel Background="#333">
                            <mi:MaterialIcon Kind="MusicNote" Width="64" Height="64"
                                Foreground="#555"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                            <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}}" />
                        </Panel>
                    </Border>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"
                        TextTrimming="CharacterEllipsis"
                        Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding FormattedTrackCount}" FontSize="13" Margin="0,4,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Button>
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />
        <StyleInclude Source="/Styles/SpotifyTheme.axaml" />
        <StyleInclude Source="avares://MyLiteMusicPlayer/Templates/LoadingSkeletons.axaml" />

        <!-- Стили для кнопки Play поверх картинки -->
        <Style Selector="Grid.track-grid Button.play-overlay">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Background" Value="#80000000" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Grid.track-grid:pointerover Button.play-overlay">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Grid.track-grid:pointerover">
            <Setter Property="Background" Value="{StaticResource BgHighlightBrush}" />
        </Style>

        <!-- ГЛОБАЛЬНЫЙ СТИЛЬ SKELETON (Пульсация) -->
        <Style Selector="Border.skeleton">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.75">
                        <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Converters/AppConverters.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>