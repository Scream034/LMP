<Application xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LMP"
    x:Class="LMP.App"
    RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/UI/Converters/AppConverters.axaml" />
                <ResourceInclude Source="avares://LMP/UI/Theme/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />

        <!-- 1. ToolTip первым -->
        <StyleInclude Source="/UI/Theme/ToolTipTheme.axaml" />
        <!-- 2. Theme.axaml: Typography, Buttons, Controls, AppComponents, PlayerBarStyles -->
        <StyleInclude Source="/UI/Theme/Theme.axaml" />
        <!-- 3. Дополнительные компоненты -->
        <StyleInclude Source="/UI/Theme/LoadingSkeletons.axaml" />
        <StyleInclude Source="/UI/Theme/ChipStyles.axaml" />
        <StyleInclude Source="UI/Features/Library/PlaylistCardTemplate.axaml" />
    </Application.Styles>

</Application>