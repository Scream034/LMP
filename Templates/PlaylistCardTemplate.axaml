<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:asyncImage="using:AsyncImageLoader">

    <Style Selector="ContentControl.playlist-card">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="vm:PlaylistCardViewModel">
                    <Button Command="{Binding OpenCommand}"
                            Background="{StaticResource BgElevatedBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Width="180" Height="240"
                            Margin="0,0,24,24">
                        <StackPanel>
                            <!-- Cover Image -->
                            <Border Width="148" Height="148" 
                                    CornerRadius="4" 
                                    ClipToBounds="True"
                                    BoxShadow="0 4 10 0 #40000000"
                                    Margin="0,0,0,16">
                                <Panel Background="#333">
                                    <mi:MaterialIcon Kind="MusicNote" 
                                                     Width="64" Height="64" 
                                                     Foreground="#555"
                                                     IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}"/>
                                    <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}}"/>
                                </Panel>
                            </Border>

                            <!-- Title -->
                            <TextBlock Text="{Binding Name}" 
                                       FontWeight="Bold" 
                                       FontSize="16"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <!-- Subtitle -->
                            <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} tracks'}" 
                                       FontSize="13" 
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</Styles>