<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader">

    <Style Selector="ContentControl.playlist-card">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="vm:PlaylistCardViewModel">
                    <Button Command="{Binding OpenCommand}"
                        Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="8"
                        Padding="12"
                        Width="160" Height="220"
                        Margin="0,0,16,16">
                        <StackPanel>
                            <!-- Cover Image -->
                            <Border Width="136" Height="136"
                                CornerRadius="4"
                                ClipToBounds="True"
                                BoxShadow="{StaticResource CardShadow}"
                                Margin="0,0,0,12">
                                <Panel Background="{StaticResource BgElevatedBrush}">
                                    <mi:MaterialIcon Kind="MusicNote"
                                        Width="64" Height="64"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                                    <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                        Stretch="UniformToFill"
                                        IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}}" />
                                </Panel>
                            </Border>

                            <!-- Title -->
                            <TextBlock Text="{Binding Name}"
                                FontWeight="Bold"
                                FontSize="14"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1"
                                ToolTip.Tip="{Binding Name}"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <!-- Subtitle -->
                            <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} tracks'}"
                                FontSize="12"
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</Styles>