<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia">

    <!-- ============================================= -->
    <!-- АНИМАЦИЯ ПЕРЕЛИВАНИЯ ОБЛАКА (CROSSFADE)       -->
    <!-- ============================================= -->
    
    <Style Selector="Panel.cloud-crossfade-overlay">
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- АНИМАЦИЯ ЛУПЫ (ПОИСК)                         -->
    <!-- ============================================= -->

    <Style Selector="mi|MaterialIcon.scanner">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform />
            </Setter.Value>
        </Setter>
        <Style.Animations>
            <!-- 
               Шаг строки = 52px (высота) + 4px (margin) = 56px.
               X сканирует от 0 до 1200 для покрытия всей ширины.
            -->
            <Animation Duration="0:0:4" IterationCount="Infinite" Easing="LinearEasing">
                <!-- Строка 1 -->
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="18" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="5%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="20%">
                    <Setter Property="TranslateTransform.X" Value="1000" />
                    <Setter Property="TranslateTransform.Y" Value="18" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="22%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>

                <!-- Строка 2 -->
                <KeyFrame Cue="25%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="74" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="30%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="45%">
                    <Setter Property="TranslateTransform.X" Value="1000" />
                    <Setter Property="TranslateTransform.Y" Value="74" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="47%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>

                <!-- Строка 3 -->
                <KeyFrame Cue="50%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="130" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="55%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="70%">
                    <Setter Property="TranslateTransform.X" Value="1000" />
                    <Setter Property="TranslateTransform.Y" Value="130" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="72%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>

                <!-- Строка 4 -->
                <KeyFrame Cue="75%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="186" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="80%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="95%">
                    <Setter Property="TranslateTransform.X" Value="1000" />
                    <Setter Property="TranslateTransform.Y" Value="186" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>


    <!-- ============================================= -->
    <!-- СКЕЛЕТОНЫ ЗАГРУЗКИ                            -->
    <!-- ============================================= -->
    
    <!-- Базовая строка трека (Минимализм + Full Width) -->
    <Style Selector="ContentControl.track-skeleton-row">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Height="52" Margin="0,2" Background="Transparent">
                        <Grid ColumnDefinitions="52, *, 50" Margin="8,0">
                            <!-- Иконка/Обложка -->
                            <Border Grid.Column="0" Width="40" Height="40" 
                                    Background="{StaticResource BgSkeletonBrush}" CornerRadius="4"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            
                            <!-- Текстовые блоки (Занимают всё свободное место '*') -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Border Width="180" Height="10" Background="{StaticResource BgSkeletonBrush}"
                                        HorizontalAlignment="Left" CornerRadius="2" />
                                <Border Width="100" Height="7" Background="{StaticResource BgSkeletonDeepBrush}"
                                        HorizontalAlignment="Left" Margin="0,6,0,0" CornerRadius="2" />
                            </StackPanel>
                            
                            <!-- Длительность -->
                            <Border Grid.Column="2" Width="30" Height="7" Background="{StaticResource BgSkeletonDeepBrush}"
                                    VerticalAlignment="Center" HorizontalAlignment="Right" CornerRadius="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Пагинация (Бесконечный скролл) -->
    <Style Selector="ContentControl.loading-skeletons">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,4,0,24" Opacity="0.5">
                        <StackPanel.Effect>
                            <BlurEffect Radius="3"/>
                        </StackPanel.Effect>
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Начальная загрузка (IsLoading) -->
    <Style Selector="ContentControl.loading-initial">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel Spacing="24" Margin="0,60" HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Stretch">
                            <StackPanel.Effect>
                                <BlurEffect Radius="3"/>
                            </StackPanel.Effect>
                            <ContentControl Classes="track-skeleton-row" />
                            <ContentControl Classes="track-skeleton-row" />
                            <ContentControl Classes="track-skeleton-row" />
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <mi:MaterialIcon Kind="Loading" Width="16" Height="16"
                                Foreground="{StaticResource TextMutedBrush}" Classes="spinning" />
                            <TextBlock Text="Loading tracks..." FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ПОИСК: Растягивающийся лоадер с лупой -->
    <Style Selector="ContentControl.loading-search">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch" Margin="0,20">
                        <!-- Контейнер для скелетонов (На всю ширину) -->
                        <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                            <StackPanel.Effect>
                                <BlurEffect Radius="5"/>
                            </StackPanel.Effect>
                            
                            <!-- 4 заблюренных трека, использующих фон для видимости -->
                            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
                                <ContentControl Classes="track-skeleton-row" />
                            </Border>
                            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
                                <ContentControl Classes="track-skeleton-row" />
                            </Border>
                            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
                                <ContentControl Classes="track-skeleton-row" />
                            </Border>
                            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
                                <ContentControl Classes="track-skeleton-row" />
                            </Border>
                        </StackPanel>
                        
                        <!-- Лупа (Маленькая, гуляет поверх) -->
                        <Canvas IsHitTestVisible="False">
                             <mi:MaterialIcon Kind="Magnify" Width="20" Height="20" Classes="scanner"/>
                        </Canvas>
                        
                        <!-- Подпись -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                                    VerticalAlignment="Bottom" Margin="0,260,0,0">
                             <TextBlock Text="Searching..." FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Styles>