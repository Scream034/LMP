<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="using:Material.Icons.Avalonia">

    <!-- ============================================= -->
    <!-- АНИМАЦИЯ ПЕРЕЛИВАНИЯ ОБЛАКА (CROSSFADE)       -->
    <!-- ============================================= -->

    <Style Selector="Panel.cloud-crossfade-overlay">
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- АНИМАЦИЯ ДЫХАНИЯ (BREATHING)                  -->
    <!-- ============================================= -->

    <Style Selector="StackPanel.breathing">
        <Style.Animations>
            <Animation Duration="0:0:1.5" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.4" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.9" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- АНИМАЦИЯ ЛУПЫ (ПЛАВНОЕ ПАРЕНИЕ)               -->
    <!-- ============================================= -->

    <Style Selector="mi|MaterialIcon.scanner-smooth">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <ScaleTransform />
                    <TranslateTransform />
                    <RotateTransform />
                </TransformGroup>
            </Setter.Value>
        </Setter>

        <!-- Тень для объема -->
        <Setter Property="Effect">
            <DropShadowEffect Color="Black" BlurRadius="8" Opacity="0.4" OffsetX="2" OffsetY="2" />
        </Setter>

        <Style.Animations>
            <!-- 1. Движение по горизонтали (Широкая амплитуда) -->
            <Animation Duration="0:0:4" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="0" />
                    <Setter Property="RotateTransform.Angle" Value="-15" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.X" Value="250" /> <!-- Двигаем вправо -->
                    <Setter Property="RotateTransform.Angle" Value="15" />  <!-- Немного наклоняем -->
                </KeyFrame>
            </Animation>

            <!-- 2. Движение по вертикали (Меньшая амплитуда, другой тайминг для эффекта восьмерки) -->
            <Animation Duration="0:0:2.5" IterationCount="Infinite" PlaybackDirection="Alternate"
                Easing="SineEaseInOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="120" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.1" /> <!-- Пульсация размера -->
                    <Setter Property="ScaleTransform.ScaleY" Value="1.1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================= -->
    <!-- СКЕЛЕТОНЫ ЗАГРУЗКИ                            -->
    <!-- ============================================= -->

    <!-- Базовая строка трека -->
    <Style Selector="ContentControl.track-skeleton-row">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Height="52" Margin="0,2" Background="Transparent">
                        <Grid ColumnDefinitions="52, *, 50" Margin="8,0">
                            <!-- Иконка/Обложка -->
                            <Border Grid.Column="0" Width="40" Height="40"
                                Background="{StaticResource BgSkeletonBrush}" CornerRadius="4"
                                VerticalAlignment="Center" HorizontalAlignment="Left" />

                            <!-- Текстовые блоки -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Border Width="180" Height="10"
                                    Background="{StaticResource BgSkeletonBrush}"
                                    HorizontalAlignment="Left" CornerRadius="2" />
                                <Border Width="100" Height="7"
                                    Background="{StaticResource BgSkeletonDeepBrush}"
                                    HorizontalAlignment="Left" Margin="0,6,0,0" CornerRadius="2" />
                            </StackPanel>

                            <!-- Длительность -->
                            <Border Grid.Column="2" Width="30" Height="7"
                                Background="{StaticResource BgSkeletonDeepBrush}"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                CornerRadius="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Пагинация (Нижний лоадер) -->
    <Style Selector="ContentControl.loading-skeletons">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,4,0,24" Opacity="0.5">
                        <StackPanel.Effect>
                            <BlurEffect Radius="3" />
                        </StackPanel.Effect>
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 
        ОБЩИЙ ШАБЛОН СПИСКА (для Initial и Search)
        Используем один стиль StackPanel для идентичности
    -->
    <Style Selector="StackPanel.skeleton-list-container">
        <Setter Property="Spacing" Value="4" />
        <Setter Property="Margin" Value="0,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />

        <!-- Единый Блюр -->
        <Setter Property="Effect">
            <BlurEffect Radius="6" />
        </Setter>

        <!-- Единый Градиент исчезновения снизу -->
        <Setter Property="OpacityMask">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0.0" Color="#FF000000" />
                <GradientStop Offset="0.6" Color="#FF000000" />
                <GradientStop Offset="1.0" Color="#00000000" />
            </LinearGradientBrush>
        </Setter>
    </Style>


    <!-- Начальная загрузка (IsLoading) -->
    <Style Selector="ContentControl.loading-initial">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <!-- Используем общий класс skeleton-list-container + анимацию breathing -->
                    <StackPanel Classes="breathing skeleton-list-container">
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                        <ContentControl Classes="track-skeleton-row" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Styles>