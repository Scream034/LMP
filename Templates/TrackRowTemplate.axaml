<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
        xmlns:asyncImage="using:AsyncImageLoader"
        xmlns:mi="using:Material.Icons.Avalonia">

    <Style Selector="ContentControl.track-row">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="vm:TrackItemViewModel">
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" Background="Transparent" Margin="0,4" Classes="track-grid">
                        
                        <!-- Thumbnail / Play -->
                        <Panel Grid.Column="0" Width="48" Height="48" Margin="0,0,16,0">
                            <Border CornerRadius="4" ClipToBounds="True">
                                <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                            </Border>
                            <Button Command="{Binding PlayCommand}" Classes="play-overlay" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- ИСПРАВЛЕНО: StaticResource BoolToSelector -->
                                <mi:MaterialIcon Kind="{Binding IsPlaying, Converter={StaticResource BoolToSelector}, ConverterParameter=Pause|Play}" 
                                                 Width="24" Height="24" Foreground="White"/>
                            </Button>
                        </Panel>

                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <!-- ИСПРАВЛЕНО: StaticResource BoolToSelector -->
                            <TextBlock Text="{Binding Title}" 
                                       Foreground="{Binding IsCurrentTrack, Converter={StaticResource BoolToSelector}, ConverterParameter='#1DB954|#FFFFFF'}"
                                       FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Download Status -->
                        <Panel Grid.Column="2" Margin="16,0" VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="CheckCircle" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" IsVisible="{Binding IsDownloaded}"/>
                            <ProgressBar Value="{Binding DownloadProgress}" Maximum="1" Width="50" Height="4" IsVisible="{Binding IsDownloading}" Foreground="{StaticResource AccentBrush}"/>
                        </Panel>

                        <!-- Like -->
                        <Button Grid.Column="3" Classes="icon-btn" Command="{Binding ToggleLikeCommand}" Margin="0,0,16,0">
                            <!-- ИСПРАВЛЕНО: StaticResource BoolToSelector (дважды) -->
                            <mi:MaterialIcon Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}"
                                             Width="18" Height="18"
                                             Foreground="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter='#1DB954|#B3B3B3'}"/>
                        </Button>

                        <!-- Duration -->
                        <TextBlock Grid.Column="4" Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Width="50" TextAlignment="Right" Margin="0,0,16,0"/>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Grid.track-grid Button.play-overlay">
        <Setter Property="Opacity" Value="0"/><Setter Property="Background" Value="#80000000"/><Setter Property="Width" Value="48"/><Setter Property="Height" Value="48"/><Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Grid.track-grid:pointerover Button.play-overlay"><Setter Property="Opacity" Value="1"/></Style>
    <Style Selector="Grid.track-grid:pointerover"><Setter Property="Background" Value="{StaticResource BgHighlightBrush}"/></Style>
</Styles>