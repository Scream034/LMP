<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyLiteMusicPlayer.ViewModels"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:asyncImage="using:AsyncImageLoader">

    <Style Selector="ContentControl.track-card">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="vm:TrackItemViewModel">
                    <!-- ФИКС: Фиксированная ширина и Margin -->
                    <Button Command="{Binding PlayCommand}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="8"
                            Width="160"
                            Margin="0,0,8,16"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Cover Image -->
                            <Border Width="144" Height="144" 
                                    CornerRadius="6" 
                                    ClipToBounds="True"
                                    BoxShadow="0 4 8 0 #40000000"
                                    Margin="0,0,0,12">
                                <Panel Background="#282828">
                                    <mi:MaterialIcon Kind="MusicNote" 
                                                     Width="48" Height="48" 
                                                     Foreground="#555"
                                                     IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}"/>
                                    <!-- Оптимизация: Mode=OneTime для URL, так как он редко меняется -->
                                    <Image asyncImage:ImageLoader.Source="{Binding ThumbnailUrl}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}}"/>
                                    
                                    <!-- Overlay Play Button (Hover effect handled in styles) -->
                                    <Panel Classes="hover-overlay" Background="#66000000" IsVisible="{Binding IsHovered}">
                                         <mi:MaterialIcon Kind="PlayCircle" Width="48" Height="48" Foreground="White"/>
                                    </Panel>
                                </Panel>
                            </Border>

                            <!-- Title (Trimming enabled) -->
                            <TextBlock Text="{Binding Title}" 
                                       FontWeight="Bold" 
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       ToolTip.Tip="{Binding Title}"/>

                            <!-- Artist (Trimming enabled) -->
                            <TextBlock Text="{Binding Author}" 
                                       FontSize="12" 
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style Selector="Button:pointerover Border Panel.hover-overlay">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
</Styles>