<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="using:MyLiteMusicPlayer.Converters">

    <conv:TimeSpanToStringConverter x:Key="TimeSpanConverter" />
    <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
    <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    <conv:InverseBoolConverter x:Key="InverseBool" />
    <conv:RepeatModeToIconConverter x:Key="RepeatModeIcon" />
    <conv:VolumeToIconConverter x:Key="VolumeIcon" />
    
    <!-- Важно: регистрируем новый конвертер -->
    <conv:BoolToSelectorConverter x:Key="BoolToSelector" />

</ResourceDictionary>