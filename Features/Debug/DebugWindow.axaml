<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Debug"
    x:Class="LMP.Features.Debug.DebugWindow"
    x:DataType="vm:DebugViewModel"
    Title="Debug Console" Width="1000" Height="800"
    Background="{DynamicResource BgPrimaryBrush}"
    WindowStartupLocation="CenterScreen">

    <TabControl TabStripPlacement="Top" Padding="0">

        <!-- TAB 1: TESTS -->
        <TabItem Header="🧪 Tests">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" DataContext="{Binding TestRunner}">

                <!-- Row 0: Run buttons -->
                <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Command="{Binding RunAllCommand}"
                            Background="#4CAF50" Foreground="White" Padding="10,6"
                            ToolTip.Tip="Run all tests">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource Icon.PlayCircle}" Width="14" Height="14" />
                                <TextBlock Text="Run All" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RunUnitCommand}"
                            Background="#2196F3" Foreground="White" Padding="8,6"
                            ToolTip.Tip="Run unit tests only" FontSize="12">
                            <TextBlock Text="Unit" />
                        </Button>

                        <Button Command="{Binding RunIntegrationCommand}"
                            Background="#FF9800" Foreground="White" Padding="8,6"
                            ToolTip.Tip="Run integration tests" FontSize="12">
                            <TextBlock Text="Integration" />
                        </Button>

                        <Button Command="{Binding RunBenchmarksCommand}"
                            Background="#9C27B0" Foreground="White" Padding="8,6"
                            ToolTip.Tip="Run benchmarks" FontSize="12">
                            <TextBlock Text="Benchmarks" />
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource TextSecondaryBrush}" Margin="2,2" />

                        <Button Command="{Binding RunFilteredCommand}"
                            Background="#00897B" Foreground="White" Padding="10,6"
                            ToolTip.Tip="Run only filtered tests (by current group/category/search)">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource Icon.FilterCheck}" Width="14" Height="14" />
                                <TextBlock Text="Run Filtered" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource TextSecondaryBrush}" Margin="2,2" />

                        <Button Command="{Binding CancelCommand}"
                            Background="#F44336" Foreground="White" Padding="8,6"
                            ToolTip.Tip="Cancel running tests">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource Icon.Stop}" Width="14" Height="14" />
                                <TextBlock Text="Cancel" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ResetCommand}"
                            Padding="6,6" ToolTip.Tip="Reset all results">
                            <PathIcon Data="{StaticResource Icon.Refresh}" Width="14" Height="14" />
                        </Button>

                        <Rectangle Width="1" Fill="{DynamicResource TextSecondaryBrush}" Margin="2,2" />

                        <TextBox Text="{Binding SearchFilter}" Width="180"
                            PlaceholderText="🔍 Filter tests..." VerticalAlignment="Center"
                            FontSize="12" />

                        <Rectangle Width="1" Fill="{DynamicResource TextSecondaryBrush}" Margin="2,2" />

                        <Button Command="{Binding OpenConfigCommand}"
                            Padding="8,6" ToolTip.Tip="Open test-config.json in default editor"
                            Background="#607D8B" Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource Icon.FileEdit}" Width="14" Height="14" />
                                <TextBlock Text="Config" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ReloadConfigCommand}"
                            Padding="6,6" ToolTip.Tip="Reload config from disk">
                            <PathIcon Data="{StaticResource Icon.Reload}" Width="14" Height="14" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Row 1: Group filter buttons -->
                <!--
                    Tag передаёт TestRunnerViewModel в дочерние DataTemplate
                    без явного каста типа в binding-выражении.
                    Это обходит резолюцию типов которая крашит Avalonia 11.2+.
                -->
                <Border Grid.Row="1" Background="{DynamicResource BgElevatedBrush}"
                    Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4"
                        x:Name="GroupFilterPanel"
                        Tag="{Binding}">
                        <TextBlock Text="Group:" VerticalAlignment="Center"
                            FontSize="11" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0" />

                        <Button Command="{Binding ToggleGroupFilterCommand}"
                            CommandParameter="{x:Null}"
                            Padding="8,4" CornerRadius="10" FontSize="11"
                            ToolTip.Tip="Show all groups">
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                </Style>
                            </Button.Styles>
                            <TextBlock Text="All" />
                        </Button>

                        <ItemsControl ItemsSource="{Binding AvailableGroups}"
                            Tag="{Binding #GroupFilterPanel.Tag}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Command="{Binding $parent[ItemsControl].Tag.ToggleGroupFilterCommand}"
                                        CommandParameter="{Binding Name}"
                                        Padding="8,4" CornerRadius="10" FontSize="11"
                                        ToolTip.Tip="{Binding Label}">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            </Style>
                                        </Button.Styles>
                                        <TextBlock Text="{Binding Label}"
                                            FontWeight="{Binding IsSelected,
                                                Converter={StaticResource BoolToFontWeight}}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Row 2: Progress bar -->
                <ProgressBar Grid.Row="2" Value="{Binding Progress}" Maximum="100"
                    Height="3" IsVisible="{Binding IsRunning}"
                    Foreground="{DynamicResource AccentBrush}" />

                <!-- Row 3: Split — Test List | Log -->
                <Grid Grid.Row="3" ColumnDefinitions="*,*">

                    <!-- Left: Test List -->
                    <Border Grid.Column="0" Margin="5"
                        BorderBrush="{DynamicResource BgHighlightBrush}"
                        BorderThickness="1" CornerRadius="4">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding FilteredTests}"
                                Tag="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Command="{Binding $parent[ItemsControl].Tag.RunSingleCommand}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="8,5" Margin="2,1"
                                            Background="Transparent"
                                            CornerRadius="4">
                                            <Grid ColumnDefinitions="22,Auto,Auto,*,Auto,Auto">
                                                <TextBlock Grid.Column="0"
                                                    Text="{Binding StateIcon}"
                                                    Foreground="{Binding StateColor}"
                                                    FontSize="13" FontWeight="Bold"
                                                    VerticalAlignment="Center" />

                                                <Border Grid.Column="1"
                                                    Background="{DynamicResource BgHighlightBrush}"
                                                    CornerRadius="3" Padding="4,1" Margin="0,0,4,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CategoryBadge}"
                                                        FontSize="8" FontWeight="Bold"
                                                        Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Border>

                                                <Border Grid.Column="2"
                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                    CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Group}"
                                                        FontSize="8"
                                                        Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Border>

                                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                        FontSize="11.5"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="🌐" FontSize="9"
                                                        IsVisible="{Binding RequiresNetwork}"
                                                        ToolTip.Tip="Requires network"
                                                        VerticalAlignment="Center" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="4"
                                                    Text="{Binding Duration}"
                                                    FontSize="10" Margin="6,0"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    VerticalAlignment="Center" />

                                                <PathIcon Grid.Column="5"
                                                    Data="{StaticResource Icon.AlertCircle}"
                                                    Width="13" Height="13"
                                                    Foreground="#F44336"
                                                    IsVisible="{Binding ErrorMessage,
                                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="{Binding ErrorMessage}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Right: Log -->
                    <Border Grid.Column="1" Margin="5"
                        BorderBrush="{DynamicResource BgHighlightBrush}"
                        BorderThickness="1" CornerRadius="4">
                        <Grid RowDefinitions="Auto,*">
                            <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="8,4" Spacing="8">
                                <TextBlock Text="Test Log" FontWeight="Bold" FontSize="11"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    VerticalAlignment="Center" />
                                <Button Command="{Binding ClearLogCommand}"
                                    Padding="6,2" FontSize="10">
                                    <TextBlock Text="Clear" />
                                </Button>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1">
                                <SelectableTextBlock Text="{Binding LogOutput}"
                                    Margin="8"
                                    FontFamily="Consolas, monospace"
                                    FontSize="11"
                                    TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Row 4: Summary bar -->
                <Border Grid.Row="4" Background="{DynamicResource BgSecondaryBrush}"
                    Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding Summary}"
                            FontSize="12" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock FontSize="11"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Showing {0} of {1}">
                                    <Binding Path="FilteredTests.Count" />
                                    <Binding Path="AllTests.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 2: YOUTUBE — без изменений -->
        <TabItem Header="📺 YouTube">
            <Grid RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" Padding="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Search Term:" VerticalAlignment="Center" />
                        <TextBox Text="{Binding SearchQuery}" Width="200" VerticalAlignment="Center" />
                        <Button Content="Clear Log" Command="{Binding ClearLogCommand}"
                            Classes="accent accent-base" />
                        <ProgressBar IsIndeterminate="True" Width="100" IsVisible="{Binding IsBusy}" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="10,10,10,5" Spacing="8">
                        <Button Content="1. YT Liked (Videos)"
                            Command="{Binding GetLikedVideosCommand}"
                            Background="#FF4444" Foreground="White" Padding="12,8" />
                        <Button Content="2. YTM Liked (Tracks)"
                            Command="{Binding GetLikedMusicCommand}"
                            Background="#AA0000" Foreground="White" Padding="12,8" />
                        <Button Content="3. YT Search 10 Videos"
                            Command="{Binding SearchVideosCommand}"
                            Background="#4444FF" Foreground="White" Padding="12,8" />
                        <Button Content="4. YTM Search 10 Tracks"
                            Command="{Binding SearchMusicCommand}"
                            Background="#00AAAA" Foreground="White" Padding="12,8" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Margin="10"
                    BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding LogOutput}"
                            Margin="10" FontFamily="Consolas, monospace"
                            FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 3: MEMORY -->
        <TabItem Header="🧠 Memory">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                    Padding="10,8" Margin="10,10,10,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding DumpMemoryCommand}"
                            Background="#9C27B0" Foreground="White" Padding="12,8"
                            ToolTip.Tip="Dump full memory report">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource Icon.Memory}" Width="16" Height="16" />
                                <TextBlock Text="Dump Report" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ForceGcCommand}"
                            Background="#FF9800" Foreground="White" Padding="12,8"
                            ToolTip.Tip="Force aggressive garbage collection">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource Icon.Broom}" Width="16" Height="16" />
                                <TextBlock Text="Force GC" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearCachesCommand}"
                            Background="#F44336" Foreground="White" Padding="12,8"
                            ToolTip.Tip="Clear all memory caches">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource Icon.DeleteSweep}" Width="16" Height="16" />
                                <TextBlock Text="Clear All Caches" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CheckVmLeaksCommand}"
                            Background="#E91E63" Foreground="White" Padding="12,8"
                            ToolTip.Tip="Check TrackVM cache for leaks">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource Icon.BugCheck}" Width="16" Height="16" />
                                <TextBlock Text="Check VM Leaks" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Margin="10"
                    BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding LogOutput}"
                            Margin="10" FontFamily="Consolas, monospace"
                            FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 4: AUDIO -->
        <TabItem Header="🎵 Audio">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource BgHighlightBrush}"
                    Padding="10,8" Margin="10,10,10,0" CornerRadius="6">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Audio Test:" VerticalAlignment="Center"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}" />
                            <TextBox Text="{Binding AudioTestInput}" Width="280"
                                PlaceholderText="YouTube URL or Video ID"
                                VerticalAlignment="Center" />
                            <TextBlock Text="Duration (sec):" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding AudioTestDuration}"
                                Minimum="5" Maximum="60" Width="80"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding PlayYoutubeAudioCommand}"
                                Background="#4CAF50" Foreground="White" Padding="12,8"
                                IsEnabled="{Binding !IsAudioPlaying}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.Play}" Width="16" Height="16" />
                                    <TextBlock Text="Play (No Cache)" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PlayYoutubeWithCacheCommand}"
                                Background="#2196F3" Foreground="White" Padding="12,8"
                                IsEnabled="{Binding !IsAudioPlaying}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.PlayCircle}" Width="16" Height="16" />
                                    <TextBlock Text="Play (With Cache)" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopAudioTestCommand}"
                                Background="#f44336" Foreground="White" Padding="12,8"
                                IsEnabled="{Binding IsAudioPlaying}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.Stop}" Width="16" Height="16" />
                                    <TextBlock Text="Stop" />
                                </StackPanel>
                            </Button>

                            <Rectangle Width="1" Fill="{DynamicResource TextSecondaryBrush}" Margin="4,0" />

                            <Button Command="{Binding ShowCacheStatsCommand}"
                                Background="#607D8B" Foreground="White" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.ChartBar}" Width="16" Height="16" />
                                    <TextBlock Text="Cache Stats" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClearAudioCacheCommand}"
                                Background="#795548" Foreground="White" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.FolderRemove}" Width="16" Height="16" />
                                    <TextBlock Text="Clear Cache" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding TestLocalFileCommand}"
                                Background="#9E9E9E" Foreground="White" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource Icon.FileMusic}" Width="16" Height="16" />
                                    <TextBlock Text="Test Local" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Margin="10"
                    BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding LogOutput}"
                            Margin="10" FontFamily="Consolas, monospace"
                            FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</Window>