<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Playlist"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:controls="using:LMP.UI.Controls"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:LMP.Core.Behaviors"
    x:Class="LMP.Features.Playlist.PlaylistView"
    x:DataType="vm:PlaylistViewModel"
    x:CompileBindings="True">

    <UserControl.Styles>
        <Style Selector="GridSplitter.header-splitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="6" />
            <Setter Property="Cursor" Value="SizeNorthSouth" />
        </Style>
        <Style Selector="GridSplitter.header-splitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Opacity" Value="0.3" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding HeaderHeight, Mode=TwoWay}" MinHeight="220" MaxHeight="340" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
            BorderBrush="{DynamicResource BgHighlightBrush}"
            Background="{DynamicResource BgPrimaryBrush}"
            Padding="24,16">

            <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                HorizontalAlignment="Left" VerticalAlignment="Bottom">

                <Grid RowDefinitions="*, Auto" Width="800">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                        <!-- Cover -->
                        <Border Grid.Column="0" Width="180" Height="180" CornerRadius="8"
                            ClipToBounds="True" Background="{DynamicResource BgSkeletonBrush}"
                            BoxShadow="{StaticResource CardShadow}">
                            <Panel>
                                <mi:MaterialIcon Kind="MusicNote" Width="64" Height="64"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />

                                <Image
                                    controls:QualityImage.Source="{Binding ThumbnailUrl}"
                                    controls:QualityImage.Quality="High"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='http'}" />

                                <Image
                                    Source="{Binding ThumbnailUrl, Converter={StaticResource BitmapAssetConverter}}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding ThumbnailUrl, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='avares'}" />
                            </Panel>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Bottom">
                            <TextBlock Text="PLAYLIST" FontSize="12" FontWeight="Bold"
                                Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1" />

                            <TextBlock Text="{Binding PlaylistName}" FontSize="42"
                                FontWeight="Black"
                                Margin="0,4,0,0" Padding="0,0,0,12" TextWrapping="Wrap" MaxLines="2"
                                ClipToBounds="False" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding FormattedTrackCount}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="•"
                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding FormattedDuration}"
                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16"
                        VerticalAlignment="Center">
                        <Button Classes="play-circle" Command="{Binding PlayAllCommand}" Width="52" Height="52">
                            <Panel>
                                <mi:MaterialIcon Kind="Play" Width="26" Height="26"
                                    Foreground="{DynamicResource TextDarkBrush}"
                                    IsVisible="{Binding !IsPlayingThisPlaylist}" />
                                <mi:MaterialIcon Kind="Pause" Width="26" Height="26"
                                    Foreground="{DynamicResource TextDarkBrush}"
                                    IsVisible="{Binding IsPlayingThisPlaylist}" />
                            </Panel>
                        </Button>

                        <Button Classes="icon-btn" Command="{Binding ShufflePlayCommand}"
                            ToolTip.Tip="{Binding L[Playlist_ShufflePlay]}">
                            <mi:MaterialIcon Kind="ShuffleVariant" Width="22" Height="22"
                                Foreground="{Binding IsShuffleActive, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                        </Button>

                        <Button Classes="icon-btn" Command="{Binding AddToQueueCommand}"
                            ToolTip.Tip="{Binding L[Queue_Add]}">
                            <mi:MaterialIcon Kind="PlaylistPlus" Width="22" Height="22" />
                        </Button>

                        <Button Classes="icon-btn" Command="{Binding DownloadAllCommand}"
                            ToolTip.Tip="Download All">
                            <mi:MaterialIcon Kind="Download" Width="22" Height="22"
                                Foreground="{Binding IsDownloadingActive, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextSecondaryBrush'}" />
                        </Button>

                        <Button Classes="icon-btn" Command="{Binding RefreshPlaylistCommand}"
                            IsVisible="{Binding IsCloud}" ToolTip.Tip="Sync with YouTube">
                            <mi:MaterialIcon Kind="Sync" Width="22" Height="22" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Viewbox>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Row="1"
            Classes="header-splitter"
            ResizeDirection="Rows"
            ResizeBehavior="PreviousAndNext"
            HorizontalAlignment="Stretch" />

        <!-- TEXT FILTER ONLY -->
        <Grid Grid.Row="2" Margin="24,12,24,12">
            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Height="36">
                <Grid ColumnDefinitions="Auto, *">
                    <mi:MaterialIcon Kind="Magnify" Width="16" Height="16"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Margin="12,0,4,0" />

                    <TextBox Grid.Column="1" Classes="filter-ghost"
                        Text="{Binding FilterQuery}"
                        Watermark="{Binding L[Search_LocalFilterTitle]}" />
                </Grid>
            </Border>
        </Grid>

        <!-- LIST -->
        <controls:TrackListControl
            Grid.Row="3"
            Margin="24,0"
            Items="{Binding Items}"
            IsLoading="{Binding IsLoading}"
            IsLoadingMore="{Binding IsLoadingMore}"
            ReachedEnd="{Binding ReachedEnd}"
            LoadMoreCommand="{Binding LoadMoreCommand}"
            UseInternalScroll="True"
            EnableSmoothLoading="{Binding EnableSmoothLoading}"
            IsPlaylistContext="{Binding CanEdit}"
            EnableReordering="{Binding CanReorderItems}"
            MoveItemCommand="{Binding MoveItemCommand}" />
    </Grid>
</UserControl>