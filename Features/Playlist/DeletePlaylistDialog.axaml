<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Playlist"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.Features.Playlist.DeletePlaylistDialog"
    x:DataType="vm:DeletePlaylistDialogViewModel"
    Title="{Binding L[Delete_Title]}"
    Width="420"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="BorderOnly"
    Background="{DynamicResource BgPrimaryBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="24">
        <StackPanel Spacing="20">

            <!-- Заголовок с иконкой -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{DynamicResource SystemErrorBgBrush}"
                    CornerRadius="20"
                    Width="40" Height="40">
                    <mi:MaterialIcon Kind="DeleteOutline"
                        Width="20" Height="20"
                        Foreground="{DynamicResource SystemErrorBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding L[Delete_Title]}"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding PlaylistName}"
                        FontSize="13"
                        Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Описание -->
            <TextBlock Text="{Binding L[Delete_Description]}"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextSecondaryBrush}"
                FontSize="13" />

            <!-- Опции удаления -->
            <StackPanel Spacing="8">
                <!-- Только локально -->
                <Border Background="{DynamicResource BgElevatedBrush}"
                    CornerRadius="8"
                    Padding="12"
                    Cursor="Hand">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
                        </Style>
                    </Border.Styles>
                    <RadioButton IsChecked="{Binding IsLocalOnly}" GroupName="DeleteMode">
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,0,0,0">
                            <mi:MaterialIcon Kind="FolderRemove"
                                Width="24" Height="24"
                                Foreground="{DynamicResource TextSecondaryBrush}" />
                            <StackPanel>
                                <TextBlock Text="{Binding L[Delete_LocalOnly]}"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding L[Delete_LocalOnlyHint]}"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </Border>

                <!-- Удалить везде (только если есть связь с облаком) -->
                <Border Background="{DynamicResource BgElevatedBrush}"
                    CornerRadius="8"
                    Padding="12"
                    Cursor="Hand"
                    IsVisible="{Binding CanDeleteFromCloud}">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
                        </Style>
                    </Border.Styles>
                    <RadioButton IsChecked="{Binding IsDeleteEverywhere}" GroupName="DeleteMode">
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,0,0,0">
                            <mi:MaterialIcon Kind="CloudOff"
                                Width="24" Height="24"
                                Foreground="{DynamicResource SystemErrorBrush}" />
                            <StackPanel>
                                <TextBlock Text="{Binding L[Delete_Everywhere]}"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding L[Delete_EverywhereHint]}"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </Border>
            </StackPanel>

            <!-- Кнопки -->
            <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,8,0,0">
                <Panel />
                <Button Grid.Column="1"
                    Content="{Binding L[Button_Cancel]}"
                    Command="{Binding CancelCommand}"
                    MinWidth="80"
                    Margin="0,0,12,0" />
                <Button Grid.Column="2"
                    Content="{Binding L[Button_Delete]}"
                    Command="{Binding ConfirmCommand}"
                    MinWidth="100"
                    Background="{DynamicResource SystemErrorBrush}"
                    Foreground="White" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
