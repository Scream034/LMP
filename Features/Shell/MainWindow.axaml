<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="using:MyLiteMusicPlayer.Features.Shell"
    xmlns:home="using:MyLiteMusicPlayer.Features.Home"
    xmlns:search="using:MyLiteMusicPlayer.Features.Search"
    xmlns:lib="using:MyLiteMusicPlayer.Features.Library"
    xmlns:settings="using:MyLiteMusicPlayer.Features.Settings"
    xmlns:playlist="using:MyLiteMusicPlayer.Features.Playlist"
    xmlns:player="using:MyLiteMusicPlayer.Features.Player"
    xmlns:views="using:MyLiteMusicPlayer.Features.Shell"
    xmlns:homeV="using:MyLiteMusicPlayer.Features.Home"
    xmlns:searchV="using:MyLiteMusicPlayer.Features.Search"
    xmlns:libV="using:MyLiteMusicPlayer.Features.Library"
    xmlns:settingsV="using:MyLiteMusicPlayer.Features.Settings"
    xmlns:playlistV="using:MyLiteMusicPlayer.Features.Playlist"
    xmlns:playerV="using:MyLiteMusicPlayer.Features.Player"
    xmlns:playerBarV="using:MyLiteMusicPlayer.Features.Player"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="MyLiteMusicPlayer.Features.Shell.MainWindow"
    x:DataType="shell:MainWindowViewModel"
    Title="Lite Music Player"
    Width="1200" Height="800"
    MinWidth="900" MinHeight="600"
    Background="{StaticResource BgPrimaryBrush}"
    WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*, Auto">

        <!-- Main Content Grid -->
        <Grid Grid.Row="0" ColumnDefinitions="240, *">

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource BgSecondaryBrush}"
                Padding="16,16,16,16">
                <Panel>
                    <!-- Sidebar Items (Navigation) -->
                    <Grid RowDefinitions="Auto, Auto, *, Auto">
                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12"
                            Margin="4,4,4,28">
                            <mi:MaterialIcon Kind="Music" Width="36" Height="36"
                                Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="LitePlayer" FontSize="22" FontWeight="Bold"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <!-- Nav Buttons -->
                        <StackPanel Grid.Row="1" Spacing="6">
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Home'}"
                                Command="{Binding NavigateCommand}" CommandParameter="Home"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="Home" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Home]}"
                                        VerticalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Search'}"
                                Command="{Binding NavigateCommand}" CommandParameter="Search"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="Magnify" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Search]}"
                                        VerticalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Library'}"
                                Command="{Binding NavigateCommand}" CommandParameter="Library"
                                IsEnabled="{Binding !IsNavigationLocked}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="BookMusic" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Library]}"
                                        VerticalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>

                            <!-- кнопка Очереди -->
                           <Button Classes="sidebar-btn" Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Queue'}" Command="{Binding NavigateCommand}" CommandParameter="Queue" IsEnabled="{Binding !IsNavigationLocked}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="PlaylistPlay" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Queue]}" VerticalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>

                            <Button Classes="sidebar-btn active"
                                IsVisible="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Playlist'}"
                                IsEnabled="False" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <mi:MaterialIcon Kind="PlaylistMusic" Width="24" Height="24" />
                                    <TextBlock Text="{Binding L[Nav_Playlist]}"
                                        VerticalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Panel Grid.Row="2" />

                        <!-- Settings -->
                        <Button Grid.Row="3" Classes="sidebar-btn"
                            Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Settings'}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            IsEnabled="{Binding !IsNavigationLocked}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <mi:MaterialIcon Kind="Cog" Width="24" Height="24" />
                                <TextBlock Text="{Binding L[Nav_Settings]}"
                                    VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- === LOCK OVERLAY === -->
                    <Border IsVisible="{Binding IsNavigationLocked}" Background="#FA121212"
                        CornerRadius="8" Margin="-16" ClipToBounds="True">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="24">
                                <Panel Width="80" Height="80" HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" CornerRadius="40"
                                        Background="{StaticResource AccentBrush}" />
                                    <mi:MaterialIcon Kind="CloudSync" Width="40" Height="40"
                                        Foreground="{StaticResource TextDarkBrush}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Panel>
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NavigationLockReason}" FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        TextAlignment="Center" />
                                    <TextBlock Text="{Binding L[Nav_PleaseWait]}" FontSize="13"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        TextAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Panel>
            </Border>

            <!-- CONTENT AREA -->
            <Border Grid.Column="1" Background="{StaticResource BgPrimaryBrush}" ClipToBounds="True">
                <Panel>
                    <ContentControl Content="{Binding CurrentPage}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.DataTemplates>
                                        <DataTemplate DataType="{x:Type homeV:HomeViewModel}">
                                            <homeV:HomeView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type searchV:SearchViewModel}">
                                            <searchV:SearchView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type libV:LibraryViewModel}">
                                            <libV:LibraryView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type settingsV:SettingsViewModel}">
                                            <settingsV:SettingsView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type playlistV:PlaylistViewModel}">
                                            <playlistV:PlaylistView />
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type playerV:QueueViewModel}">
                                            <playerV:QueueView />
                                        </DataTemplate>
                                    </ContentControl.DataTemplates>
                                </ContentControl>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <Border IsVisible="{Binding IsNavigationLocked}" Background="#60000000"
                        IsHitTestVisible="True" />
                </Panel>
            </Border>
        </Grid>

        <!-- PLAYER BAR -->
        <playerBarV:PlayerBarView Grid.Row="1" DataContext="{Binding PlayerBar}"
            IsVisible="{Binding HasTrack}" />

    </Grid>
</Window>
