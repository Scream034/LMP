<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="using:LMP.Features.Shell"
    xmlns:home="using:LMP.Features.Home"
    xmlns:search="using:LMP.Features.Search"
    xmlns:lib="using:LMP.Features.Library"
    xmlns:settings="using:LMP.Features.Settings"
    xmlns:playlist="using:LMP.Features.Playlist"
    xmlns:player="using:LMP.Features.Player"
    xmlns:notifications="using:LMP.Features.Notifications"
    xmlns:homeV="using:LMP.Features.Home"
    xmlns:searchV="using:LMP.Features.Search"
    xmlns:libV="using:LMP.Features.Library"
    xmlns:settingsV="using:LMP.Features.Settings"
    xmlns:playlistV="using:LMP.Features.Playlist"
    xmlns:playerV="using:LMP.Features.Player"
    xmlns:playerBarV="using:LMP.Features.Player"
    xmlns:mi="using:Material.Icons.Avalonia"
    x:Class="LMP.Features.Shell.MainWindow"
    x:DataType="shell:MainWindowViewModel"
    Title="Lite Music Player"
    Width="1200" Height="800"
    MinWidth="900" MinHeight="600"
    Background="{DynamicResource BgPrimaryBrush}"
    WindowStartupLocation="CenterScreen"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="-1"
    SystemDecorations="BorderOnly">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ═══ TITLE BAR + NAVIGATION (46px) ═══ -->
        <Grid Grid.Row="0" Height="46" Background="{DynamicResource BgSecondaryBrush}"
            ColumnDefinitions="Auto, Auto, *, Auto, Auto" Name="TitleBar">

            <!-- Col 0: App Logo (toggle version) + Version info (clickable → GitHub) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Logo Button (toggle version visibility) -->
                <Button Background="Transparent" BorderThickness="0"
                    Padding="12,0,8,0" Margin="0" VerticalAlignment="Stretch"
                    Cursor="Hand" Name="AppLogoButton"
                    Command="{Binding ToggleVersionInfoCommand}"
                    ToolTip.Tip="{Binding L[Common_AppName]}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </Button.Styles>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Grid Width="24" Height="24">
                            <Border Width="24" Height="24" CornerRadius="4"
                                Background="{DynamicResource AccentBrush}" Opacity="0.15" />
                            <Path Data="M8,5 L19,12 L8,19 Z"
                                Fill="{DynamicResource AccentBrush}"
                                Stretch="Uniform" Width="12" Height="12"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="4,0,0,0" />
                            <StackPanel Orientation="Horizontal" Spacing="-2"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,1,3">
                                <Path Data="M0,0 L4,4 L0,8"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="1.5" StrokeLineCap="Round"
                                    Width="5" Height="8" Stretch="Uniform" />
                                <Path Data="M0,0 L4,4 L0,8"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="1.5" StrokeLineCap="Round"
                                    Width="5" Height="8" Stretch="Uniform" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="LMP" FontSize="12" FontWeight="Bold"
                            VerticalAlignment="Center" LetterSpacing="2"
                            Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </Button>

                <!-- Version Info (clickable → GitHub, toggleable) -->
                <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0" Margin="0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsVersionInfoVisible}"
                    Cursor="Hand"
                    Command="{Binding OpenGitHubCommand}"
                    ToolTip.Tip="{Binding L[Common_OpenGitHub]}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="Button:pointerover StackPanel">
                            <Setter Property="Opacity" Value="0.8" />
                        </Style>
                        <Style Selector="Button:pointerover TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Style>
                    </Button.Styles>

                    <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.5">
                        <Border Width="1" Height="12"
                            Background="{DynamicResource BgHighlightBrush}"
                            Margin="4,0" />
                        <TextBlock Text="{Binding VersionDisplay}"
                            FontSize="10" FontFamily="Consolas, monospace"
                            Foreground="{DynamicResource TextMutedBrush}"
                            VerticalAlignment="Center" />
                        <TextBlock Text="{Binding GitHashDisplay}"
                            FontSize="10" FontFamily="Consolas, monospace"
                            Foreground="{DynamicResource TextMutedBrush}"
                            VerticalAlignment="Center" Opacity="0.7" />
                        <TextBlock Text="{Binding CommitsDisplay}"
                            FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}"
                            VerticalAlignment="Center" Opacity="0.5" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Col 1: Navigation Tabs -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0"
                VerticalAlignment="Stretch" Margin="8,0,0,0">

                <Border Width="1" Height="20"
                    Background="{DynamicResource BgHighlightBrush}"
                    Margin="0,0,4,0" VerticalAlignment="Center" />

                <Button Classes="nav-tab"
                    Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Home'}"
                    Command="{Binding NavigateCommand}" CommandParameter="Home"
                    IsEnabled="{Binding !IsNavigationLocked}"
                    ToolTip.Tip="{Binding L[Nav_Home_Tip]}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Home" />
                        <TextBlock Text="{Binding L[Nav_Home]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="nav-tab"
                    Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Search'}"
                    Command="{Binding NavigateCommand}" CommandParameter="Search"
                    IsEnabled="{Binding !IsNavigationLocked}"
                    ToolTip.Tip="{Binding L[Nav_Search_Tip]}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Magnify" />
                        <TextBlock Text="{Binding L[Nav_Search]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="nav-tab"
                    Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Library'}"
                    Command="{Binding NavigateCommand}" CommandParameter="Library"
                    IsEnabled="{Binding !IsNavigationLocked}"
                    ToolTip.Tip="{Binding L[Nav_Library_Tip]}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="BookMusic" />
                        <TextBlock Text="{Binding L[Nav_Library]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="nav-tab"
                    Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Queue'}"
                    Command="{Binding NavigateCommand}" CommandParameter="Queue"
                    IsEnabled="{Binding !IsNavigationLocked}"
                    ToolTip.Tip="{Binding L[Nav_Queue_Tip]}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="PlaylistPlay" />
                        <TextBlock Text="{Binding L[Nav_Queue]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="nav-tab"
                    Classes.active="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Settings'}"
                    Command="{Binding NavigateCommand}" CommandParameter="Settings"
                    IsEnabled="{Binding !IsNavigationLocked}"
                    ToolTip.Tip="{Binding L[Nav_Settings_Tip]}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Cog" />
                        <TextBlock Text="{Binding L[Nav_Settings]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="nav-tab active"
                    IsVisible="{Binding CurrentPageName, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='Playlist'}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="PlaylistMusic" />
                        <TextBlock Text="{Binding L[Nav_Playlist]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Col 2: Drag Area -->
            <Border Grid.Column="2" Background="Transparent" Name="DragArea" />

            <!-- Col 3: Notification Button -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                Margin="0,0,4,0">
                <notifications:NotificationButton DataContext="{Binding NotificationButton}"
                    x:Name="NotificationButtonControl" />
            </StackPanel>

            <!-- Col 4: Window Controls -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" Margin="0,0,4,0">
                <Border Width="1" Height="16"
                    Background="{DynamicResource BgHighlightBrush}"
                    Margin="4,0" VerticalAlignment="Center" />

                <Button Classes="window-btn" Name="MinimizeButton"
                    ToolTip.Tip="{Binding L[Window_Minimize]}">
                    <Border Width="10" Height="1" Background="{DynamicResource TextMutedBrush}"
                        VerticalAlignment="Center" CornerRadius="0.5" />
                </Button>

                <Button Classes="window-btn" Name="MaximizeButton"
                    ToolTip.Tip="{Binding L[Window_Maximize]}">
                    <Panel>
                        <Border Width="10" Height="10" BorderThickness="1.2" CornerRadius="1"
                            BorderBrush="{DynamicResource TextMutedBrush}"
                            Name="MaximizeIcon" />
                        <Grid Name="RestoreIcon" IsVisible="False" Width="12" Height="12">
                            <Border Width="8" Height="8" BorderThickness="1.2" CornerRadius="1"
                                BorderBrush="{DynamicResource TextMutedBrush}"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                            <Border Width="8" Height="8" BorderThickness="1.2" CornerRadius="1"
                                BorderBrush="{DynamicResource TextMutedBrush}"
                                Background="{DynamicResource BgSecondaryBrush}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" />
                        </Grid>
                    </Panel>
                </Button>

                <Button Classes="window-btn window-btn-close" Name="CloseButton"
                    ToolTip.Tip="{Binding L[Window_Close]}">
                    <Grid Width="10" Height="10">
                        <Line StartPoint="0,0" EndPoint="10,10"
                            Stroke="{DynamicResource TextMutedBrush}"
                            StrokeThickness="1.2" StrokeLineCap="Round" />
                        <Line StartPoint="10,0" EndPoint="0,10"
                            Stroke="{DynamicResource TextMutedBrush}"
                            StrokeThickness="1.2" StrokeLineCap="Round" />
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ MAIN CONTENT (обновить секцию Grid.Row="1") ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource BgPrimaryBrush}" ClipToBounds="True">
            <Panel>
                <!-- Страницы контента -->
                <TransitioningContentControl Content="{Binding CurrentPage}"
                    IsTransitionReversed="False">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.15" />
                    </TransitioningContentControl.PageTransition>
                    <TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.DataTemplates>
                                    <DataTemplate DataType="{x:Type homeV:HomeViewModel}">
                                        <homeV:HomeView />
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type searchV:SearchViewModel}">
                                        <searchV:SearchView />
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type libV:LibraryViewModel}">
                                        <libV:LibraryView />
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type settingsV:SettingsViewModel}">
                                        <settingsV:SettingsView />
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type playlistV:PlaylistViewModel}">
                                        <playlistV:PlaylistView />
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type playerV:QueueViewModel}">
                                        <playerV:QueueView />
                                    </DataTemplate>
                                </ContentControl.DataTemplates>
                            </ContentControl>
                        </DataTemplate>
                    </TransitioningContentControl.ContentTemplate>
                </TransitioningContentControl>

                <!-- Navigation Lock Overlay (сетевые операции) -->
                <Border IsVisible="{Binding IsNavigationLocked}" Background="#60000000"
                    IsHitTestVisible="True">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                        <Panel Width="80" Height="80" HorizontalAlignment="Center">
                            <Border Width="80" Height="80" CornerRadius="40"
                                Background="{DynamicResource AccentBrush}" />
                            <mi:MaterialIcon Kind="CloudSync" Width="40" Height="40"
                                Foreground="{DynamicResource TextDarkBrush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Panel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding NavigationLockReason}" FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                TextAlignment="Center" />
                            <TextBlock Text="{Binding L[Nav_PleaseWait]}" FontSize="13"
                                Foreground="{DynamicResource TextMutedBrush}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Dialog Host (ZIndex: 900) — над контентом, под TopBar ═══ -->
                <shell:DialogHost DataContext="{Binding DialogHost}"
                    ZIndex="900"
                    IsVisible="{Binding HasActiveDialog}" />

                <!-- Toast Overlay (ZIndex: 1000) -->
                <notifications:ToastOverlay DataContext="{Binding ToastOverlay}" ZIndex="1000" />
            </Panel>
        </Border>

        <!-- PLAYER BAR -->
        <playerBarV:PlayerBarView Grid.Row="2" DataContext="{Binding PlayerBar}"
            IsVisible="{Binding HasTrack}" />

        <!-- NOTIFICATION PANEL POPUP -->
        <Popup Grid.Row="0" Grid.RowSpan="3"
            PlacementTarget="{Binding #NotificationButtonControl}"
            Placement="BottomEdgeAlignedRight"
            IsOpen="{Binding NotificationButton.IsPanelOpen, Mode=TwoWay}"
            IsLightDismissEnabled="True"
            HorizontalOffset="-8"
            VerticalOffset="8">
            <notifications:NotificationPanel DataContext="{Binding NotificationPanel}" />
        </Popup>

        <!-- TOAST CANVAS (ZIndex: 2000) — позиционируется у курсора -->
        <Canvas x:Name="CopyHintCanvas"
            Grid.Row="0" Grid.RowSpan="3"
            ZIndex="2000"
            IsHitTestVisible="False">

            <Border x:Name="CopyHintOverlay"
                Padding="10,7"
                Background="{DynamicResource BgElevatedBrush}"
                BorderThickness="1"
                CornerRadius="8"
                BoxShadow="0 4 20 0 #70000000"
                MaxWidth="260"
                IsVisible="False"
                Opacity="0">

                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                    </Transitions>
                </Border.Transitions>

                <StackPanel Orientation="Horizontal" Spacing="7">
                    <mi:MaterialIcon x:Name="CopyHintIcon"
                        Width="14" Height="14"
                        VerticalAlignment="Center" />
                    <TextBlock x:Name="CopyHintText"
                        FontSize="12"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        TextWrapping="Wrap"
                        MaxWidth="200"
                        MaxLines="2" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>