<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:LMP.Features.Settings.Controls"
             x:Class="LMP.Features.Settings.Controls.ColorPickerPopup"
             x:Name="Root"
             Width="280">

    <UserControl.Styles>
        <Style Selector="Button.preset-color">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.preset-color:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style Selector="Slider.color-slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="Height" Value="24"/>
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BgHighlightBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            BoxShadow="0 8 24 0 #40000000">
        
        <StackPanel Spacing="4">
            
            <!-- Preview & HEX Input -->
            <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,8">
                <Border Width="48" Height="48" CornerRadius="6"
                        BorderThickness="1" BorderBrush="{DynamicResource BgHighlightBrush}">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding SelectedColor, ElementName=Root}"/>
                    </Border.Background>
                </Border>
                
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="HEX" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBox x:Name="HexTextBox"
                             Text="{Binding HexInput, ElementName=Root, Mode=TwoWay}"
                             FontFamily="Consolas, monospace"
                             FontSize="14"
                             Watermark="#RRGGBB"
                             MaxLength="9"
                             Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Preset Colors -->
            <TextBlock Classes="section-header" Text="PRESETS"/>
            <ItemsControl x:Name="PresetsControl" ItemsSource="{Binding PresetColors, ElementName=Root}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="controls:ColorPreset">
                        <Button Classes="preset-color"
                                Background="{Binding Brush}"
                                Click="OnPresetClick"
                                Tag="{Binding Color}"
                                ToolTip.Tip="{Binding Name}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- RGB Sliders -->
            <TextBlock Classes="section-header" Text="RGB"/>
            
            <Grid ColumnDefinitions="24, *, 40">
                <TextBlock Text="R" VerticalAlignment="Center" Foreground="#FF6B6B" FontWeight="Bold"/>
                <Slider Grid.Column="1" Classes="color-slider" 
                        Value="{Binding RedValue, ElementName=Root, Mode=TwoWay}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding RedValue, ElementName=Root}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas"/>
            </Grid>
            
            <Grid ColumnDefinitions="24, *, 40">
                <TextBlock Text="G" VerticalAlignment="Center" Foreground="#4ECB71" FontWeight="Bold"/>
                <Slider Grid.Column="1" Classes="color-slider" 
                        Value="{Binding GreenValue, ElementName=Root, Mode=TwoWay}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding GreenValue, ElementName=Root}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas"/>
            </Grid>
            
            <Grid ColumnDefinitions="24, *, 40">
                <TextBlock Text="B" VerticalAlignment="Center" Foreground="#5B9BD5" FontWeight="Bold"/>
                <Slider Grid.Column="1" Classes="color-slider" 
                        Value="{Binding BlueValue, ElementName=Root, Mode=TwoWay}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding BlueValue, ElementName=Root}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas"/>
            </Grid>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*, 8, *" Margin="0,16,0,0">
                <Button Grid.Column="0" Content="Cancel" Click="OnCancelClick"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2" Classes="primary-btn" Content="OK" Click="OnConfirmClick"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </Grid>
            
        </StackPanel>
    </Border>
</UserControl>