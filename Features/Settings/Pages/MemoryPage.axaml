<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Settings"
    x:Class="LMP.Features.Settings.Pages.MemoryPage"
    x:DataType="vm:SettingsViewModel"
    x:CompileBindings="True">

    <StackPanel Margin="32,24">
        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
            <PathIcon Grid.Column="0" Data="{StaticResource Icon.Memory}"
                Width="20" Height="20" VerticalAlignment="Center"
                Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Grid.Column="1" Classes="h2"
                Text="{Binding L[Settings_Memory]}"
                VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>

        <Border Classes="card">
            <StackPanel Spacing="20">

                <!-- ── GPU texture cache ── -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Settings_GpuTextureCache]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Settings_GpuTextureCacheDesc]}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                        ItemsSource="{Binding GpuCachePresets}"
                        SelectedItem="{Binding SelectedGpuCachePreset}"
                        MinWidth="180" />
                </Grid>

                <Border Background="{DynamicResource SystemWarnOrangeBrush}"
                    CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding GpuCacheRestartRequired}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource Icon.Refresh}"
                            Width="14" Height="14"
                            Foreground="{DynamicResource TextDarkBrush}" />
                        <TextBlock Foreground="{DynamicResource TextDarkBrush}"
                            FontWeight="SemiBold" FontSize="12"
                            Text="{Binding L[Settings_RestartRequired]}" />
                    </StackPanel>
                </Border>

                <Separator Background="{DynamicResource BgHighlightBrush}" Height="1" />

                <!-- ── Auto cleanup ── -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Settings_AutoMemoryCleanup]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Settings_AutoMemoryCleanupDesc]}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding AutoMemoryCleanupEnabled}" />
                </Grid>

                <Grid ColumnDefinitions="*, 200, 80"
                    IsEnabled="{Binding AutoMemoryCleanupEnabled}">
                    <StackPanel>
                        <TextBlock Classes="label"
                            Text="{Binding L[Settings_MemoryCleanupInterval]}" />
                        <TextBlock Classes="desc"
                            Text="{Binding L[Settings_MemoryCleanupIntervalDesc]}" />
                    </StackPanel>
                    <Slider Grid.Column="1" Minimum="5" Maximum="120"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        Value="{Binding MemoryCleanupIntervalMinutes}"
                        Margin="12,0" />
                    <TextBlock Grid.Column="2" Classes="value-label"
                        Text="{Binding MemoryCleanupIntervalMinutes,
                                          StringFormat='{}{0} min'}" />
                </Grid>

                <!-- ── Pressure threshold ── -->
                <Grid ColumnDefinitions="*, 200, 80">
                    <StackPanel>
                        <TextBlock Classes="label"
                            Text="{Binding L[Settings_MemoryPressureThreshold]}" />
                        <TextBlock Classes="desc"
                            Text="{Binding L[Settings_MemoryPressureThresholdDesc]}" />
                    </StackPanel>
                    <Slider Grid.Column="1" Minimum="200" Maximum="800"
                        TickFrequency="50" IsSnapToTickEnabled="True"
                        Value="{Binding MemoryPressureThresholdMb}"
                        Margin="12,0" />
                    <TextBlock Grid.Column="2" Classes="value-label"
                        Text="{Binding MemoryPressureThresholdMb,
                                          StringFormat='{}{0} MB'}" />
                </Grid>

                <Separator Background="{DynamicResource BgHighlightBrush}" Height="1" />

                <!-- ── Manual cleanup ── -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{Binding L[Settings_ManualCleanup]}" />
                        <TextBlock Classes="desc" Text="{Binding L[Settings_ManualCleanupDesc]}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                        Content="{Binding L[Settings_CleanupNow]}"
                        Command="{Binding CleanupMemoryNowCommand}" />
                </Grid>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>