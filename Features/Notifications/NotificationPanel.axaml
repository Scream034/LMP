<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:notifications="using:LMP.Features.Notifications"
             xmlns:models="using:LMP.Core.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="LMP.Features.Notifications.NotificationPanel"
             x:DataType="notifications:NotificationPanelViewModel">

    <UserControl.Styles>

        <!-- ═══ Карточка уведомления ═══ -->
        <Style Selector="Border.notification-card">
            <Setter Property="Background" Value="{DynamicResource BgHoverTransparentBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.notification-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        </Style>

        <!-- ═══ Severity-индикатор ═══ -->
        <Style Selector="Border.severity-strip">
            <Setter Property="Width" Value="3" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2,12,2" />
        </Style>

        <!-- ═══ Блок рекомендации ═══ -->
        <Style Selector="Border.recommendation-block">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <!-- ═══ Трек-информация ═══ -->
        <Style Selector="Border.track-info-block">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <!-- ═══ Attempt row ═══ -->
        <Style Selector="Border.attempt-row">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Background" Value="{DynamicResource BgHoverTransparentBrush}" />
        </Style>
        <Style Selector="Border.attempt-row:pointerover">
            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        </Style>

        <!-- ═══ Expander стили ═══ -->
        <Style Selector="Expander.details-expander">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

    </UserControl.Styles>

    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BgHighlightBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Width="400"
            MaxHeight="580"
            BoxShadow="0 8 32 0 #50000000"
            ClipToBounds="True">

        <Grid RowDefinitions="Auto, *">

            <!-- ═══ ШАПКА ═══ -->
            <Border Grid.Row="0"
                    Padding="20,16,16,14"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BgHighlightBrush}">
                <Grid ColumnDefinitions="*, Auto">

                    <!-- Заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="BellOutline" Width="18" Height="18"
                                         Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding L[Nav_Notifications]}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Кнопка "Очистить все" -->
                    <Button Grid.Column="1" Classes="ghost-btn"
                            Command="{Binding ClearAllCommand}"
                            IsVisible="{Binding HasNotifications}"
                            ToolTip.Tip="{Binding L[Notification_Clear]}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="NotificationClearAll" Width="16" Height="16"
                                             Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ ТЕЛО: Список / Пустое состояние ═══ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,6,0,8">
                <Panel>

                    <!-- ── Пустое состояние ── -->
                    <StackPanel IsVisible="{Binding !HasNotifications}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Margin="0,48">
                        <Border Width="72" Height="72" CornerRadius="36"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BgHighlightBrush}">
                            <mi:MaterialIcon Kind="BellSleepOutline"
                                             Width="32" Height="32"
                                             Foreground="{DynamicResource TextMutedBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Opacity="0.6" />
                        </Border>
                        <TextBlock Text="{Binding L[Notification_NoNotifications]}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Opacity="0.8" />
                    </StackPanel>

                    <!-- ── Список уведомлений ── -->
                    <ItemsControl ItemsSource="{Binding Notifications}"
                                  IsVisible="{Binding HasNotifications}"
                                  Tag="{Binding}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Notification}">
                                <Border Classes="notification-card">
                                    <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                                        <Border Grid.Column="0" Classes="severity-strip">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Severity, Converter={StaticResource SeverityToColor}}" />
                                            </Border.Background>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Width="36" Height="36"
                                                CornerRadius="10"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Top">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Severity, Converter={StaticResource SeverityToColor}}"
                                                                 Opacity="0.1" />
                                            </Border.Background>
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2" Spacing="2"
                                                    MinWidth="0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0"
                                                       LineHeight="18" />

                                            <!-- ── Трек-информация ── -->
                                            <Border Classes="track-info-block"
                                                    IsVisible="{Binding TrackTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <mi:MaterialIcon Grid.Column="0"
                                                                     Kind="MusicNote"
                                                                     Width="13" Height="13"
                                                                     Foreground="{DynamicResource TextMutedBrush}"
                                                                     Margin="0,1,6,0"
                                                                     VerticalAlignment="Top" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding TrackTitle}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="16" />
                                                    <Button Grid.Column="2"
                                                            Classes="ghost-btn"
                                                            Command="{Binding $parent[ItemsControl].((notifications:NotificationPanelViewModel)Tag).CopyTrackUrlCommand}"
                                                            CommandParameter="{Binding TrackId}"
                                                            VerticalAlignment="Top"
                                                            Margin="6,0,0,0"
                                                            ToolTip.Tip="{Binding $parent[ItemsControl].((notifications:NotificationPanelViewModel)Tag).L[Notification_CopyTrackUrl]}">
                                                        <mi:MaterialIcon Kind="LinkVariant"
                                                                         Width="14" Height="14"
                                                                         Foreground="{DynamicResource AccentBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- ── Рекомендация ── -->
                                            <Border Classes="recommendation-block"
                                                    IsVisible="{Binding HasRecommendation}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding Severity, Converter={StaticResource SeverityToColor}}"
                                                                     Opacity="0.06" />
                                                </Border.Background>
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <mi:MaterialIcon Grid.Column="0"
                                                                     Kind="LightbulbOnOutline"
                                                                     Width="14" Height="14"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     Margin="0,1,8,0"
                                                                     VerticalAlignment="Top" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Recommendation}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="17"
                                                               Opacity="0.9" />
                                                </Grid>
                                            </Border>

                                            <!-- ── Детали (Expander) ── -->
                                            <Expander Classes="details-expander"
                                                      IsVisible="{Binding HasDetails}">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <mi:MaterialIcon Kind="ChevronDown"
                                                                         Width="14" Height="14"
                                                                         Foreground="{DynamicResource AccentBrush}" />
                                                        <TextBlock Text="{Binding $parent[ItemsControl].((notifications:NotificationPanelViewModel)Tag).L[Notification_ViewDetails]}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   Cursor="Hand" />
                                                    </StackPanel>
                                                </Expander.Header>

                                                <StackPanel Spacing="4" Margin="0,8,0,0">
                                                    <ItemsControl ItemsSource="{Binding Attempts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:AttemptRecord}">
                                                                <Border Classes="attempt-row">
                                                                    <Grid ColumnDefinitions="Auto, Auto, *" Margin="0,1">
                                                                        <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Top" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding ClientName}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Top" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding DisplayMessage}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Button Classes="ghost-btn"
                                                            IsVisible="{Binding ExceptionDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                            Command="{Binding $parent[ItemsControl].((notifications:NotificationPanelViewModel)Tag).CopyErrorCommand}"
                                                            CommandParameter="{Binding ExceptionDetails}"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,4,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <mi:MaterialIcon Kind="ContentCopy" Width="13" Height="13" Foreground="{DynamicResource TextMutedBrush}" />
                                                            <TextBlock Text="{Binding $parent[ItemsControl].((notifications:NotificationPanelViewModel)Tag).L[Notification_CopyError]}"
                                                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Expander>

                                        </StackPanel>

                                        <!-- ── Время ── -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TimeAgo}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="12,2,0,0"
                                                   VerticalAlignment="Top"
                                                   TextAlignment="Right"
                                                   Opacity="0.7" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Panel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
