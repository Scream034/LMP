<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:notifications="using:LMP.Features.Notifications"
    xmlns:models="using:LMP.Core.Models"
    xmlns:controls="using:LMP.UI.Controls"
    x:Class="LMP.Features.Notifications.NotificationPanel"
    x:DataType="notifications:NotificationPanelViewModel">

    <UserControl.Styles>
        <Style Selector="Border.notification-card">
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgElevatedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.notification-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="Border.skeleton-card">
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="6,2" />
        </Style>

        <!-- Плашка-заглушка внутри скелетона -->
        <Style Selector="Border.skeleton-line">
            <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Height" Value="10" />
        </Style>

        <!-- Круглая заглушка иконки -->
        <Style Selector="Border.skeleton-icon">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style Selector="Border.severity-strip">
            <Setter Property="Width" Value="3" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2,12,2" />
        </Style>

        <Style Selector="Border.recommendation-block">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2,0,0,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style Selector="Border.track-info-block">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="0,6,0,0" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style Selector="Border.attempt-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightTransparentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Expander.details-expander">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource BgElevatedBrush}"
        BorderBrush="{DynamicResource BgHighlightBrush}"
        BorderThickness="1"
        CornerRadius="14"
        Width="400"
        MaxHeight="560"
        BoxShadow="0 8 32 0 #50000000"
        ClipToBounds="True">

        <Grid RowDefinitions="Auto, *">

            <!-- ═══ ШАПКА — рендерится мгновенно ═══ -->
            <Border Grid.Row="0"
                Padding="16,14,12,12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BgHighlightBrush}">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource Icon.BellOutline}"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding L[Nav_Notifications]}"
                            FontSize="14" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                        Classes="ghost-btn"
                        Command="{Binding ClearAllCommand}"
                        IsVisible="{Binding HasNotifications}"
                        ToolTip.Tip="{Binding L[Notification_Clear]}">
                        <PathIcon Data="{StaticResource Icon.NotificationClearAll}"
                            Width="15" Height="15"
                            Foreground="{DynamicResource TextMutedBrush}" />
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ ТЕЛО ═══ -->
            <Grid Grid.Row="1">

                <!-- ── Пустое состояние ── -->
                <StackPanel IsVisible="{Binding !HasNotifications}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,40">
                    <Border Width="60" Height="60"
                        CornerRadius="30"
                        HorizontalAlignment="Center"
                        BorderBrush="{DynamicResource BgHighlightBrush}"
                        BorderThickness="1">
                        <Border Width="60" Height="60"
                            CornerRadius="30"
                            HorizontalAlignment="Center"
                            BorderBrush="{DynamicResource BgHighlightBrush}"
                            BorderThickness="1">
                            <PathIcon Data="{StaticResource Icon.BellSleep}"
                                Width="26" Height="26"
                                Foreground="{DynamicResource TextMutedBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                    </Border>
                    <TextBlock Text="{Binding L[Notification_NoNotifications]}"
                        FontSize="13"
                        Foreground="{DynamicResource TextMutedBrush}"
                        HorizontalAlignment="Center"
                        Opacity="0.7" />
                </StackPanel>

                <ListBox IsVisible="{Binding HasNotifications}"
                    ItemsSource="{Binding Notifications}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,4,0,6"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Notification}">
                            <Border Classes="notification-card">
                                <Grid ColumnDefinitions="Auto, Auto, *, Auto">

                                    <Border Grid.Column="0" Classes="severity-strip">
                                        <Border.Background>
                                            <SolidColorBrush
                                                Color="{Binding Severity, Converter={StaticResource SeverityToColor}}" />
                                        </Border.Background>
                                    </Border>

                                    <Border Grid.Column="1"
                                        Width="32" Height="32"
                                        CornerRadius="8"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Top"
                                        BorderThickness="1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush
                                                Color="{Binding Severity, Converter={StaticResource SeverityToColor}}"
                                                Opacity="0.3" />
                                        </Border.BorderBrush>
                                        <TextBlock Text="{Binding Icon}"
                                            FontSize="14"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="2" MinWidth="0">

                                        <TextBlock Text="{Binding Title}"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding Message}"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Margin="0,2,0,0"
                                            LineHeight="17" />

                                        <Border Classes="track-info-block"
                                            IsVisible="{Binding TrackTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <PathIcon Grid.Column="0"
                                                    Data="{StaticResource Icon.MusicNote}"
                                                    Width="12" Height="12"
                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                    Margin="0,1,6,0"
                                                    VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                    Text="{Binding TrackTitle}"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                    TextWrapping="Wrap"
                                                    LineHeight="15" />
                                                <controls:CopyLinkButton Grid.Column="2"
                                                    CopyUrl="{Binding TrackUrl}"
                                                    SuccessText="{Binding $parent[ListBox].DataContext.L[Track_Copied]}"
                                                    ToolTipText="{Binding $parent[ListBox].DataContext.L[Notification_CopyTrackUrl]}"
                                                    ButtonSize="28" IconSize="13"
                                                    ShowHoverRing="False"
                                                    VerticalAlignment="Top"
                                                    Margin="6,0,0,0"
                                                    IsVisible="{Binding TrackUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Grid>
                                        </Border>

                                        <Border Classes="recommendation-block"
                                            IsVisible="{Binding HasRecommendation}">
                                            <Grid ColumnDefinitions="Auto, *">
                                                <PathIcon Grid.Column="0"
                                                    Data="{StaticResource Icon.Lightbulb}"
                                                    Width="13" Height="13"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Margin="0,1,8,0"
                                                    VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                    Text="{Binding Recommendation}"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    TextWrapping="Wrap"
                                                    LineHeight="16" />
                                            </Grid>
                                        </Border>

                                        <Expander Classes="details-expander"
                                            IsVisible="{Binding HasDetails}">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <PathIcon
                                                        Data="{StaticResource Icon.ChevronDown}"
                                                        Width="13" Height="13"
                                                        Foreground="{DynamicResource AccentBrush}" />
                                                    <TextBlock
                                                        Text="{Binding $parent[ListBox].DataContext.L[Notification_ViewDetails]}"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        Cursor="Hand" />
                                                </StackPanel>
                                            </Expander.Header>

                                            <StackPanel Spacing="3" Margin="0,6,0,0">

                                                <ItemsControl ItemsSource="{Binding Attempts}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate
                                                            DataType="{x:Type models:AttemptRecord}">
                                                            <Border Classes="attempt-row">
                                                                <Grid
                                                                    ColumnDefinitions="Auto, Auto, *"
                                                                    Margin="0,1">
                                                                    <TextBlock Grid.Column="0"
                                                                        Text="{Binding StatusIcon}"
                                                                        FontSize="11"
                                                                        Margin="0,0,8,0"
                                                                        VerticalAlignment="Top" />
                                                                    <TextBlock Grid.Column="1"
                                                                        Text="{Binding ClientName}"
                                                                        FontSize="11"
                                                                        FontWeight="Medium"
                                                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                                                        Margin="0,0,10,0"
                                                                        VerticalAlignment="Top" />
                                                                    <TextBlock Grid.Column="2"
                                                                        Text="{Binding DisplayMessage}"
                                                                        FontSize="11"
                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                        TextWrapping="Wrap"
                                                                        LineHeight="15" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Border Classes="attempt-row"
                                                    IsVisible="{Binding HasExceptionDetails}">
                                                    <ScrollViewer MaxHeight="140"
                                                        HorizontalScrollBarVisibility="Disabled"
                                                        VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding ExceptionDetails}"
                                                            FontSize="10"
                                                            FontFamily="Consolas, monospace"
                                                            Foreground="{DynamicResource TextMutedBrush}"
                                                            TextWrapping="Wrap"
                                                            LineHeight="14" />
                                                    </ScrollViewer>
                                                </Border>

                                                <Button Classes="ghost-btn"
                                                    IsVisible="{Binding HasExceptionDetails}"
                                                    Command="{Binding $parent[ListBox].DataContext.CopyErrorCommand}"
                                                    CommandParameter="{Binding ExceptionDetails}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,2,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <PathIcon
                                                            Data="{StaticResource Icon.ContentCopy}"
                                                            Width="12" Height="12"
                                                            Foreground="{DynamicResource TextMutedBrush}" />
                                                        <TextBlock
                                                            Text="{Binding $parent[ListBox].DataContext.L[Notification_CopyError]}"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextMutedBrush}" />
                                                    </StackPanel>
                                                </Button>

                                            </StackPanel>
                                        </Expander>

                                    </StackPanel>

                                    <TextBlock Grid.Column="3"
                                        Text="{Binding TimeAgo}"
                                        FontSize="10"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        Margin="10,2,0,0"
                                        VerticalAlignment="Top"
                                        TextAlignment="Right"
                                        Opacity="0.6" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Grid>
    </Border>
</UserControl>