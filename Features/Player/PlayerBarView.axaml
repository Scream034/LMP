<UserControl
    x:Class="LMP.Features.Player.PlayerBarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:vm="using:LMP.Features.Player"
    x:CompileBindings="True"
    x:DataType="vm:PlayerBarViewModel"
    Focusable="True"
    UseLayoutRounding="True">

    <!--  MAIN CONTENT  -->
    <Border Background="{DynamicResource BgSecondaryBrush}">
        <Grid RowDefinitions="Auto,*">

            <!--  ROW 0: SEEK SLIDER  -->
            <Grid
                Name="SeekContainer"
                Grid.Row="0"
                Height="14"
                Margin="0,1,0,0"
                VerticalAlignment="Top"
                Background="Transparent"
                Classes="seek-container"
                ClipToBounds="True"
                Cursor="Hand">

                <Grid
                    Name="TrackContainer"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Classes="track-container"
                    RenderTransformOrigin="0.5,0.5">

                    <!--  Layer 0: Background track  -->
                    <Border
                        Background="{DynamicResource BgHighlightBrush}"
                        CornerRadius="2"
                        Opacity="0.4" />

                    <!--  Layer 1: SPARK  -->
                    <Border
                        Name="SparkContainer"
                        ClipToBounds="True"
                        CornerRadius="2"
                        IsVisible="{Binding IsLoading}">
                        <Border
                            Name="SparkRunner"
                            Width="80"
                            Height="4"
                            HorizontalAlignment="Left"
                            CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Offset="0" Color="{DynamicResource AccentHover}" />
                                    <GradientStop Offset="0.5" Color="{DynamicResource Accent}" />
                                    <GradientStop Offset="1"
                                        Color="{DynamicResource AccentHoverTransparent}" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <!--  Layer 2: Buffer segments  -->
                    <Canvas
                        Name="BufferSegmentsCanvas"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ClipToBounds="True"
                        IsHitTestVisible="False" />

                    <!--  Layer 3: Preview fill  -->
                    <Border
                        Name="PreviewFill"
                        HorizontalAlignment="Left"
                        Classes="slider-preview"
                        CornerRadius="2" />

                    <!--  Layer 4: Progress bar  -->
                    <Border
                        Name="ProgressBar"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AccentBrush}"
                        Classes="progress-bar"
                        CornerRadius="2" />

                    <!--  Layer 5: Playing glow  -->
                    <Border
                        Name="PlayingGlow"
                        Height="4"
                        HorizontalAlignment="Left"
                        Classes="playing-glow"
                        Classes.active="{Binding IsPlaying}"
                        CornerRadius="2"
                        IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="100%,50%" EndPoint="0%,50%">
                                <GradientStop Offset="0" Color="{DynamicResource AccentHover}" />
                                <GradientStop Offset="0.3" Color="Transparent" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!--  Thumb canvas  -->
                <Canvas
                    Name="ThumbCanvas"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    IsHitTestVisible="False">
                    <Border
                        Name="SeekCursor"
                        Canvas.Top="0"
                        Width="2"
                        Height="14"
                        Background="{DynamicResource AccentBrush}"
                        Classes="seek-cursor"
                        CornerRadius="1" />
                    <Ellipse
                        Name="SeekThumb"
                        Canvas.Top="0"
                        Width="14"
                        Height="14"
                        Classes="slider-thumb"
                        Fill="{DynamicResource AccentBrush}" />
                </Canvas>

                <!--  Hit area  -->
                <Border
                    Name="SeekHitBox"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    IsHitTestVisible="{Binding HasTrack}"
                    PointerCaptureLost="OnSeekAreaCaptureLost"
                    PointerExited="OnSeekAreaExited"
                    PointerMoved="OnSeekAreaMoved"
                    PointerPressed="OnSeekAreaPressed"
                    PointerReleased="OnSeekAreaReleased" />
            </Grid>

            <!--  Seek Tooltip (time)  -->
            <Popup
                Name="SeekTooltipPopup"
                IsHitTestVisible="False"
                IsLightDismissEnabled="False"
                Placement="TopEdgeAlignedLeft"
                PlacementTarget="{Binding #SeekContainer}"
                VerticalOffset="-5">
                <Border
                    Name="SeekTooltipBorder"
                    Padding="6,3"
                    Background="{DynamicResource BgSkeletonBrush}"
                    BorderBrush="{DynamicResource BgHighlightBrush}"
                    BorderThickness="1"
                    BoxShadow="0 2 8 0 #40000000"
                    CornerRadius="4">
                    <TextBlock
                        Name="HoverTimeText"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="0:00" />
                </Border>
            </Popup>

            <!--  Seek Hint Popup (cancel / wait info)  -->
            <Popup
                Name="SeekHintPopup"
                IsHitTestVisible="False"
                IsLightDismissEnabled="False"
                Placement="Top"
                PlacementTarget="{Binding #SeekContainer}"
                HorizontalOffset="0"
                VerticalOffset="-28">
                <Border
                    Padding="8,4"
                    Background="{DynamicResource BgSkeletonBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    BoxShadow="0 2 8 0 #60000000"
                    CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon
                            Width="14" Height="14"
                            Foreground="{DynamicResource AccentBrush}"
                            Kind="InformationOutline" />
                        <TextBlock
                            Name="SeekHintText"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Popup>

            <!--  ROW 1: CONTROLS  -->
            <Grid
                Grid.Row="1"
                Margin="8,4,8,4"
                ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <!--  Left Controls  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="2">

                    <!-- Shuffle: ЛКМ = shuffle now, ПКМ = toggle auto-shuffle -->
                    <Panel>
                        <Button
                            x:Name="ShuffleButton"
                            Width="40" Height="40"
                            Classes="playback-btn"
                            Classes.active="{Binding IsShuffleAnimating}"
                            Classes.auto-enabled="{Binding AutoShuffleEnabled}"
                            Command="{Binding ShuffleQueueCommand}"
                            CornerRadius="20"
                            ToolTip.Tip="{Binding ShuffleTooltip}"
                            ToolTip.Placement="Top"
                            ToolTip.VerticalOffset="-6"
                            PointerPressed="OnShuffleButtonPressed">
                            <Panel>
                                <mi:MaterialIcon Width="18" Height="18" Kind="Shuffle" />
                                <!-- Индикатор auto-shuffle (точка) -->
                                <Ellipse
                                    Width="6" Height="6"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,4,4"
                                    Fill="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding AutoShuffleEnabled}" />
                            </Panel>
                        </Button>
                        <!-- Shuffle Hint Popup -->
                        <Popup
                            HorizontalOffset="-30"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsShuffleHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #ShuffleButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint"
                                Classes.visible="{Binding IsShuffleHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Width="14" Height="14"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Kind="Shuffle" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding ShuffleHintText}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>

                    <!-- Previous -->
                    <Button
                        Width="40" Height="40"
                        Classes="playback-btn"
                        Command="{Binding PreviousCommand}"
                        CornerRadius="20"
                        ToolTip.Tip="{Binding PreviousTooltip}"
                        ToolTip.Placement="Top"
                        ToolTip.VerticalOffset="-6">
                        <mi:MaterialIcon Width="24" Height="24" Kind="SkipPrevious" />
                    </Button>

                    <!-- Play/Pause -->
                    <Button
                        Width="52" Height="52"
                        Classes="playback-btn-main"
                        Command="{Binding PlayPauseCommand}"
                        CornerRadius="26"
                        ToolTip.Tip="{Binding PlayPauseTooltip}"
                        ToolTip.Placement="Top"
                        ToolTip.VerticalOffset="-6">
                        <Panel>
                            <mi:MaterialIcon Width="30" Height="30"
                                IsVisible="{Binding IsPlaying}" Kind="Pause" />
                            <mi:MaterialIcon Width="30" Height="30"
                                IsVisible="{Binding IsPaused}" Kind="Play" />
                        </Panel>
                    </Button>

                    <!-- Next -->
                    <Button
                        Width="40" Height="40"
                        Classes="playback-btn"
                        Command="{Binding NextCommand}"
                        CornerRadius="20"
                        ToolTip.Tip="{Binding NextTooltip}"
                        ToolTip.Placement="Top"
                        ToolTip.VerticalOffset="-6">
                        <mi:MaterialIcon Width="24" Height="24" Kind="SkipNext" />
                    </Button>

                    <!-- Repeat -->
                    <Panel>
                        <Button
                            x:Name="RepeatButton"
                            Width="40" Height="40"
                            Classes="playback-btn"
                            Classes.active="{Binding RepeatMode, Converter={StaticResource RepeatModeActive}}"
                            Command="{Binding ToggleRepeatCommand}"
                            CornerRadius="20"
                            ToolTip.Tip="{Binding RepeatTooltip}"
                            ToolTip.Placement="Top"
                            ToolTip.VerticalOffset="-6">
                            <Grid>
                                <mi:MaterialIcon Width="18" Height="18"
                                    Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" />
                                <Border
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Classes="repeat-indicator"
                                    Classes.visible="{Binding RepeatMode, Converter={StaticResource RepeatModeEquals}, ConverterParameter=RepeatAll}" />
                            </Grid>
                        </Button>
                        <Popup
                            HorizontalOffset="-30"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsRepeatHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #RepeatButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint"
                                Classes.visible="{Binding IsRepeatHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Width="14" Height="14"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding RepeatHintText}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>

                    <Border Width="1" Height="28" Margin="6,0"
                        Background="{DynamicResource BgHighlightBrush}" />

                    <!-- Volume -->
                    <Panel Name="VolumePanel">
                        <Button
                            x:Name="VolumeButton"
                            Width="38" Height="38"
                            Classes="icon-btn"
                            Classes.popup-open="{Binding #VolumePopup.IsOpen}"
                            Command="{Binding ToggleMuteCommand}"
                            CornerRadius="19"
                            ToolTip.Placement="Top"
                            ToolTip.VerticalOffset="-6"
                            PointerWheelChanged="OnVolumeScroll">
                            <Grid>
                                <mi:MaterialIcon Width="20" Height="20"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    IsVisible="{Binding IsMuted}" Kind="VolumeMute" />
                                <mi:MaterialIcon Width="20" Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeLow}" Kind="VolumeLow" />
                                <mi:MaterialIcon Width="20" Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeMedium}" Kind="VolumeMedium" />
                                <mi:MaterialIcon Width="20" Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeHigh}" Kind="VolumeHigh" />
                                <mi:MaterialIcon Width="20" Height="20"
                                    Foreground="{DynamicResource SystemWarnOrangeBrush}"
                                    IsVisible="{Binding IsVolumeBoosted}" Kind="VolumeVibrate" />
                            </Grid>
                        </Button>

                        <!-- Volume Popup -->
                        <Popup
                            x:Name="VolumePopup"
                            IsLightDismissEnabled="False"
                            Placement="Top"
                            PlacementTarget="{Binding #VolumeButton}"
                            VerticalOffset="-4">
                            <Border
                                Padding="4"
                                Background="{DynamicResource BgElevatedBrush}"
                                BorderBrush="{DynamicResource BgHighlightBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                PointerEntered="OnVolumePopupContentEntered"
                                PointerExited="OnVolumePopupContentExited">
                                <Panel
                                    Name="VolumeSliderPanel"
                                    Width="20" MinHeight="60" Height="80"
                                    HorizontalAlignment="Center">
                                    <Border Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Classes="vol-track" />
                                    <Border Name="VolumeBar"
                                        Width="4" Height="0" MinHeight="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Classes="vol-fill"
                                        Classes.boosted="{Binding IsVolumeBoosted}" />
                                    <Ellipse Name="VolumeThumb"
                                        Width="12" Height="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Classes="vol-thumb"
                                        Classes.boosted="{Binding IsVolumeBoosted}" />
                                    <Border Name="VolumeHitBox"
                                        Width="20"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        PointerCaptureLost="OnVolumeAreaCaptureLost"
                                        PointerExited="OnVolumeAreaExited"
                                        PointerMoved="OnVolumeAreaMoved"
                                        PointerPressed="OnVolumeAreaPressed"
                                        PointerReleased="OnVolumeAreaReleased"
                                        PointerWheelChanged="OnVolumeScroll" />
                                </Panel>
                            </Border>
                        </Popup>

                        <!-- Volume Tooltip -->
                        <Popup Name="VolumeTooltipPopup"
                            HorizontalOffset="-8"
                            IsHitTestVisible="False"
                            IsLightDismissEnabled="False"
                            Placement="Left"
                            PlacementTarget="{Binding #VolumeHitBox}">
                            <Border Padding="6,4"
                                Background="{DynamicResource BgSkeletonBrush}"
                                BorderBrush="{DynamicResource BgHighlightBrush}"
                                BorderThickness="1"
                                BoxShadow="0 2 6 0 #40000000"
                                CornerRadius="4">
                                <TextBlock Name="VolumeTooltipText"
                                    FontSize="11" FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                        </Popup>
                    </Panel>

                    <Border Width="1" Height="28" Margin="6,0"
                        Background="{DynamicResource BgHighlightBrush}" />

                    <!-- Like -->
                    <Panel>
                        <Button
                            x:Name="LikeButton"
                            Width="36" Height="36"
                            Classes="icon-btn"
                            Command="{Binding ToggleLikeCommand}"
                            CornerRadius="18"
                            ToolTip.Tip="{Binding LikeTooltip}"
                            ToolTip.Placement="Top"
                            ToolTip.VerticalOffset="-6">
                            <mi:MaterialIcon Width="18" Height="18"
                                Classes="heart-icon"
                                Classes.active="{Binding IsLiked}"
                                Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}" />
                        </Button>
                        <Popup
                            HorizontalOffset="-20"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsLikeHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #LikeButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint"
                                Classes.visible="{Binding IsLikeHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Width="14" Height="14"
                                        Foreground="{DynamicResource AccentBrush}" Kind="Heart" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding LikeHintText}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>

                    <!-- Copy -->
                    <Panel>
                        <Button
                            x:Name="CopyButton"
                            Width="36" Height="36"
                            Classes="icon-btn"
                            Command="{Binding CopyLinkCommand}"
                            CornerRadius="18"
                            ToolTip.Tip="{Binding CopyTooltip}"
                            ToolTip.Placement="Top"
                            ToolTip.VerticalOffset="-6">
                            <mi:MaterialIcon Width="16" Height="16"
                                Classes.active="{Binding IsCopyHighlighted}"
                                Kind="ContentCopy" />
                        </Button>
                        <Popup
                            HorizontalOffset="-15"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsCopyHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #CopyButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint"
                                Classes.visible="{Binding IsCopyHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon Width="14" Height="14"
                                        Foreground="{DynamicResource AccentBrush}" Kind="Check" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding L[Track_Copied]}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Grid.Column="1"
                    Width="1"
                    Margin="10,10"
                    Background="{DynamicResource BgHighlightBrush}" />

                <!--  Track Info  -->
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Border
                        Width="52"
                        Height="52"
                        Background="{DynamicResource BgElevatedBrush}"
                        ClipToBounds="True"
                        CornerRadius="6">
                        <Panel>
                            <mi:MaterialIcon
                                Width="22"
                                Height="22"
                                Foreground="{DynamicResource TextMutedBrush}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}, ConverterParameter=invert}"
                                Kind="MusicNote" />
                            <Image
                                asyncImage:ImageLoader.Source="{Binding SafeThumbnail}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}}"
                                Stretch="UniformToFill" />
                        </Panel>
                    </Border>
                    <StackPanel MaxWidth="350" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="{Binding SafeTitle}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="{Binding SafeAuthor}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Grid.Column="3"
                    Width="1"
                    Margin="10,10"
                    Background="{DynamicResource BgHighlightBrush}" />

                <!--  Queue + Duration + Format  -->
                <StackPanel
                    Grid.Column="4"
                    Width="180"
                    VerticalAlignment="Center"
                    Spacing="4">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding TotalTracksInQueue, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                            Orientation="Horizontal"
                            Spacing="3"
                            ToolTip.Tip="{Binding TrackNumberTooltip}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="{Binding CurrentTrackIndexDisplay}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="/" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding TotalTracksInQueue}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="2"
                            ToolTip.Tip="{Binding DurationTooltip}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="{Binding Position, Converter={StaticResource TimeSpanConverter}}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="/" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}" />
                        </StackPanel>
                    </Grid>
                    <Panel>
                        <Button
                            x:Name="FormatButton"
                            Padding="6,3"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Classes="sidebar-btn format-btn"
                            Command="{Binding LoadFormatsCommand}"
                            IsVisible="{Binding ShowStreamInfo}">
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel MinWidth="220" Spacing="4">
                                        <TextBlock
                                            Margin="4"
                                            FontWeight="Bold"
                                            Text="{Binding L[Stream_SelectQuality]}" />
                                        <ItemsControl ItemsSource="{Binding AvailableFormats}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        Classes="sidebar-btn"
                                                        Command="{Binding $parent[UserControl].DataContext.SwitchFormatCommand}"
                                                        CommandParameter="{Binding}">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                            <Panel Grid.Column="0" Width="22">
                                                                <mi:MaterialIcon
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{DynamicResource AccentBrush}"
                                                                    IsVisible="{Binding IsDownloaded}"
                                                                    Kind="CheckCircle" />
                                                            </Panel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeight}}"
                                                                Text="{Binding DisplayName}" />
                                                            <Panel
                                                                Grid.Column="2"
                                                                Width="20"
                                                                Margin="4,0">
                                                                <mi:MaterialIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Foreground="{DynamicResource AccentBrush}"
                                                                    IsVisible="{Binding IsActive}"
                                                                    Kind="VolumeHigh" />
                                                            </Panel>
                                                            <TextBlock
                                                                Grid.Column="3"
                                                                Margin="4,0,0,0"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                Text="{Binding SizeMbFormatted}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Text="{Binding StreamInfo}" />
                                <mi:MaterialIcon
                                    Width="10"
                                    Height="10"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Kind="ChevronUp" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}"
                                    Text="{Binding DownloadSpeedText}" />
                            </StackPanel>
                        </Button>
                    </Panel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>