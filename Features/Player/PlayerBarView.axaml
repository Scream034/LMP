<UserControl
    x:Class="LMP.Features.Player.PlayerBarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:asyncImage="using:AsyncImageLoader"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:vm="using:LMP.Features.Player"
    x:CompileBindings="True"
    x:DataType="vm:PlayerBarViewModel"
    Focusable="True"
    UseLayoutRounding="True">

    <UserControl.Styles>
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  PLAYER BUTTONS                                                   -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Style Selector="Button.pb-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="ToolTip.Placement" Value="Top" />
            <Setter Property="ToolTip.VerticalOffset" Value="-6" />
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.pb-btn:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        </Style>
        <Style Selector="Button.pb-btn:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="RenderTransform" Value="scale(0.96)" />
        </Style>
        <Style Selector="Button.pb-btn.active">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.pb-btn.active:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!--  MAIN PLAY BUTTON  -->
        <Style Selector="Button.pb-main">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="ToolTip.Placement" Value="Top" />
            <Setter Property="ToolTip.VerticalOffset" Value="-6" />
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.pb-main:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.pb-main:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="RenderTransform" Value="scale(0.94)" />
        </Style>

        <!--  ICON BUTTON  -->
        <Style Selector="Button.ico-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="ToolTip.Placement" Value="Top" />
            <Setter Property="ToolTip.VerticalOffset" Value="-6" />
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ico-btn:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BgHighlightBrush}" />
        </Style>
        <Style Selector="Button.ico-btn:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="RenderTransform" Value="scale(0.92)" />
        </Style>
        <Style Selector="Button.ico-btn.active mi|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.ico-btn.popup-open">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!--  Heart animation  -->
        <Style Selector="Button.ico-btn mi|MaterialIcon.heart-icon">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="BackEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ico-btn:pressed mi|MaterialIcon.heart-icon">
            <Setter Property="RenderTransform" Value="scale(1.25)" />
        </Style>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  SEEK SLIDER                                                      -->
        <!--  ═══════════════════════════════════════════════════════════════  -->

        <!--  Track container hover  -->
        <Style Selector="Grid.track-container">
            <Setter Property="RenderTransform" Value="scaleY(1)" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid.seek-container:pointerover Grid.track-container">
            <Setter Property="RenderTransform" Value="scaleY(1.5)" />
        </Style>
        <Style Selector="Grid.seek-container.dragging Grid.track-container">
            <Setter Property="RenderTransform" Value="scaleY(1.5)" />
        </Style>

        <!--  Seek thumb  -->
        <Style Selector="Ellipse.slider-thumb">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid.seek-container:pointerover Ellipse.slider-thumb">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Grid.seek-container.dragging Ellipse.slider-thumb">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!--  Seek cursor  -->
        <Style Selector="Border.seek-cursor">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid.seek-container:pointerover Border.seek-cursor">
            <Setter Property="Opacity" Value="0.6" />
        </Style>

        <!--  Preview fill  -->
        <Style Selector="Border.slider-preview">
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Border.slider-preview.active">
            <Setter Property="Opacity" Value="0.5" />
        </Style>

        <!--  Playing glow  -->
        <Style Selector="Border.playing-glow">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Border.playing-glow.active">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:1.5">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.7" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  VOLUME SLIDER (Minimalist)                                       -->
        <!--  ═══════════════════════════════════════════════════════════════  -->

        <Style Selector="Ellipse.vol-thumb">
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut" />
                    <ThicknessTransition Property="Margin" Duration="0:0:0.06" Easing="CubicEaseOut" />
                    <BrushTransition Property="Fill" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Ellipse.vol-thumb:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.15)" />
        </Style>
        <Style Selector="Ellipse.vol-thumb.dragging">
            <Setter Property="RenderTransform" Value="scale(1.2)" />
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Ellipse.vol-thumb.boosted">
            <Setter Property="Fill" Value="{DynamicResource SystemWarnOrangeBrush}" />
        </Style>

        <Style Selector="Border.vol-track">
            <Setter Property="Background" Value="{DynamicResource BgHighlightBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>

        <Style Selector="Border.vol-fill">
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.06" Easing="CubicEaseOut" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.vol-fill.boosted">
            <Setter Property="Background" Value="{DynamicResource SystemWarnOrangeBrush}" />
        </Style>

        <Style Selector="Button.format-btn.popup-open">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
    </UserControl.Styles>

    <!--  ═══════════════════════════════════════════════════════════════════  -->
    <!--  MAIN CONTENT                                                         -->
    <!--  ═══════════════════════════════════════════════════════════════════  -->
    <Border Background="{DynamicResource BgSecondaryBrush}">
        <Grid RowDefinitions="Auto,*">

            <!--  ROW 0: SEEK SLIDER  -->
            <Grid
                Name="SeekContainer"
                Grid.Row="0"
                Height="14"
                Margin="0,1,0,0"
                VerticalAlignment="Top"
                Background="Transparent"
                Classes="seek-container"
                ClipToBounds="True"
                Cursor="Hand">

                <Grid
                    Name="TrackContainer"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Classes="track-container"
                    RenderTransformOrigin="0.5,0.5">

                    <!--  Background track  -->
                    <Border Classes="slider-track seek-track" CornerRadius="2" />

                    <!--  SPARK (движется через code-behind)  -->
                    <Border
                        Name="SparkContainer"
                        ClipToBounds="True"
                        CornerRadius="2"
                        IsVisible="{Binding IsLoading}">
                        <Border
                            Name="SparkRunner"
                            Width="80"
                            Height="4"
                            HorizontalAlignment="Left"
                            CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Offset="0" Color="Transparent" />
                                    <GradientStop Offset="0.5" Color="{DynamicResource Accent}" />
                                    <GradientStop Offset="1" Color="Transparent" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <!--  Buffer bar  -->
                    <Border
                        Name="BufferBar"
                        HorizontalAlignment="Left"
                        Classes="slider-buffer seek-track"
                        CornerRadius="2" />

                    <!--  Preview fill  -->
                    <Border
                        Name="PreviewFill"
                        HorizontalAlignment="Left"
                        Classes="slider-preview seek-track"
                        CornerRadius="2" />

                    <!--  Progress bar  -->
                    <Border
                        Name="ProgressBar"
                        HorizontalAlignment="Left"
                        Classes="slider-fill seek-track"
                        CornerRadius="2" />

                    <!--  Playing glow  -->
                    <Border
                        Name="PlayingGlow"
                        Height="4"
                        HorizontalAlignment="Left"
                        Classes="playing-glow"
                        Classes.active="{Binding IsPlaying}"
                        CornerRadius="2"
                        IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="100%,50%" EndPoint="0%,50%">
                                <GradientStop Offset="0" Color="{DynamicResource AccentHover}" />
                                <GradientStop Offset="0.3" Color="Transparent" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!--  Thumb canvas  -->
                <Canvas
                    Name="ThumbCanvas"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    IsHitTestVisible="False">
                    <Border
                        Name="SeekCursor"
                        Canvas.Top="0"
                        Width="2"
                        Height="14"
                        Background="{DynamicResource AccentBrush}"
                        Classes="seek-cursor"
                        CornerRadius="1" />
                    <Ellipse
                        Name="SeekThumb"
                        Canvas.Top="0"
                        Width="14"
                        Height="14"
                        Classes="slider-thumb"
                        Fill="{DynamicResource AccentBrush}" />
                </Canvas>

                <!--  Hit area  -->
                <Border
                    Name="SeekHitBox"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    IsHitTestVisible="{Binding HasTrack}"
                    PointerCaptureLost="OnSeekAreaCaptureLost"
                    PointerExited="OnSeekAreaExited"
                    PointerMoved="OnSeekAreaMoved"
                    PointerPressed="OnSeekAreaPressed"
                    PointerReleased="OnSeekAreaReleased" />
            </Grid>

            <!--  Seek Tooltip  -->
            <Popup
                Name="SeekTooltipPopup"
                IsHitTestVisible="False"
                IsLightDismissEnabled="False"
                Placement="TopEdgeAlignedLeft"
                PlacementTarget="{Binding #SeekContainer}"
                VerticalOffset="-5">
                <Border
                    Name="SeekTooltipBorder"
                    Padding="6,3"
                    Background="{DynamicResource BgSkeletonBrush}"
                    BorderBrush="{DynamicResource BgHighlightBrush}"
                    BorderThickness="1"
                    BoxShadow="0 2 8 0 #40000000"
                    CornerRadius="4">
                    <TextBlock
                        Name="HoverTimeText"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="0:00" />
                </Border>
            </Popup>

            <!--  ROW 1: CONTROLS  -->
            <Grid
                Grid.Row="1"
                Margin="8,4,8,4"
                ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <!--  Left Controls  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="2">

                    <!--  Shuffle  -->
                    <Button
                        Width="40"
                        Height="40"
                        Classes="pb-btn"
                        Classes.active="{Binding ShuffleEnabled}"
                        Command="{Binding ShuffleQueueCommand}"
                        CornerRadius="20"
                        ToolTip.Tip="{Binding ShuffleTooltip}">
                        <mi:MaterialIcon Width="18" Height="18" Kind="Shuffle" />
                    </Button>

                    <!--  Previous  -->
                    <Button
                        Width="40"
                        Height="40"
                        Classes="pb-btn"
                        Command="{Binding PreviousCommand}"
                        CornerRadius="20"
                        ToolTip.Tip="{Binding PreviousTooltip}">
                        <mi:MaterialIcon Width="24" Height="24" Kind="SkipPrevious" />
                    </Button>

                    <!--  Play/Pause  -->
                    <Button
                        Width="52"
                        Height="52"
                        Classes="pb-main"
                        Command="{Binding PlayPauseCommand}"
                        CornerRadius="26"
                        ToolTip.Tip="{Binding PlayPauseTooltip}">
                        <Panel>
                            <mi:MaterialIcon
                                Width="30"
                                Height="30"
                                IsVisible="{Binding IsPlaying}"
                                Kind="Pause" />
                            <mi:MaterialIcon
                                Width="30"
                                Height="30"
                                IsVisible="{Binding IsPaused}"
                                Kind="Play" />
                        </Panel>
                    </Button>

                    <!--  Next  -->
                    <Button
                        Width="40"
                        Height="40"
                        Classes="pb-btn"
                        Command="{Binding NextCommand}"
                        CornerRadius="20"
                        ToolTip.Tip="{Binding NextTooltip}">
                        <mi:MaterialIcon Width="24" Height="24" Kind="SkipNext" />
                    </Button>

                    <!--  Repeat  -->
                    <Panel>
                        <Button
                            x:Name="RepeatButton"
                            Width="40"
                            Height="40"
                            Classes="pb-btn"
                            Classes.active="{Binding RepeatMode, Converter={StaticResource RepeatModeActive}}"
                            Command="{Binding ToggleRepeatCommand}"
                            CornerRadius="20"
                            ToolTip.Tip="{Binding RepeatTooltip}">
                            <Grid>
                                <mi:MaterialIcon
                                    Width="18"
                                    Height="18"
                                    Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" />
                                <Border
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Classes="repeat-indicator"
                                    Classes.visible="{Binding RepeatMode, Converter={StaticResource RepeatModeEquals}, ConverterParameter=RepeatAll}" />
                            </Grid>
                        </Button>
                        <Popup
                            HorizontalOffset="-30"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsRepeatHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #RepeatButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint" Classes.visible="{Binding IsRepeatHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding RepeatHintText}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>

                    <Border
                        Width="1"
                        Height="28"
                        Margin="6,0"
                        Background="{DynamicResource BgHighlightBrush}" />

                    <!--  Volume  -->
                    <Panel Name="VolumePanel">
                        <Button
                            x:Name="VolumeButton"
                            Width="38"
                            Height="38"
                            Classes="ico-btn"
                            Classes.popup-open="{Binding #VolumePopup.IsOpen}"
                            Command="{Binding ToggleMuteCommand}"
                            CornerRadius="19"
                            PointerWheelChanged="OnVolumeScroll">
                            <Grid>
                                <mi:MaterialIcon
                                    Width="20"
                                    Height="20"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    IsVisible="{Binding IsMuted}"
                                    Kind="VolumeMute" />
                                <mi:MaterialIcon
                                    Width="20"
                                    Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeLow}"
                                    Kind="VolumeLow" />
                                <mi:MaterialIcon
                                    Width="20"
                                    Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeMedium}"
                                    Kind="VolumeMedium" />
                                <mi:MaterialIcon
                                    Width="20"
                                    Height="20"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    IsVisible="{Binding IsVolumeHigh}"
                                    Kind="VolumeHigh" />
                                <mi:MaterialIcon
                                    Width="20"
                                    Height="20"
                                    Foreground="{DynamicResource SystemWarnOrangeBrush}"
                                    IsVisible="{Binding IsVolumeBoosted}"
                                    Kind="VolumeVibrate" />
                            </Grid>
                        </Button>

                        <!--  Volume Popup  -->
                        <Popup
                            x:Name="VolumePopup"
                            HorizontalOffset="5"
                            IsLightDismissEnabled="False"
                            Placement="Top"
                            PlacementTarget="{Binding #VolumeButton}"
                            VerticalOffset="-4">
                            <Border
                                Padding="4"
                                Background="{DynamicResource BgElevatedBrush}"
                                BorderBrush="{DynamicResource BgHighlightBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                PointerEntered="OnVolumePopupContentEntered"
                                PointerExited="OnVolumePopupContentExited">
                                <Panel
                                    Name="VolumeSliderPanel"
                                    Width="20"
                                    HorizontalAlignment="Center">
                                    <Border
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Classes="vol-track" />
                                    <Border
                                        Name="VolumeBar"
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Classes="vol-fill"
                                        Classes.boosted="{Binding IsVolumeBoosted}" />
                                    <Ellipse
                                        Name="VolumeThumb"
                                        Width="12"
                                        Height="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Classes="vol-thumb"
                                        Classes.boosted="{Binding IsVolumeBoosted}" />
                                    <Border
                                        Name="VolumeHitBox"
                                        Width="20"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        PointerCaptureLost="OnVolumeAreaCaptureLost"
                                        PointerExited="OnVolumeAreaExited"
                                        PointerMoved="OnVolumeAreaMoved"
                                        PointerPressed="OnVolumeAreaPressed"
                                        PointerReleased="OnVolumeAreaReleased"
                                        PointerWheelChanged="OnVolumeScroll" />
                                </Panel>
                            </Border>
                        </Popup>

                        <!--  Volume Tooltip  -->
                        <Popup
                            Name="VolumeTooltipPopup"
                            HorizontalOffset="-8"
                            IsHitTestVisible="False"
                            IsLightDismissEnabled="False"
                            Placement="Left"
                            PlacementTarget="{Binding #VolumeHitBox}">
                            <Border
                                Padding="6,4"
                                Background="{DynamicResource BgSkeletonBrush}"
                                BorderBrush="{DynamicResource BgHighlightBrush}"
                                BorderThickness="1"
                                BoxShadow="0 2 6 0 #40000000"
                                CornerRadius="4">
                                <TextBlock
                                    Name="VolumeTooltipText"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                        </Popup>
                    </Panel>

                    <Border
                        Width="1"
                        Height="28"
                        Margin="6,0"
                        Background="{DynamicResource BgHighlightBrush}" />

                    <!--  Like  -->
                    <Panel>
                        <Button
                            x:Name="LikeButton"
                            Width="36"
                            Height="36"
                            Classes="ico-btn"
                            Command="{Binding ToggleLikeCommand}"
                            CornerRadius="18"
                            ToolTip.Tip="{Binding LikeTooltip}">
                            <mi:MaterialIcon
                                Width="18"
                                Height="18"
                                Classes="heart-icon"
                                Classes.active="{Binding IsLiked}"
                                Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}" />
                        </Button>
                        <Popup
                            HorizontalOffset="-20"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsLikeHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #LikeButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint" Classes.visible="{Binding IsLikeHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Kind="Heart" />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding LikeHintText}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>

                    <!--  Copy  -->
                    <Panel>
                        <Button
                            x:Name="CopyButton"
                            Width="36"
                            Height="36"
                            Classes="ico-btn"
                            Command="{Binding CopyLinkCommand}"
                            CornerRadius="18"
                            ToolTip.Tip="{Binding CopyTooltip}">
                            <mi:MaterialIcon
                                Width="16"
                                Height="16"
                                Classes.active="{Binding IsCopyHighlighted}"
                                Kind="ContentCopy" />
                        </Button>
                        <Popup
                            HorizontalOffset="-15"
                            IsLightDismissEnabled="False"
                            IsOpen="{Binding IsCopyHintVisible}"
                            Placement="Top"
                            PlacementTarget="{Binding #CopyButton}"
                            VerticalOffset="-8">
                            <Border Classes="mode-hint" Classes.visible="{Binding IsCopyHintVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <mi:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Kind="Check" />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{Binding L[Track_Copied]}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Panel>
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Grid.Column="1"
                    Width="1"
                    Margin="10,10"
                    Background="{DynamicResource BgHighlightBrush}" />

                <!--  Track Info  -->
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Border
                        Width="52"
                        Height="52"
                        Background="{DynamicResource BgElevatedBrush}"
                        ClipToBounds="True"
                        CornerRadius="6">
                        <Panel>
                            <mi:MaterialIcon
                                Width="22"
                                Height="22"
                                Foreground="{DynamicResource TextMutedBrush}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}, ConverterParameter=invert}"
                                Kind="MusicNote" />
                            <Image
                                asyncImage:ImageLoader.Source="{Binding SafeThumbnail}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}}"
                                Stretch="UniformToFill" />
                        </Panel>
                    </Border>
                    <StackPanel MaxWidth="350" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="{Binding SafeTitle}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="{Binding SafeAuthor}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Grid.Column="3"
                    Width="1"
                    Margin="10,10"
                    Background="{DynamicResource BgHighlightBrush}" />

                <!--  Queue + Duration + Format  -->
                <StackPanel
                    Grid.Column="4"
                    Width="140"
                    VerticalAlignment="Center"
                    Spacing="4">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding TotalTracksInQueue, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                            Orientation="Horizontal"
                            Spacing="3"
                            ToolTip.Tip="{Binding TrackNumberTooltip}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="{Binding CurrentTrackIndexDisplay}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="/" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding TotalTracksInQueue}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="2"
                            ToolTip.Tip="{Binding DurationTooltip}">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AccentBrush}"
                                Text="{Binding Position, Converter={StaticResource TimeSpanConverter}}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="/" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}" />
                        </StackPanel>
                    </Grid>
                    <Panel>
                        <Button
                            x:Name="FormatButton"
                            Padding="6,3"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Classes="sidebar-btn format-btn"
                            Command="{Binding LoadFormatsCommand}"
                            IsVisible="{Binding ShowStreamInfo}">
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel MinWidth="220" Spacing="4">
                                        <TextBlock
                                            Margin="4"
                                            FontWeight="Bold"
                                            Text="{Binding L[Stream_SelectQuality]}" />
                                        <ItemsControl ItemsSource="{Binding AvailableFormats}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        Classes="sidebar-btn"
                                                        Command="{Binding $parent[UserControl].DataContext.SwitchFormatCommand}"
                                                        CommandParameter="{Binding}">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                            <Panel Grid.Column="0" Width="22">
                                                                <mi:MaterialIcon
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{DynamicResource AccentBrush}"
                                                                    IsVisible="{Binding IsDownloaded}"
                                                                    Kind="CheckCircle" />
                                                            </Panel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontWeight="{Binding IsActive, Converter={StaticResource BoolToFontWeight}}"
                                                                Text="{Binding DisplayName}" />
                                                            <Panel
                                                                Grid.Column="2"
                                                                Width="20"
                                                                Margin="4,0">
                                                                <mi:MaterialIcon
                                                                    Width="14"
                                                                    Height="14"
                                                                    Foreground="{DynamicResource AccentBrush}"
                                                                    IsVisible="{Binding IsActive}"
                                                                    Kind="VolumeHigh" />
                                                            </Panel>
                                                            <TextBlock
                                                                Grid.Column="3"
                                                                Margin="4,0,0,0"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextMutedBrush}"
                                                                Text="{Binding SizeMbFormatted}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Text="{Binding StreamInfo}" />
                                <mi:MaterialIcon
                                    Width="10"
                                    Height="10"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Kind="ChevronUp" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}"
                                    Text="{Binding DownloadSpeedText}" />
                            </StackPanel>
                        </Button>
                    </Panel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>