<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Player"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:asyncImage="using:AsyncImageLoader"
    x:Class="MyLiteMusicPlayer.Features.Player.PlayerBarView"
    x:DataType="vm:PlayerBarViewModel"
    x:CompileBindings="True">

    <Border Background="{DynamicResource BgSecondaryBrush}" Height="110"
        BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="0,1,0,0">
        <Grid>
            <!-- Global Loading Progress (Top Line) -->
            <ProgressBar VerticalAlignment="Top" Height="2" IsIndeterminate="True"
                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                IsVisible="{Binding IsLoading}" />

            <Grid ColumnDefinitions="3*, 4*, 3*" Margin="16,0">

                <!-- LEFT: Track Info -->
                <Grid Grid.Column="0" ColumnDefinitions="Auto, *, Auto">
                    <!-- Thumbnail -->
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4"
                        ClipToBounds="True" Background="{DynamicResource BgElevatedBrush}">
                        <Panel>
                            <mi:MaterialIcon Kind="MusicNote" Width="24" Height="24"
                                Foreground="{DynamicResource TextMutedBrush}"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}, ConverterParameter=invert}" />
                            <Image asyncImage:ImageLoader.Source="{Binding SafeThumbnail}"
                                Stretch="UniformToFill"
                                IsVisible="{Binding SafeThumbnail, Converter={StaticResource NullToVisible}}" />
                        </Panel>
                    </Border>

                    <!-- Title & Author -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                        <TextBlock Text="{Binding SafeTitle}" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SafeAuthor}" FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- Actions (Like / Copy) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">

                        <!-- Like Button -->
                        <Panel>
                            <Button x:Name="LikeButton" Classes="icon-btn"
                                Command="{Binding ToggleLikeCommand}"
                                ToolTip.Tip="{Binding LikeTooltip}">
                                <!-- Иконка меняется через Converter, стиль берется из темы -->
                                <mi:MaterialIcon
                                    Kind="{Binding IsLiked, Converter={StaticResource BoolToSelector}, ConverterParameter=Heart|HeartOutline}"
                                    Classes.active="{Binding IsLiked}"
                                    Width="18" Height="18" />
                            </Button>

                            <!-- Popup Hint -->
                            <Popup PlacementTarget="{Binding #LikeButton}"
                                Placement="Top" HorizontalOffset="-20" VerticalOffset="-8"
                                IsOpen="{Binding IsLikeHintVisible}" IsLightDismissEnabled="False">
                                <Border Classes="mode-hint" Classes.visible="{Binding IsLikeHintVisible}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <mi:MaterialIcon Kind="Heart" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{Binding LikeHintText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Panel>

                        <!-- Copy Button -->
                        <Panel>
                            <Button x:Name="CopyButton" Classes="icon-btn"
                                Command="{Binding CopyLinkCommand}"
                                ToolTip.Tip="{Binding CopyTooltip}">
                                <mi:MaterialIcon Kind="ContentCopy" Width="16" Height="16"
                                    Classes.active="{Binding IsCopyHighlighted}"/>
                            </Button>

                            <Popup PlacementTarget="{Binding #CopyButton}"
                                Placement="Top" HorizontalOffset="-15" VerticalOffset="-8"
                                IsOpen="{Binding IsCopyHintVisible}" IsLightDismissEnabled="False">
                                <Border Classes="mode-hint" Classes.visible="{Binding IsCopyHintVisible}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <mi:MaterialIcon Kind="Check" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{Binding L[Track_Copied]}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>
                </Grid>

                <!-- CENTER: Controls -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">

                    <!-- Playback Buttons Row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                        <Button Classes="playback-btn"
                            Classes.active="{Binding ShuffleEnabled}"
                            Classes.disabled="{Binding IsLoading}"
                            Command="{Binding ShuffleQueueCommand}"
                            ToolTip.Tip="{Binding ShuffleTooltip}">
                            <mi:MaterialIcon Kind="Shuffle" Width="20" Height="20" />
                        </Button>

                        <Button Classes="playback-btn"
                            Classes.disabled="{Binding IsLoading}"
                            Command="{Binding PreviousCommand}"
                            ToolTip.Tip="{Binding PreviousTooltip}">
                            <mi:MaterialIcon Kind="SkipPrevious" Width="24" Height="24" />
                        </Button>

                        <Button Classes="playback-btn-main"
                            Classes.disabled="{Binding IsLoading}"
                            Command="{Binding PlayPauseCommand}"
                            ToolTip.Tip="{Binding PlayPauseTooltip}">
                            <Panel>
                                <mi:MaterialIcon Kind="Pause" Width="28" Height="28" IsVisible="{Binding IsPlaying}" />
                                <mi:MaterialIcon Kind="Play" Width="28" Height="28" IsVisible="{Binding IsPaused}" />
                            </Panel>
                        </Button>

                        <Button Classes="playback-btn"
                            Classes.disabled="{Binding IsLoading}"
                            Command="{Binding NextCommand}"
                            ToolTip.Tip="{Binding NextTooltip}">
                            <mi:MaterialIcon Kind="SkipNext" Width="24" Height="24" />
                        </Button>

                        <!-- Repeat Button -->
                        <Panel>
                            <Button x:Name="RepeatButton" Classes="playback-btn"
                                Classes.active="{Binding RepeatMode, Converter={StaticResource RepeatModeActive}}"
                                Command="{Binding ToggleRepeatCommand}"
                                ToolTip.Tip="{Binding RepeatTooltip}">
                                <Grid>
                                    <mi:MaterialIcon Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" Width="20" Height="20" />
                                    <Border Classes="repeat-indicator"
                                        Classes.visible="{Binding RepeatMode, Converter={StaticResource RepeatModeEquals}, ConverterParameter=RepeatAll}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Popup PlacementTarget="{Binding #RepeatButton}" Placement="Top" HorizontalOffset="-30" VerticalOffset="-8" IsOpen="{Binding IsRepeatHintVisible}" IsLightDismissEnabled="False">
                                <Border Classes="mode-hint" Classes.visible="{Binding IsRepeatHintVisible}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <mi:MaterialIcon Kind="{Binding RepeatMode, Converter={StaticResource RepeatModeIcon}}" Foreground="{DynamicResource AccentBrush}" Width="14" Height="14" />
                                        <TextBlock Text="{Binding RepeatHintText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>

                    <!-- Seek Bar Row -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Position, Converter={StaticResource TimeSpanConverter}}"
                            FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                            Width="40" VerticalAlignment="Center" />

                        <Grid Grid.Column="1" Height="24" VerticalAlignment="Center">
                            <!-- Busy Indicator -->
                            <Border Classes="seek-busy-indicator" CornerRadius="6" Margin="-6,-4"
                                IsVisible="{Binding IsSeekBusy}" BorderBrush="{DynamicResource AccentBrush}" />

                            <!-- Seek Runner Animation (Visual candy) -->
                            <Canvas IsVisible="{Binding IsSeekBusy}" ClipToBounds="False" Margin="-2,0">
                                <Border Canvas.Top="-2" Classes="seek-gradient-runner"/>
                            </Canvas>

                            <!-- Slider Visuals -->
                            <Panel VerticalAlignment="Center" Height="12">
                                <Border Classes="slider-track" />
                                
                                <Canvas VerticalAlignment="Center" ClipToBounds="True" Height="4">
                                    <Border Name="BufferBar" Classes="slider-buffer" />
                                </Canvas>
                                
                                <Canvas VerticalAlignment="Center" ClipToBounds="True" Height="4">
                                    <Border Name="ProgressBar" Classes="slider-fill" />
                                </Canvas>
                                
                                <Canvas VerticalAlignment="Center" ClipToBounds="False">
                                    <Ellipse Name="SeekThumb" Classes="slider-thumb" Canvas.Top="-6" />
                                </Canvas>
                            </Panel>

                            <!-- Hit Box -->
                            <Border Name="SeekHitBox" Classes="slider-area"
                                PointerPressed="OnSeekAreaPressed"
                                PointerMoved="OnSeekAreaMoved"
                                PointerReleased="OnSeekAreaReleased"
                                PointerExited="OnSeekAreaExited"
                                IsHitTestVisible="{Binding HasTrack}" />

                            <!-- Hover Tooltip -->
                            <Border Name="HoverTooltip" Classes="slider-tooltip" Margin="0,-30,0,0">
                                <TextBlock Name="HoverTimeText" Classes="slider-tooltip-text" Text="0:00" />
                            </Border>
                        </Grid>

                        <TextBlock Grid.Column="2"
                            Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}"
                            FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                            Width="40" TextAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Bottom Info Row -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,2,0,0">
                        <!-- Queue Position -->
                        <TextBlock Text="{Binding QueuePositionText}" FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                            IsVisible="{Binding TotalTracksInQueue, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" />

                        <!-- Stream Quality & Speed -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            Classes="stream-info" IsVisible="{Binding ShowStreamInfo}">
                            <Button Classes="sidebar-btn" Padding="4,2" Command="{Binding LoadFormatsCommand}">
                                <Button.Flyout>
                                    <Flyout Placement="Top">
                                        <StackPanel Spacing="4" MinWidth="200">
                                            <TextBlock Text="{Binding L[Stream_SelectQuality]}" FontWeight="Bold" Margin="4" />
                                            <ItemsControl ItemsSource="{Binding AvailableFormats}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="sidebar-btn" HorizontalAlignment="Stretch"
                                                            Command="{Binding $parent[UserControl].DataContext.SwitchFormatCommand}"
                                                            CommandParameter="{Binding}">
                                                            <Grid ColumnDefinitions="*, Auto">
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                                <TextBlock Grid.Column="1" Text="{Binding SizeMb, StringFormat='{}{0:F1} MB'}"
                                                                    Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                                                    VerticalAlignment="Center" Margin="12,0,0,0" />
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding StreamInfo}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                    <mi:MaterialIcon Kind="ChevronUp" Width="12" Height="12" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="•" FontSize="9" Foreground="{DynamicResource BgHighlightBrush}" IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DownloadSpeedText}" FontSize="9" Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding DownloadSpeedText, Converter={StaticResource NullToVisible}}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            
                            <!-- Loading Dots -->
                            <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding IsSeekBusy}" VerticalAlignment="Center" Margin="4,0,0,0">
                                <Ellipse Classes="loading-dot" Width="4" Height="4" />
                                <Ellipse Classes="loading-dot loading-dot-2" Width="4" Height="4" />
                                <Ellipse Classes="loading-dot loading-dot-3" Width="4" Height="4" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="2" Width="30" />
                    </Grid>
                </StackPanel>

                <!-- RIGHT: Volume Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="12">
                    
                    <!-- Mute Button & Visualizer -->
                    <Button Classes="icon-btn" Command="{Binding ToggleMuteCommand}" Padding="0" Width="40" ToolTip.Tip="{Binding VolumeTooltip}">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Classes="volume-bar" Classes.boosted="{Binding IsVolumeBoosted}" Height="6" Opacity="{Binding Bar1Opacity}" />
                            <Border Classes="volume-bar" Classes.boosted="{Binding IsVolumeBoosted}" Height="9" Opacity="{Binding Bar2Opacity}" />
                            <Border Classes="volume-bar" Classes.boosted="{Binding IsVolumeBoosted}" Height="12" Opacity="{Binding Bar3Opacity}" />
                            <Border Classes="volume-bar" Classes.boosted="{Binding IsVolumeBoosted}" Height="15" Opacity="{Binding Bar4Opacity}" />
                            <Border Classes="volume-bar" Classes.boosted="{Binding IsVolumeBoosted}" Height="18" Opacity="{Binding Bar5Opacity}" Width="{Binding Bar5Thickness}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                                        <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="BackEaseOut" />
                                        <BrushTransition Property="Background" Duration="0:0:0.2" />
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Volume Slider -->
                    <Grid Width="{Binding VolumeSliderWidth}" Height="24">
                        <Grid.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Width" Duration="0:0:0.4" Easing="CubicEaseOut" />
                            </Transitions>
                        </Grid.Transitions>

                        <Panel VerticalAlignment="Center" Height="12">
                            <Border Classes="slider-track" Background="{DynamicResource BgHighlightBrush}" />
                            <Canvas VerticalAlignment="Center" ClipToBounds="True" Height="4">
                                <Border Name="VolumeBar" Classes="slider-fill" />
                            </Canvas>
                            <Canvas VerticalAlignment="Center" ClipToBounds="False">
                                <Ellipse Name="VolumeThumb" Classes="slider-thumb" Canvas.Top="-6" />
                            </Canvas>
                        </Panel>

                        <!-- Hit Area -->
                        <Border Name="VolumeHitBox" Classes="slider-area"
                            PointerPressed="OnVolumeAreaPressed"
                            PointerMoved="OnVolumeAreaMoved"
                            PointerReleased="OnVolumeAreaReleased"
                            PointerExited="OnVolumeAreaExited" />

                        <!-- Tooltip -->
                        <Border Name="VolumeTooltip" Classes="slider-tooltip" Margin="0,-30,0,0">
                            <TextBlock Name="VolumeTooltipText" Classes="slider-tooltip-text" Text="50%" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>