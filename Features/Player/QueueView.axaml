<!-- QueueView.axaml - УПРОЩЁННАЯ ВЕРСИЯ -->
<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Player"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:controls="using:LMP.UI.Controls"
    x:Class="LMP.Features.Player.QueueView"
    x:DataType="vm:QueueViewModel"
    x:CompileBindings="True">

    <Grid>
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center"
            VerticalAlignment="Center" Spacing="16">
            <mi:MaterialIcon Kind="PlaylistMusicOutline" Width="64" Height="64"
                Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding L[Queue_Empty]}" FontSize="20" FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" />
                <TextBlock Text="{Binding L[Queue_EmptySubtitle]}" FontSize="14"
                    Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"
                    Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <Grid RowDefinitions="Auto, *" IsVisible="{Binding !IsEmpty}">

            <!-- HEADER + COMPACT FILTER -->
            <StackPanel Grid.Row="0" Margin="24,24,24,8" Spacing="12">
                <!-- Title Row -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding L[Queue_Title]}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{Binding L[Queue_NowPlaying]}" FontSize="12"
                            Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Button Command="{Binding ShuffleQueueCommand}" Classes="icon-btn"
                            ToolTip.Tip="{Binding L[Queue_Shuffle]}">
                            <mi:MaterialIcon Kind="Shuffle" Width="20" Height="20" />
                        </Button>
                        <Button Command="{Binding DownloadAllCommand}" Classes="icon-btn"
                            ToolTip.Tip="{Binding L[Queue_DownloadAll]}">
                            <mi:MaterialIcon Kind="DownloadOutline" Width="20" Height="20" />
                        </Button>
                        <Button Command="{Binding ClearQueueCommand}" Classes="icon-btn"
                            ToolTip.Tip="{Binding L[Queue_Clear]}">
                            <mi:MaterialIcon Kind="Broom" Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- COMPACT FILTER STRIP -->
                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="6" Height="32">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <mi:MaterialIcon Kind="Magnify" Width="14" Height="14"
                            Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0" />
                        <TextBox Grid.Column="1" Classes="filter-ghost" Text="{Binding FilterQuery}"
                            Watermark="{Binding L[Search_LocalFilterTitle]}" FontSize="12" />

                        <!-- Toggle Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                            <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="All"
                                Classes="filter-type-btn"
                                Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=All}"
                                ToolTip.Tip="All">
                                <mi:MaterialIcon Kind="AllInclusive" Width="14" Height="14" />
                            </Button>
                            <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="Music"
                                Classes="filter-type-btn"
                                Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=Music}"
                                ToolTip.Tip="Music">
                                <mi:MaterialIcon Kind="MusicNote" Width="14" Height="14" />
                            </Button>
                            <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="Video"
                                Classes="filter-type-btn"
                                Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=Video}"
                                ToolTip.Tip="Video">
                                <mi:MaterialIcon Kind="Movie" Width="14" Height="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ★ ИСПОЛЬЗУЕМ TrackListControl ВМЕСТО СВОЕГО ListBox -->
            <controls:TrackListControl
                Grid.Row="1"
                Margin="24,0"
                Items="{Binding QueueItems}"
                IsLoading="False"
                IsLoadingMore="False"
                ReachedEnd="True"
                UseInternalScroll="True"
                EnableSmoothLoading="False"
                IsQueueContext="True" 
                EnableReordering="{Binding CanReorderItems}"
                MoveItemCommand="{Binding MoveItemCommand}" />
                
        </Grid>
    </Grid>
</UserControl>