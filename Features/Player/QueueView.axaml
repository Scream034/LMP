<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Player"
    xmlns:svm="using:MyLiteMusicPlayer.Features.Shared"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:controls="using:MyLiteMusicPlayer.UI.Controls"
    x:Class="MyLiteMusicPlayer.Features.Player.QueueView"
    x:DataType="vm:QueueViewModel"
    x:CompileBindings="True">

    <Grid>
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center"
            VerticalAlignment="Center" Spacing="16">
            <mi:MaterialIcon Kind="PlaylistMusicOutline" Width="64" Height="64"
                Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding L[Queue_Empty]}" FontSize="20" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" />
                <TextBlock Text="{Binding L[Queue_EmptySubtitle]}" FontSize="14"
                    Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"
                    Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <Grid RowDefinitions="Auto, *" IsVisible="{Binding !IsEmpty}">
            <!-- Header -->
            <Grid Grid.Row="0" Margin="24,24,24,16" ColumnDefinitions="*, Auto">

                <!-- Titles -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{Binding L[Queue_Title]}" FontSize="32" FontWeight="Bold"
                        TextTrimming="CharacterEllipsis" MaxLines="1" />
                    <TextBlock Text="{Binding L[Queue_NowPlaying]}" FontSize="13"
                        Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"
                        FontWeight="SemiBold" />
                </StackPanel>

                <!-- Actions Toolbar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">

                    <Button Command="{Binding ShuffleQueueCommand}" Classes="icon-btn"
                        ToolTip.Tip="{Binding L[Queue_Shuffle]}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Shuffle" Width="20" Height="20" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DownloadAllCommand}" Classes="icon-btn"
                        ToolTip.Tip="{Binding L[Queue_DownloadAll]}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="DownloadOutline" Width="20" Height="20" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ClearQueueCommand}" Classes="icon-btn"
                        ToolTip.Tip="{Binding L[Queue_Clear]}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Broom" Width="20" Height="20" />
                            <TextBlock Text="{Binding L[Queue_Clear]}" VerticalAlignment="Center"
                                IsVisible="{Binding $parent[UserControl].Bounds.Width, Converter={StaticResource GreaterThanConverter}, ConverterParameter=500}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Custom Queue ListBox with Drag&Drop and Delete support -->
            <ListBox Grid.Row="1" Margin="24,0"
                x:Name="QueueListBox"
                ItemsSource="{Binding QueueItems}"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Name="PART_ContentPresenter"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Content="{TemplateBinding Content}"
                                    Padding="{TemplateBinding Padding}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </ControlTemplate>
                        </Setter>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="svm:TrackItemViewModel">
                        <Grid ColumnDefinitions="*, Auto" Background="Transparent">

                            <!-- Track Content (Reuse existing ContentTemplate logic or
                            ContentControl) -->
                            <!-- We wrap it in a border for Hover effect -->
                            <Border Grid.Column="0" Classes="track-row"
                                Classes.isActive="{Binding IsActive}"
                                Background="Transparent" CornerRadius="6" Padding="4,2">
                                <ContentControl Content="{Binding}" />

                                <Border.Styles>
                                    <Style Selector="Border.track-row:pointerover">
                                        <Setter Property="Background" Value="#1AFFFFFF" />
                                    </Style>
                                    <Style Selector="Border.track-row.isActive">
                                        <Setter Property="Background"
                                            Value="{StaticResource BgElevatedBrush}" />
                                    </Style>
                                </Border.Styles>
                            </Border>

                            <!-- Delete Button (Only visible on hover over the row) -->
                            <Button Grid.Column="1"
                                Classes="icon-btn"
                                Width="32" Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding $parent[UserControl].((vm:QueueViewModel)DataContext).RemoveTrackCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding L[Queue_Remove]}"> <!-- Tooltip: Remove -->
                                <!-- Иконка КРЕСТИК (Close) или КОРЗИНА (Delete), а не Плюс -->
                                <mi:MaterialIcon Kind="Close" Width="16" Height="16"
                                    Foreground="{StaticResource TextMutedBrush}" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
