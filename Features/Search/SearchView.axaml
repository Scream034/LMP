<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Search"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Core.Behaviors"
    xmlns:controls="using:MyLiteMusicPlayer.UI.Controls"
    x:Class="MyLiteMusicPlayer.Features.Search.SearchView"
    x:DataType="vm:SearchViewModel"
    x:CompileBindings="True"
    x:Name="SearchRoot">

    <Grid RowDefinitions="Auto, *">
        <!-- HEADER + FILTERS -->
        <StackPanel Grid.Row="0" Margin="24,24,24,10">
            <TextBlock Text="{Binding L[Search_Title]}" FontSize="32" FontWeight="Bold"
                Margin="0,0,0,16" />

            <!-- Global Search Box -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Classes="search-box"
                    Watermark="{Binding L[Search_Placeholder]}"
                    Text="{Binding SearchQuery}"
                    Width="400" CornerRadius="20" Padding="15,10">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>

                <Button Command="{Binding SearchCommand}" Classes="icon-btn"
                    Width="44" Height="44" Background="{DynamicResource BgElevatedBrush}"
                    ToolTip.Tip="{Binding L[Search_Button]}">
                    <mi:MaterialIcon Kind="Magnify" Width="24" Height="24" />
                </Button>

                <Button Command="{Binding ForceSearchCommand}"
                    Classes="icon-btn"
                    Width="44" Height="44"
                    Background="{DynamicResource BgElevatedBrush}"
                    IsVisible="{Binding ShowForceSearchButton}"
                    ToolTip.Tip="{Binding L[Search_ForceRefresh]}">
                    <mi:MaterialIcon Kind="Refresh" Width="20" Height="20"
                        Foreground="{DynamicResource AccentBrush}" />
                </Button>
            </StackPanel>

            <!-- Info & History -->
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0"
                IsVisible="{Binding IsFromCache}"
                Opacity="0.6">
                <mi:MaterialIcon Kind="DatabaseOutline" Width="14" Height="14"
                    Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding L[Search_FromCache]}"
                    FontSize="12"
                    Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Disabled"
                Margin="0,12,0,0" IsVisible="{Binding RecentSearches.Count}">
                <ItemsControl ItemsSource="{Binding RecentSearches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="16"
                                Padding="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Command="{Binding #SearchRoot.DataContext.HistoryClickCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        Content="{Binding}"
                                        Padding="12,6"
                                        Foreground="{DynamicResource TextSecondaryBrush}" />

                                    <Button
                                        Command="{Binding #SearchRoot.DataContext.RemoveHistoryCommand}"
                                        CommandParameter="{Binding}"
                                        Classes="icon-btn" Width="24" Height="24"
                                        Margin="0,0,4,0" Background="Transparent">
                                        <mi:MaterialIcon Kind="Close" Width="14" Height="14"
                                            Foreground="{DynamicResource TextMutedBrush}" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Error Message -->
            <Border
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{DynamicResource SystemErrorBgBrush}" CornerRadius="8" Padding="16"
                Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <mi:MaterialIcon Kind="AlertCircle" Width="20" Height="20"
                        Foreground="{DynamicResource SystemErrorBrush}" />
                    <TextBlock Text="{Binding ErrorMessage}"
                        Foreground="{DynamicResource SystemErrorBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            
           <!-- LOCAL FILTER BAR (Replaced) -->
            <StackPanel Margin="0,24,0,0" Spacing="12" IsVisible="{Binding HasResults}">
                <TextBlock Text="{Binding L[Search_LocalFilterTitle]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                
                <controls:FilterBar GroupName="SearchFilterGroup" />
            </StackPanel>

        </StackPanel>

        <!-- LIST AREA -->
        <ScrollViewer Grid.Row="1" Margin="24,0">
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>

            <controls:TrackListControl
                Items="{Binding Items}"
                IsLoading="{Binding IsLoading}"
                IsLoadingMore="{Binding IsLoadingMore}"
                IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
                ReachedEnd="{Binding ReachedEnd}"
                LoadMoreCommand="{Binding LoadMoreCommand}"
                UseInternalScroll="False"
                UseSearchLoader="True"
                EnableSmoothLoading="{Binding EnableSmoothLoading}" />
        </ScrollViewer>
    </Grid>
</UserControl>