<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Search"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:LMP.Core.Behaviors"
    xmlns:controls="using:LMP.UI.Controls"
    x:Class="LMP.Features.Search.SearchView"
    x:DataType="vm:SearchViewModel"
    x:CompileBindings="True"
    x:Name="SearchRoot">

    <Grid RowDefinitions="Auto, *">
        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="24,24,24,8">
            <TextBlock Text="{Binding L[Search_Title]}" FontSize="28" FontWeight="Bold"
                Margin="0,0,0,16" />

            <!-- SOURCE TABS -->
            <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" Padding="4"
                Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <RadioButton Classes="source-tab" GroupName="SearchSource"
                        IsChecked="{Binding Source, Converter={StaticResource EnumToBool}, ConverterParameter=YouTubeMusic}"
                        Command="{Binding SetSourceCommand}" CommandParameter="YouTubeMusic">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Music" Width="18" Height="18" />
                            <TextBlock Text="YouTube Music" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Classes="source-tab" GroupName="SearchSource"
                        IsChecked="{Binding Source, Converter={StaticResource EnumToBool}, ConverterParameter=YouTube}"
                        Command="{Binding SetSourceCommand}" CommandParameter="YouTube">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Youtube" Width="18" Height="18" />
                            <TextBlock Text="YouTube" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Classes="source-tab" GroupName="SearchSource"
                        IsChecked="{Binding Source, Converter={StaticResource EnumToBool}, ConverterParameter=Local}"
                        Command="{Binding SetSourceCommand}" CommandParameter="Local">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="FolderMusic" Width="18" Height="18" />
                            <TextBlock
                                Text="{Binding L[Search_LocalFiles], FallbackValue='Local Files'}" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Search Box -->
            <Grid ColumnDefinitions="*, Auto" MaxWidth="600" HorizontalAlignment="Left">
                <TextBox Classes="search-box"
                    Watermark="{Binding L[Search_Placeholder]}"
                    Text="{Binding SearchQuery}"
                    CornerRadius="20" Padding="15,10">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                    <TextBox.InnerLeftContent>
                        <mi:MaterialIcon Kind="{Binding SourceIcon}" Width="18" Height="18"
                            Foreground="{DynamicResource TextMutedBrush}" Margin="8,0,0,0" />
                    </TextBox.InnerLeftContent>
                    <TextBox.InnerRightContent>
                        <Button Command="{Binding SearchCommand}" Classes="icon-btn"
                            Margin="0,0,4,0" Height="30" Width="30">
                            <mi:MaterialIcon Kind="Magnify" Width="20" Height="20" />
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>

                <Button Grid.Column="1" Command="{Binding ForceSearchCommand}" Classes="icon-btn"
                    Margin="8,0,0,0"
                    IsVisible="{Binding ShowForceSearchButton}"
                    ToolTip.Tip="{Binding L[Search_ForceRefresh]}">
                    <mi:MaterialIcon Kind="Refresh" Width="20" Height="20"
                        Foreground="{DynamicResource AccentBrush}" />
                </Button>
            </Grid>

            <!-- Offline mode indicator -->
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,8,0,0"
                IsVisible="{Binding IsOfflineMode}" Opacity="0.8">
                <mi:MaterialIcon Kind="WifiOff" Width="14" Height="14"
                    Foreground="{DynamicResource SystemWarnOrangeBrush}" />
                <TextBlock
                    Text="{Binding L[Search_OfflineMode], FallbackValue='Searching local library only'}"
                    FontSize="12" Foreground="{DynamicResource SystemWarnOrangeBrush}" />
            </StackPanel>

            <!-- Recent Searches -->
            <ItemsControl ItemsSource="{Binding RecentSearches}" Margin="0,12,0,0"
                MaxWidth="600" HorizontalAlignment="Left"
                IsVisible="{Binding !IsOfflineMode}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Classes="chip" Content="{Binding}"
                            Command="{Binding #SearchRoot.DataContext.HistoryClickCommand}"
                            CommandParameter="{Binding}">
                            <Button.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Remove"
                                        Command="{Binding #SearchRoot.DataContext.RemoveHistoryCommand}"
                                        CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <mi:MaterialIcon Kind="Delete" Width="16" Height="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.ContextFlyout>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Cache Indicator -->
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,4,0,0"
                IsVisible="{Binding IsFromCache}" Opacity="0.6">
                <mi:MaterialIcon Kind="DatabaseOutline" Width="14" Height="14"
                    Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding L[Search_FromCache]}" FontSize="12"
                    Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <!-- Error Message -->
            <Border
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{DynamicResource SystemErrorBgBrush}" CornerRadius="8" Padding="12"
                Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="AlertCircle" Width="18" Height="18"
                        Foreground="{DynamicResource SystemErrorBrush}" />
                    <TextBlock Text="{Binding ErrorMessage}"
                        Foreground="{DynamicResource SystemErrorBrush}" VerticalAlignment="Center"
                        FontSize="13" />
                </StackPanel>
            </Border>

            <!-- Local text filter -->
            <controls:FilterBar
                Margin="0,16,0,0"
                IsVisible="{Binding HasResults}"
                MaxWidth="600"
                HorizontalAlignment="Left"
                FilterText="{Binding FilterQuery}"
                Watermark="{Binding L[Search_LocalFilterTitle]}"
                IconKind="FilterVariant" />
        </StackPanel>

        <!-- LIST -->
        <ScrollViewer Grid.Row="1" Margin="24,0">
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>
            <controls:TrackListControl
                Items="{Binding Items}"
                IsLoading="{Binding IsLoading}"
                IsLoadingMore="{Binding IsLoadingMore}"
                IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
                ReachedEnd="{Binding ReachedEnd}"
                LoadMoreCommand="{Binding LoadMoreCommand}"
                UseInternalScroll="False"
                UseSearchLoader="True"
                EnableSmoothLoading="{Binding EnableSmoothLoading}" />
        </ScrollViewer>
    </Grid>
</UserControl>