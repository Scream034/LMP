<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Search"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:LMP.Core.Behaviors"
    xmlns:controls="using:LMP.UI.Controls"
    x:Class="LMP.Features.Search.SearchView"
    x:DataType="vm:SearchViewModel"
    x:CompileBindings="True"
    x:Name="SearchRoot">

    <Grid RowDefinitions="Auto, *">
        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="24,24,24,8">
            <TextBlock Text="{Binding L[Search_Title]}" FontSize="28" FontWeight="Bold"
                Margin="0,0,0,12" />

            <!-- Global Search Box -->
            <Grid ColumnDefinitions="*, Auto" MaxWidth="600" HorizontalAlignment="Left">
                <TextBox Classes="search-box" Watermark="{Binding L[Search_Placeholder]}"
                    Text="{Binding SearchQuery}" CornerRadius="20" Padding="15,10">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                    <TextBox.InnerRightContent>
                        <Button Command="{Binding SearchCommand}" Classes="icon-btn"
                            Margin="0,0,4,0" Height="30" Width="30">
                            <mi:MaterialIcon Kind="Magnify" Width="20" Height="20" />
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>

                <Button Grid.Column="1" Command="{Binding ForceSearchCommand}" Classes="icon-btn"
                    Margin="8,0,0,0"
                    IsVisible="{Binding ShowForceSearchButton}"
                    ToolTip.Tip="{Binding L[Search_ForceRefresh]}">
                    <mi:MaterialIcon Kind="Refresh" Width="20" Height="20"
                        Foreground="{DynamicResource AccentBrush}" />
                </Button>
            </Grid>

            <!-- History / Error blocks -->
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,8,0,0"
                IsVisible="{Binding IsFromCache}" Opacity="0.6">
                <mi:MaterialIcon Kind="DatabaseOutline" Width="14" Height="14"
                    Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding L[Search_FromCache]}" FontSize="12"
                    Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <Border
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{DynamicResource SystemErrorBgBrush}" CornerRadius="8" Padding="12"
                Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="AlertCircle" Width="18" Height="18"
                        Foreground="{DynamicResource SystemErrorBrush}" />
                    <TextBlock Text="{Binding ErrorMessage}"
                        Foreground="{DynamicResource SystemErrorBrush}" VerticalAlignment="Center"
                        FontSize="13" />
                </StackPanel>
            </Border>

            <!-- COMPACT LOCAL FILTER (Only when results exist) -->
            <Border Margin="0,16,0,0" IsVisible="{Binding HasResults}"
                Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Height="36"
                MaxWidth="600" HorizontalAlignment="Left">
                <Grid ColumnDefinitions="Auto, *, Auto" Width="500">
                    <mi:MaterialIcon Kind="FilterVariant" Width="16" Height="16"
                        Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,4,0" />

                    <TextBox Grid.Column="1" Classes="filter-ghost" Text="{Binding FilterQuery}"
                        Watermark="{Binding L[Search_LocalFilterTitle]}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="4">
                        <!-- All -->
                        <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="All"
                            Classes="filter-type-btn"
                            Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=All}">
                            <mi:MaterialIcon Kind="AllInclusive" Width="16" Height="16" />
                        </Button>
                        
                        <!-- Music -->
                        <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="Music"
                            Classes="filter-type-btn"
                            Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=Music}">
                            <mi:MaterialIcon Kind="MusicNote" Width="16" Height="16" />
                        </Button>
                        
                        <!-- Video -->
                        <Button Command="{Binding SetFilterTypeCommand}" CommandParameter="Video"
                            Classes="filter-type-btn"
                            Classes.active="{Binding FilterType, Converter={StaticResource EnumToBool}, ConverterParameter=Video}">
                            <mi:MaterialIcon Kind="Movie" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- LIST AREA -->
        <ScrollViewer Grid.Row="1" Margin="24,0">
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>
            <controls:TrackListControl
                Items="{Binding Items}"
                IsLoading="{Binding IsLoading}"
                IsLoadingMore="{Binding IsLoadingMore}"
                IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
                ReachedEnd="{Binding ReachedEnd}"
                LoadMoreCommand="{Binding LoadMoreCommand}"
                UseInternalScroll="False"
                UseSearchLoader="True"
                EnableSmoothLoading="{Binding EnableSmoothLoading}" />
        </ScrollViewer>
    </Grid>
</UserControl>