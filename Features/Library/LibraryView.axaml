<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LMP.Features.Library"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:local="using:LMP.Core.Converters"
    x:Class="LMP.Features.Library.LibraryView"
    x:DataType="vm:LibraryViewModel"
    x:CompileBindings="True">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="24,24,24,8">
            <StackPanel>
                <TextBlock Text="{Binding L[Library_Title]}"
                    FontSize="28" FontWeight="Bold"
                    RenderOptions.TextRenderingMode="Antialias"
                    Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding SyncStatus}"
                    FontSize="12"
                    Foreground="{DynamicResource TextMutedBrush}"
                    IsVisible="{Binding IsSyncing}"
                    Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <!-- Sync Button (Unified Crossfade Style) -->
                <Button Command="{Binding SyncAccountPlaylistsCommand}"
                    Classes="icon-btn"
                    ToolTip.Tip="{Binding L[Library_SyncYoutube]}"
                    Width="36" Height="36">
                    <Panel Width="22" Height="22">
                        <!-- Static Icon (Visible when NOT syncing) -->
                        <mi:MaterialIcon Kind="CloudSync" Width="22" Height="22"
                            IsVisible="{Binding !IsSyncing}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <!-- Animated Icon Container (Visible when syncing) -->
                        <Panel IsVisible="{Binding IsSyncing}" Width="22" Height="22">
                            <!-- State A: Accent BG, Dark Cloud -->
                            <Panel>
                                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource AccentBrush}" />
                                <mi:MaterialIcon Kind="Cloud" Width="14" Height="14" Foreground="{DynamicResource TextDarkBrush}" 
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Panel>

                            <!-- State B: Dark BG, Accent Cloud (Overlay) -->
                            <Panel Classes="cloud-crossfade-overlay">
                                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BgSecondaryBrush}" />
                                <mi:MaterialIcon Kind="Cloud" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Panel>
                        </Panel>
                    </Panel>
                </Button>

                <!-- Create Button -->
                <Button Command="{Binding OpenCreateCommand}"
                    Classes="icon-btn"
                    ToolTip.Tip="{Binding L[Library_CreatePlaylist]}"
                    IsEnabled="{Binding !IsSyncing}">
                    <mi:MaterialIcon Kind="Plus" Width="20" Height="20" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Sync Progress Bar -->
        <Grid Grid.Row="1" Height="3" Margin="24,0" IsVisible="{Binding IsSyncing}">
            <Border Background="{DynamicResource BgHighlightBrush}" CornerRadius="1.5" />
            <Border Background="{DynamicResource AccentBrush}"
                CornerRadius="1.5"
                HorizontalAlignment="Left">
                <Border.Width>
                    <MultiBinding>
                        <MultiBinding.Converter>
                            <local:ProgressToWidthConverter />
                        </MultiBinding.Converter>
                        <Binding Path="SyncProgress" />
                        <Binding Path="$parent[Grid].Bounds.Width" />
                    </MultiBinding>
                </Border.Width>
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="CubicEaseOut" />
                    </Transitions>
                </Border.Transitions>
            </Border>
        </Grid>

        <!-- Content -->
        <Panel Grid.Row="2" Margin="0,8,0,0">
            <!-- Skeleton (Initial) -->
            <ScrollViewer IsVisible="{Binding IsSyncing}">
                <StackPanel Margin="24,16,24,100">
                    <WrapPanel Orientation="Horizontal">
                        <Border Width="160" Height="220" Margin="0,0,16,16"
                            Background="{DynamicResource BgElevatedBrush}"
                            CornerRadius="8" Classes="skeleton" Opacity="0.7" />
                        <Border Width="160" Height="220" Margin="0,0,16,16"
                            Background="{DynamicResource BgElevatedBrush}"
                            CornerRadius="8" Classes="skeleton" Opacity="0.5">
                            <Border.Effect>
                                <BlurEffect Radius="2" />
                            </Border.Effect>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Main Content -->
            <ScrollViewer IsVisible="{Binding !IsSyncing}">
                <StackPanel Margin="24,0,24,100">
                    <!-- Create Form -->
                    <Border IsVisible="{Binding IsCreatingPlaylist}"
                        Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding L[Library_NewPlaylistName]}" FontWeight="Medium" />
                            <TextBox Text="{Binding NewPlaylistName}" Watermark="{Binding L[Library_PlaylistNameHint]}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="{Binding L[Button_Cancel]}" Command="{Binding CancelCreateCommand}" />
                                <Button Content="{Binding L[Button_Create]}" Command="{Binding SavePlaylistCommand}" Classes="accent accent-base" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Playlist Grid -->
                    <ItemsControl ItemsSource="{Binding Playlists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}" Classes="playlist-card" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel IsVisible="{Binding !Playlists.Count}" HorizontalAlignment="Center" Margin="0,60">
                        <mi:MaterialIcon Kind="PlaylistMusic" Width="64" Height="64" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding L[Library_Empty]}" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Panel>
    </Grid>
</UserControl>
