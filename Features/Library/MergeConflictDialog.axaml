<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="using:MyLiteMusicPlayer.Features.Library"
        x:Class="MyLiteMusicPlayer.Features.Library.MergeConflictDialog"
        x:DataType="d:MergeConflictViewModel"
        Title="{Binding L[Conflict_Title]}"
        Width="450" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgBaseBrush}">

    <Border BorderBrush="{DynamicResource BgHighlightBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
        <Grid RowDefinitions="Auto, *, Auto">
            <TextBlock Grid.Row="0" Text="{Binding L[Conflict_Header]}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            
            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" 
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,24,0,0">
                <Button Content="{Binding L[Conflict_Skip]}" Command="{Binding SkipCommand}" Background="Transparent"/>
                <Button Content="{Binding L[Conflict_Duplicate]}" Command="{Binding DuplicateCommand}" />
                <Button Content="{Binding L[Conflict_Merge]}" Command="{Binding MergeCommand}" Classes="accent"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
