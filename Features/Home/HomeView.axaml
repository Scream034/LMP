<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MyLiteMusicPlayer.Features.Home"
    xmlns:mi="using:Material.Icons.Avalonia"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:b="using:MyLiteMusicPlayer.Core.Behaviors"
    xmlns:controls="using:MyLiteMusicPlayer.UI.Controls"
    x:Class="MyLiteMusicPlayer.Features.Home.HomeView"
    x:DataType="vm:HomeViewModel"
    x:CompileBindings="True">

    <Grid RowDefinitions="Auto, *">

        <!-- 1. HEADER (Greeting, Categories, Debug) -->
        <StackPanel Grid.Row="0" Margin="24,16,24,0">
            <!-- Greeting & Debug Button -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                <TextBlock Text="{Binding Greeting}"
                    FontSize="32" FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}" />

                <Button Grid.Column="1"
                    Command="{Binding ToggleDebugCommand}"
                    Background="Transparent" Padding="8"
                    Cursor="Hand">
                    <mi:MaterialIcon Kind="Bug" Width="20" Height="20"
                        Foreground="{Binding ShowDebugInfo, Converter={StaticResource BoolToSelector}, ConverterParameter='AccentBrush|TextMutedBrush'}" />
                </Button>
            </Grid>

            <!-- Debug Panel -->
            <Border IsVisible="{Binding ShowDebugInfo}"
                Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" Padding="16,12"
                Margin="0,0,0,16">
                <Grid ColumnDefinitions="*, *, *, *">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding L[Home_Debug_Total]}" FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.TotalTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding L[Home_Debug_Displayed]}" FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.DisplayedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding L[Home_Debug_Cached]}" FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.CachedTracks}" FontSize="18"
                            FontWeight="Bold" Foreground="{DynamicResource SystemWarnOrangeBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="{Binding L[Home_Debug_Memory]}" FontSize="10"
                            Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Stats.MemoryUsage}" FontSize="14"
                            FontWeight="Bold" Foreground="{DynamicResource SystemInfoBlueBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Categories -->
            <ListBox ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent" Margin="0,0,0,16"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryItem">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="CornerRadius" Value="20" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BgPrimaryBrush}" />
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </StackPanel>

        <!-- 2. MAIN CONTENT AREA (External Scroll) -->
        <ScrollViewer Grid.Row="1" Margin="24,0,24,0">
            <i:Interaction.Behaviors>
                <b:InfiniteScrollBehavior Command="{Binding LoadMoreCommand}" Threshold="300" />
            </i:Interaction.Behaviors>

            <!-- Централизованный список треков -->
            <controls:TrackListControl
                Items="{Binding ActiveTracks}"
                IsLoading="{Binding IsLoading}"
                IsLoadingMore="{Binding IsLoadingMore}"
                IsFetchingFromNetwork="{Binding IsFetchingFromNetwork}"
                ReachedEnd="{Binding ReachedEnd}"
                LoadMoreCommand="{Binding LoadMoreCommand}"
                UseInternalScroll="False"
                EnableSmoothLoading="{Binding EnableSmoothLoading}" />
        </ScrollViewer>
    </Grid>
</UserControl>
